@{
    ViewData["Title"] = "Home Page";
}
<style>
        body { background-color: #f8f9fa; }
        .card { border: none; border-radius: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        .stat-card { transition: transform 0.2s; }
        .stat-card:hover { transform: translateY(-5px); }
    </style>
<div class="text-center">
  <div class="container py-5">
    <h2 class="mb-4">System Overview</h2>

    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card stat-card bg-primary text-white p-3">
                <h5>Total Website</h5>
                <h2 class="fw-bold">12</h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stat-card bg-success text-white p-3">
                <h5>Total Publication</h5>
                <h2 class="fw-bold">458</h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stat-card bg-info text-white p-3">
                <h5>Total News</h5>
                <h2 class="fw-bold">1,240</h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stat-card bg-warning text-dark p-3">
                <h5>Total Clients</h5>
                <h2 class="fw-bold">89</h2>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card p-4 h-100">
                <h5 class="mb-3">Last Uploaded Files</h5>
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>File Name</th>
                                <th>Count of Record</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>001</td>
                                <td>Q1_Report_v2.csv</td>
                                <td class="text-center">1,200</td>
                                <td><button class="btn btn-sm btn-outline-primary">View</button></td>
                            </tr>
                            <tr>
                                <td>002</td>
                                <td>Client_Leads_April.xlsx</td>
                                <td class="text-center">850</td>
                                <td><button class="btn btn-sm btn-outline-primary">View</button></td>
                            </tr>
                            <tr>
                                <td>003</td>
                                <td>Site_Traffic_Logs.json</td>
                                <td class="text-center">4,320</td>
                                <td><button class="btn btn-sm btn-outline-primary">View</button></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card p-4 h-100">
                <h5 class="mb-3">Total Storage</h5>
                <canvas id="storageChart"></canvas>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card p-4">
                <h5 class="mb-3">Monthly Visits</h5>
                <canvas id="visitsChart"></canvas>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card p-4">
                <h5 class="mb-3">Quarterly Revenue ($)</h5>
                <canvas id="revenueChart"></canvas>
            </div>
        </div>
    </div>
</div>

<script>
    // 1. Storage Pie Chart (40% used)
    const storageCtx = document.getElementById('storageChart').getContext('2d');
    new Chart(storageCtx, {
        type: 'pie',
        data: {
            labels: ['Used Storage', 'Available'],
            datasets: [{
                data: [40, 60],
                backgroundColor: ['#0d6efd', '#e9ecef'],
                hoverOffset: 4
            }]
        }
    });

    // 2. Monthly Visits Line Chart
    const visitsCtx = document.getElementById('visitsChart').getContext('2d');
    new Chart(visitsCtx, {
        type: 'line',
        data: {
            labels: ['Jan', 'Feb', 'March', 'April', 'May', 'June'],
            datasets: [{
                label: 'Visits',
                data: [50, 60, 40, 70, 85, 90],
                borderColor: '#198754',
                tension: 0.3,
                fill: true,
                backgroundColor: 'rgba(25, 135, 84, 0.1)'
            }]
        }
    });

    // 3. Quarterly Revenue Column (Bar) Chart
    const revenueCtx = document.getElementById('revenueChart').getContext('2d');
    new Chart(revenueCtx, {
        type: 'bar',
        data: {
            labels: ['Q1', 'Q2', 'Q3', 'Q4'],
            datasets: [{
                label: 'Revenue',
                data: [1500, 2400, 2300, 1700],
                backgroundColor: '#ffc107'
            }]
        },
        options: {
            scales: {
                y: { beginAtZero: true }
            }
        }
    });
</script>
</div>

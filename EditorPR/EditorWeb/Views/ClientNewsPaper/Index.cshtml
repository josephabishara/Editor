@model EditorViewModelLayer.MediaViewModel.ClientNewsPaperListDTO
@using EditorViewModelLayer.MediaViewModel
@using Microsoft.AspNetCore.Mvc.Rendering
@using System.Text.Encodings.Web
@{
    ViewData["Title"] = "Newspaper";
    var clientId = Model.ClientId > 0 ? Model.ClientId : (ViewBag.ClientId is int v ? v : 0);

    var fTitle = ViewBag.FilterTitle as string ?? "";
    var fFrom = ViewBag.FilterDateFrom as string ?? "";
    var fTo = ViewBag.FilterDateTo as string ?? "";
    var fCat = (int)(ViewBag.FilterCategoryId ?? 0);
    var fSub = (int)(ViewBag.FilterSubId ?? 0);
    var fPub = (int)(ViewBag.FilterPubId ?? 0);
    var fCreatedFrom = ViewBag.FilterCreatedFrom as string ?? "";
    var fCreatedTo = ViewBag.FilterCreatedTo as string ?? "";

    bool isAdmin = User.IsInRole("Admin");
    bool canEdit = User.IsInRole("Admin") || User.IsInRole("Manager") || User.IsInRole("EditorWeb");

    List<SelectListItem> ToSL(List<MediaSelectOption> src)
        => src.Select(o => new SelectListItem(o.Text, o.Value, o.Selected)).ToList();

    var pubSL = ToSL(Model.PublicationOptions);
    var catSL = ToSL(Model.CategoryOptions);
    var subSL = ToSL(Model.SubCategoryOptions);
    var writerSL = ToSL(Model.WriterOptions);

    // Extract first image path from JSON Images array
    string FirstImage(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) return "";
        try { return System.Text.Json.JsonSerializer.Deserialize<List<string>>(json)?.FirstOrDefault() ?? ""; }
        catch { return ""; }
    }
}

@await Html.PartialAsync("_MediaStyles")

<style>
    .cb-col {
        width: 36px;
        text-align: center !important;
    }

    .row-cb {
        width: 16px;
        height: 16px;
        accent-color: var(--accent);
        cursor: pointer;
    }

    .sel-toolbar {
        display: none;
        align-items: center;
        gap: .75rem;
        background: #0891b2;
        color: #fff;
        border-radius: var(--radius);
        padding: .65rem 1.2rem;
        margin-bottom: 1rem;
        flex-wrap: wrap;
    }

        .sel-toolbar.visible {
            display: flex;
        }

        .sel-toolbar .sel-count {
            font-size: .85rem;
            font-weight: 700;
            flex: 1;
        }

            .sel-toolbar .sel-count span {
                background: rgba(255,255,255,.25);
                border-radius: 20px;
                padding: .15rem .6rem;
                margin-left: .4rem;
            }

    .btn-export {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        border: none;
        border-radius: 7px;
        padding: .42rem 1rem;
        font-size: .82rem;
        font-weight: 700;
        cursor: pointer;
        transition: filter .15s;
    }

        .btn-export:hover {
            filter: brightness(.9);
        }

    .btn-xl {
        background: #16a34a;
        color: #fff;
    }

    .btn-pdf {
        background: #dc2626;
        color: #fff;
    }

    .btn-desel {
        background: rgba(255,255,255,.18);
        color: #fff;
        border: 1px solid rgba(255,255,255,.35);
    }
</style>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        ✅ @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        ❌ @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="m-header">
    <div class="m-header-icon" style="background:#dbeafe;">📰</div>
    <div><h1>Newspaper</h1><p>@Model.ClientName</p></div>
    <div class="ms-auto">
        <a href="@Url.Action("ClientDashboard", "Dashboard", new { id = clientId })"
           class="btn-dashboard">← Dashboard</a>
    </div>
    @await Html.PartialAsync("_navdashboard")
</div>

<div class="stat-row">
    <div class="stat-pill sp-total"><span class="num">@Model.Total</span><span class="lbl">Total Newspapers</span></div>
    <div class="stat-pill sp-pr"><span class="num">@Model.TotalPR.ToString("N0")</span><span class="lbl">Total PR</span></div>
    <div class="stat-pill sp-ad"><span class="num">@Model.TotalAD.ToString("N0")</span><span class="lbl">Total AD</span></div>
</div>

<div class="filter-card">
    <div class="filter-title">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3" />
        </svg>
        Filter Newspapers
    </div>
    <form method="get" action="@Url.Action("Index")">
        <input type="hidden" name="clientId" value="@clientId" />
        <div class="filter-grid">
            <div class="fg"><label>Title</label><input type="text" name="title" value="@fTitle" placeholder="Search…" /></div>
            <div class="fg"><label>Date From</label><input type="date" name="dateFrom" value="@fFrom" /></div>
            <div class="fg"><label>Date To</label><input type="date" name="dateTo" value="@fTo" /></div>
            <div class="fg">
                <label>Category</label>
                <select name="categoryId" id="fCat" asp-items="catSL"
                        onchange="loadSubs(this.value,'fSub','/ClientNewsPaper/GetSubCategories')">
                    <option value="0">All</option>
                </select>
            </div>
            <div class="fg"><label>Sub Category</label><select name="subCategoryId" id="fSub" asp-items="subSL"><option value="0">All</option></select></div>
        </div>
        <br />
        <div class="filter-grid">
            <div class="fg"><label>Publication</label><select name="publicationId" asp-items="pubSL"><option value="0">All</option></select></div>
            <div class="fg"><label>Created From</label><input type="date" name="createdFrom" value="@fCreatedFrom" /></div>
            <div class="fg"><label>Created To</label><input type="date" name="createdTo" value="@fCreatedTo" /></div>
            <div class="fg" style="display:flex;gap:.4rem;">
                <button type="submit" class="btn-filter">Search</button>
            </div>
            <div class="fg" style="display:flex;gap:.4rem;">
                <a href="@Url.Action("Index", new { clientId })" class="btn-reset">Reset</a>
            </div>
        </div>
    </form>
</div>

<div class="sel-toolbar" id="selToolbar">
    <div class="sel-count">Selected <span id="selCount">0</span> newspapers</div>
    <button class="btn-export btn-xl" onclick="exportExcel()">⬇ Excel</button>
    <button class="btn-export btn-pdf" onclick="exportPDF()">⬇ PDF Report</button>
    <button class="btn-export" style="background:#0ea5e9;color:#fff;" onclick="viewAsHtml()">📄 View as HTML</button>

    <form id="duplicateForm" asp-action="Duplicate" asp-controller="ClientNewsPaper"
          method="post" style="display:inline;">
        @Html.AntiForgeryToken()
        <input type="hidden" name="clientId" value="@ViewBag.ClientId" />
        <input type="hidden" name="id" id="hdnSelectedId" value="0" />
        <button type="submit" id="btnDuplicate" disabled
                style="display:inline-flex;align-items:center;gap:.35rem;
            background:#f59e0b;color:#fff;border:none;border-radius:7px;
            padding:.38rem .85rem;font-size:.82rem;font-weight:600;
            cursor:pointer;opacity:.5;"
                onclick="return confirmDuplicate()">
            📋 Duplicate Selected
        </button>
    </form>
    @if (isAdmin)
    {
        <form id="bulkDeleteForm" asp-action="BulkDelete" asp-controller="ClientNewsPaper"
              method="post" style="display:inline;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="clientId" value="@clientId" />
            <div id="bulkDeleteIdsContainer"></div>
            <button type="button" class="btn-export" style="background:#dc2626;color:#fff;"
                    onclick="confirmBulkDelete('newspaper')">
                🗑 Delete Selected
            </button>
        </form>
    }
    <button class="btn-export btn-desel" onclick="deselectAll()">✕ Deselect All</button>
</div>

<div class="action-bar">
    <div class="result-count">Showing <strong>@Model.Items.Count()</strong> of <strong>@Model.Total</strong></div>
    @if (canEdit)
    {
        <a href="@Url.Action("Create", new { clientId })" class="btn-add">+ Add Newspaper</a>
    }
</div>

<div class="m-table-wrap">
    @if (!Model.Items.Any())
    {
        <div class="empty-state"><h3>No newspapers found</h3><p>Adjust filters or add a new newspaper.</p></div>
    }
    else
    {
        <table class="m-table" id="mainTable">
            <thead>
                <tr>
                    <th class="cb-col">
                        <input type="checkbox" class="row-cb" id="cbAll" onchange="toggleAll(this)" />
                    </th>
                    <th>#</th>
                    <th>Parent</th>
                    <th>Date</th>
                    <th>Title</th>
                    <th>Publication</th>
                    <th>Category</th>
                    <th>Sub-Category</th>
                    <th>Created By</th>
                    <th>Created At</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    var firstImg = FirstImage(item.Images);
                    var encodedContent = HtmlEncoder.Default.Encode(item.Content ?? "");
                    var encodedTitle = HtmlEncoder.Default.Encode(item.Title ?? "");

                    <tr data-id="@item.Id"
                        data-parentid="@(item.ParentId?.ToString() ?? "")"
                        data-date="@item.Date.ToString("dd-MM-yyyy")"
                        data-title="@encodedTitle"
                        data-publication="@(item.PublicationName ?? "")"
                        data-categorytype="@(item.CategoryName ?? "")"
                        data-category="@(item.CategoryName ?? "")"
                        data-subcategory="@(item.SubCategoryName ?? "")"
                        data-writer="@(item.WriterName ?? "")"
                        data-mediatype="@(item.MediaType ?? "")"
                        data-mediatier="@(item.MediaTier ?? "")"
                        data-frequency="@(item.Frequency ?? "")"
                        data-language="@(item.Language ?? "")"
                        data-circulation="@(item.Circulation ?? 0)"
                        data-reach="@item.Reach"
                        data-ad="@item.ADValue"
                        data-pr="@item.PRValue"
                        data-toning="@(item.Toning ?? "")"
                        data-articlebrand="@(item.ArticleBranding ?? "")"
                        data-headlinebrand="@(item.HeadlineBranding ?? "")"
                        data-picture="@(item.PictureinArticle ?? "")"
                        data-generation="@(item.Generation ?? "")"
                        data-pages="@item.Pages"
                        data-height="@item.Height"
                        data-width="@item.Width"
                        data-size="@(item.Height > 0 ? $"{item.Height} cm X {item.Width} col" : "")"
                        data-createdby="@(item.CreatedByUserName ?? "")"
                        data-createdat="@item.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")"
                        data-screenshot="@firstImg"
                        data-content="@encodedContent">

                        <td class="cb-col">
                            <input type="checkbox" class="row-cb row-check"
                                   value="@item.Id" onchange="onRowCheck()" />
                        </td>
                        <td class="text-muted small">@item.Id</td>
                        <td class="small">@(item.ParentId?.ToString() ?? "—")</td>
                        <td class="small text-nowrap">@item.Date.ToString("dd MMM yyyy")</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id"
                               class="fw-semibold text-decoration-none text-dark"
                               title="@item.Title">
                                @(item.Title.Length > 55 ? item.Title[..55] + "…" : item.Title)
                            </a>
                            @if (item.Publish)
                            {
                                <span class="badge bg-success ms-1" style="font-size:.7rem;">Published</span>
                            }
                        </td>
                        <td class="small">@(item.PublicationName ?? "—")</td>
                        <td class="small">@(item.CategoryName ?? "—")</td>
                        <td class="small">@(item.SubCategoryName ?? "—")</td>
                        <td class="small text-muted">@(item.CreatedByUserName ?? "—")</td>
                        <td class="small text-nowrap text-muted">
                            @item.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                        </td>
                        <td class="text-center text-nowrap">
                            <a asp-action="Details" asp-route-id="@item.Id" class="act-btn act-view" title="View">
                                <i class="fa fa-eye"></i>
                            </a>
                            @if (canEdit)
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="act-btn act-edit" title="Edit">
                                    <i class="fa fa-pencil"></i>
                                </a>
                            }
                            @if (isAdmin)
                            {
                                @if (item.Publish)
                                {
                                    <form method="post" action="@Url.Action("Unpublish")" style="display:inline;"
                                          onsubmit="return confirm('Unpublish?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="clientId" value="@clientId" />
                                        <button type="submit" class="act-btn act-unpub" title="Unpublish">📤</button>
                                    </form>
                                }
                                else
                                {
                                    <form method="post" action="@Url.Action("Publish")" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="clientId" value="@clientId" />
                                        <button type="submit" class="act-btn act-pub" title="Publish">📢</button>
                                    </form>
                                }
                                <a asp-action="Delete" asp-route-id="@item.Id" class="act-btn act-del" title="Delete">
                                    <i class="fa fa-trash"></i>
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<script src="/js/clientnewspaper-print-view.js"></script>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>
    <script>
        const clientName = "@Model.ClientName";

        // ── Checkbox helpers ─────────────────────────────────────────────────────
        function toggleAll(cb) {
            document.querySelectorAll('.row-check').forEach(c => c.checked = cb.checked);
            onRowCheck();
        }
        function deselectAll() {
            document.querySelectorAll('.row-check, #cbAll').forEach(c => { c.checked = false; c.indeterminate = false; });
            onRowCheck();
        }
        function onRowCheck() {
            const checked = document.querySelectorAll('.row-check:checked');
            const count   = checked.length;
            const all     = document.querySelectorAll('.row-check');
            document.getElementById('selCount').textContent = count;
            document.getElementById('selToolbar').classList.toggle('visible', count > 0);
            const cbAll = document.getElementById('cbAll');
            cbAll.indeterminate = count > 0 && count < all.length;
            cbAll.checked       = count === all.length && all.length > 0;
            const btnDup = document.getElementById('btnDuplicate');
            const hdnId  = document.getElementById('hdnSelectedId');
            if (count === 1) {
                hdnId.value = checked[0].value;
                btnDup.disabled = false;
                btnDup.style.opacity = '1';
            } else {
                hdnId.value = '0';
                btnDup.disabled = true;
                btnDup.style.opacity = '.5';
            }
        }
        function getSelectedRows() {
            const rows = [];
            document.querySelectorAll('.row-check:checked').forEach(cb => rows.push(cb.closest('tr').dataset));
            return rows;
        }
        function confirmDuplicate() {
            const hdnId = document.getElementById('hdnSelectedId');
            if (!hdnId.value || hdnId.value === '0') return false;
            return confirm('Duplicate this record and all its children?');
        }
        function confirmBulkDelete(label) {
            const checked = document.querySelectorAll('.row-check:checked');
            if (!checked.length) { alert(`Please select at least one ${label}.`); return; }
            if (!confirm(`Delete ${checked.length} selected ${label}(s)? This cannot be undone.`)) return;

            const container = document.getElementById('bulkDeleteIdsContainer');
            container.innerHTML = '';
            checked.forEach(cb => {
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'ids';
                input.value = cb.value;
                container.appendChild(input);
            });
            document.getElementById('bulkDeleteForm').submit();
        }

        // ── Sub-category cascade ─────────────────────────────────────────────────
        async function loadSubs(parentId, targetId, url) {
            const sel = document.getElementById(targetId);
            sel.innerHTML = '<option value="0">Loading…</option>';
            if (!parentId || parentId == '0') { sel.innerHTML = '<option value="0">All</option>'; return; }
            const data = await (await fetch(`${url}?parentId=${parentId}`)).json();
            sel.innerHTML = '<option value="0">All</option>';
            data.forEach(s => sel.innerHTML += `<option value="${s.value}">${s.text}</option>`);
        }

        // ── Excel ─────────────────────────────────────────────────────────────────
        function exportExcel() {
            const rows = getSelectedRows();
            if (!rows.length) { alert('Please select at least one newspaper.'); return; }
            const headers = [
                'Id', 'Parent ID', 'Date', 'Title', 'Publication', 'Category', 'Sub-Category', 'Writer',
                'Media Type', 'Media Tier', 'Frequency', 'Language',
                'Circulation', 'Reach', 'AD Value', 'PR Value',
                'Toning', 'Article Branding', 'Headline Branding',
                'Picture in Article', 'Generation', 'Pages', 'Height', 'Width'
            ];
            const data = rows.map(d => [
                d.id, d.parentid || '—', d.date, d.title, d.publication, d.category, d.subcategory, d.writer,
                d.mediatype, d.mediatier, d.frequency, d.language,
                d.circulation, d.reach, d.ad, d.pr,
                d.toning, d.articlebrand, d.headlinebrand,
                d.picture, d.generation, d.pages, d.height, d.width
            ]);
            const wb = XLSX.utils.book_new();
            const ws = XLSX.utils.aoa_to_sheet([headers, ...data]);
            ws['!cols'] = headers.map((_, i) => ({ wch: i === 3 ? 40 : i === 4 ? 22 : 15 }));
            XLSX.utils.book_append_sheet(wb, ws, 'Newspapers');
            XLSX.writeFile(wb, `${clientName}_Newspapers_${new Date().toISOString().slice(0,10)}.xlsx`);
        }

        // ══════════════════════════════════════════════════════════════════════
        // PDF EXPORT — EditorPR brand (#721a24 maroon), Arabic-aware
        // ══════════════════════════════════════════════════════════════════════

        let _arabicFontLoaded = false;
        const ARABIC_FONT_NAME = 'Cairo';

        async function ensureArabicFont(doc) {
            if (_arabicFontLoaded) return;
            try {
                const url = 'https://cdn.jsdelivr.net/fontsource/fonts/cairo@latest/arabic-400-normal.ttf';
                const resp = await fetch(url);
                if (!resp.ok) throw new Error('font fetch failed');
                const buf  = await resp.arrayBuffer();
                const bytes = new Uint8Array(buf);
                let binary  = '';
                for (let i = 0; i < bytes.length; i++) binary += String.fromCharCode(bytes[i]);
                const b64 = btoa(binary);
                doc.addFileToVFS('Cairo-Regular.ttf', b64);
                doc.addFont('Cairo-Regular.ttf', ARABIC_FONT_NAME, 'normal');
                _arabicFontLoaded = true;
            } catch (e) {
                console.warn('Arabic font load failed, falling back to helvetica:', e);
            }
        }

        function useArabicFont(doc, size, style) {
            const name = _arabicFontLoaded ? ARABIC_FONT_NAME : 'helvetica';
            doc.setFont(name, style || 'normal');
            doc.setFontSize(size);
        }

        function isArabic(str) {
            return /[\u0600-\u06FF\u0750-\u077F\uFB50-\uFDFF\uFE70-\uFEFF]/.test(str || '');
        }

        function fixArabic(str) {
            if (!str || !isArabic(str)) return str;
            return str.split(' ').reverse().join(' ');
        }

        function decodeContent(raw) {
            if (!raw) return '';
            try {
                const ta  = document.createElement('textarea');
                ta.innerHTML = raw;
                const div = document.createElement('div');
                div.innerHTML = ta.value;
                return (div.textContent || div.innerText || '').replace(/\s+/g,' ').trim();
            } catch { return ''; }
        }

        function imgFormat(dataUri) {
            if (!dataUri) return 'JPEG';
            if (dataUri.startsWith('data:image/png'))  return 'PNG';
            if (dataUri.startsWith('data:image/webp')) return 'WEBP';
            if (dataUri.startsWith('data:image/gif'))  return 'GIF';
            return 'JPEG';
        }
        async function loadImgB64(url) {
            if (!url) return null;
            try {
                const resp = await fetch(url);
                if (!resp.ok) return null;
                const blob = await resp.blob();
                return new Promise(res => {
                    const r = new FileReader();
                    r.onload  = () => res(r.result);
                    r.onerror = () => res(null);
                    r.readAsDataURL(blob);
                });
            } catch { return null; }
        }

        async function exportPDF() {
            const rows = getSelectedRows();
            if (!rows.length) { alert('Please select at least one newspaper.'); return; }

            const { jsPDF } = window.jspdf;

            // ── EditorPR brand colours (matches Preview.cshtml / View-as-HTML) ──────
            const MAROON    = [114, 26, 36];   // #721a24
            const WHITE     = [255, 255, 255];
            const LIGHT_GRY = [247, 247, 247]; // matches .media-card-title bg
            const BORDER    = [221, 221, 221]; // matches #ddd
            const INK       = [26, 26, 26];    // matches #1a1a1a
            const SLATE     = [136, 136, 136]; // matches #888

            const PW = 210, PH = 297, ML = 14, MR = 14, MT = 14;
            const CW = PW - ML - MR;

            const C_LW = 28, C_VW = 32, GAP = 1, ROW_H = 7.5;

            const col1X = ML;
            const col2X = ML + C_LW + C_VW + GAP;
            const col3X = col2X + C_LW + C_VW + GAP;

            const doc = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });
            await ensureArabicFont(doc);

            function drawCell(doc, x, y, label, value, shade) {
                doc.setFillColor(...MAROON);
                doc.rect(x, y, C_LW, ROW_H, 'F');
                doc.setFillColor(...(shade ? LIGHT_GRY : WHITE));
                doc.rect(x + C_LW, y, C_VW, ROW_H, 'F');
                doc.setDrawColor(...BORDER);
                doc.setLineWidth(0.25);
                doc.rect(x, y, C_LW + C_VW, ROW_H, 'S');

                doc.setFont('helvetica', 'bold');
                doc.setFontSize(6.5);
                doc.setTextColor(...WHITE);
                doc.text(String(label || ''), x + 2, y + 5);

                const valStr = String(value || '—');
                const arabic = isArabic(valStr);
                if (arabic) {
                    useArabicFont(doc, 7.5, 'normal');
                    doc.setTextColor(...INK);
                    const fixedVal = fixArabic(valStr);
                    const lines = doc.splitTextToSize(fixedVal, C_VW - 4);
                    doc.text(lines[0], x + C_LW + C_VW - 2, y + 5, { align: 'right' });
                } else {
                    doc.setFont('helvetica', 'normal');
                    doc.setFontSize(7.5);
                    doc.setTextColor(...INK);
                    const lines = doc.splitTextToSize(valStr, C_VW - 4);
                    doc.text(lines[0], x + C_LW + 2, y + 5);
                }
            }

            const imgCache = {};
            for (const d of rows) {
                const src = d.screenshot || '';
                if (src && !imgCache[src]) imgCache[src] = await loadImgB64(src);
            }

            for (let idx = 0; idx < rows.length; idx++) {
                const d = rows[idx];
                if (idx > 0) doc.addPage();

                doc.setFillColor(255, 255, 255);
                doc.rect(0, 0, PW, PH, 'F');

                let y = MT;

                doc.setFont('helvetica', 'normal');
                doc.setFontSize(8);
                doc.setTextColor(...SLATE);
                doc.text(clientName, PW - MR, y + 3, { align: 'right' });

                const titleRaw = decodeContent(d.title || 'Untitled');
                const titleArabic = isArabic(titleRaw);
                if (titleArabic) { useArabicFont(doc, 11, 'normal'); }
                else { doc.setFont('helvetica', 'bold'); doc.setFontSize(11); }
                doc.setTextColor(...INK);
                const titleFixed = titleArabic ? fixArabic(titleRaw) : titleRaw;
                const titleLines = doc.splitTextToSize(titleFixed, CW);
                titleLines.forEach((line, li) => {
                    doc.text(line, PW - MR, y + 3 + (li + 1) * 6.5, { align: 'right' });
                });
                y += 4 + titleLines.length * 6.5 + 2;

                doc.setDrawColor(...BORDER);
                doc.setLineWidth(0.5);
                doc.line(ML, y, PW - MR, y);
                y += 4;

                // 9-row grid — Created By / Created At now included
                const gridDef = [
                    [ ['Publication',        d.publication],   ['Date',              d.date],            ['Ad Value',    d.ad]          ],
                    [ ['Category Type',      d.categorytype],  ['Category',          d.category],        ['PR Value',    d.pr]          ],
                    [ ['Media Type',         d.mediatype],     ['Sub Category',      d.subcategory],     ['Circulation', d.circulation] ],
                    [ ['Frequency',          d.frequency],     ['Page Number',       d.pages],           ['Reach',       d.reach]       ],
                    [ ['Media Tier',         d.mediatier],     ['Size',              d.size],            ['Writer',      d.writer]      ],
                    [ ['Language',           d.language],      ['Tone',              d.toning],          ['Generation',  d.generation]  ],
                    [ ['Picture In Article', d.picture],       ['Headline Branding', d.headlinebrand],   ['Article Branding', d.articlebrand] ],
                    [ ['Parent ID',          d.parentid || '—'], ['Created By',      d.createdby],       ['Created At',  d.createdat]    ],
                ];

                gridDef.forEach((rowCells, ri) => {
                    const shade = ri % 2 === 1;
                    const gy    = y + ri * ROW_H;
                    drawCell(doc, col1X, gy, rowCells[0][0], rowCells[0][1], shade);
                    drawCell(doc, col2X, gy, rowCells[1][0], rowCells[1][1], shade);
                    drawCell(doc, col3X, gy, rowCells[2][0], rowCells[2][1], shade);
                });

                y += gridDef.length * ROW_H + 8;

                const bodyTitleFixed = titleArabic ? fixArabic(titleRaw) : titleRaw;
                if (titleArabic) { useArabicFont(doc, 14, 'normal'); }
                else { doc.setFont('helvetica', 'bold'); doc.setFontSize(14); }
                doc.setTextColor(...INK);
                const bodyTitleLines = doc.splitTextToSize(bodyTitleFixed, CW);
                bodyTitleLines.forEach((line, li) => {
                    doc.text(line, PW - MR, y + (li + 1) * 8, { align: 'right' });
                });
                y += bodyTitleLines.length * 8 + 5;

                const imgSrc  = d.screenshot || '';
                const imgData = imgSrc ? imgCache[imgSrc] : null;
                if (imgData) {
                    const imgW = 90, imgH = 60;
                    const imgX = (PW - imgW) / 2;
                    try {
                        doc.addImage(imgData, imgFormat(imgData), imgX, y, imgW, imgH, undefined, 'FAST');
                        y += imgH + 5;
                    } catch (e) { console.warn('Image add failed:', e); }
                }

                const contentRaw = decodeContent(d.content || '');
                if (contentRaw) {
                    const footerReserve = 28;
                    const arabicContent = isArabic(contentRaw);
                    if (arabicContent) { useArabicFont(doc, 9, 'normal'); }
                    else { doc.setFont('helvetica', 'normal'); doc.setFontSize(9); }
                    doc.setTextColor(...INK);

                    const fixedContent = arabicContent ? fixArabic(contentRaw) : contentRaw;
                    const contentLines = doc.splitTextToSize(fixedContent, CW);

                    const colW     = (CW - 4) / 2;
                    const leftX    = ML;
                    const rightX   = ML + colW + 4;
                    const lineH    = 4.5;
                    const maxLines = Math.floor((PH - y - footerReserve - 5) / lineH);

                    let lY = y + 4;
                    const half = Math.ceil(Math.min(contentLines.length, maxLines) / 2);

                    contentLines.slice(0, half).forEach(line => {
                        if (lY + lineH > PH - footerReserve) return;
                        if (arabicContent) doc.text(line, leftX + colW, lY, { align: 'right' });
                        else doc.text(line, leftX, lY);
                        lY += lineH;
                    });

                    lY = y + 4;
                    contentLines.slice(half, maxLines).forEach(line => {
                        if (lY + lineH > PH - footerReserve) return;
                        if (arabicContent) doc.text(line, rightX + colW, lY, { align: 'right' });
                        else doc.text(line, rightX, lY);
                        lY += lineH;
                    });
                }

                // ── FOOTER — EditorPR brand (matches Preview.cshtml report-footer) ──
                const fY = PH - 20;
                doc.setDrawColor(...BORDER);
                doc.setLineWidth(0.5);
                doc.line(ML, fY, PW - MR, fY);

                doc.setFont('helvetica', 'bold');
                doc.setFontSize(11);
                doc.setTextColor(...MAROON);
                doc.text('EditorPR', ML, fY + 7);
                doc.setFont('helvetica', 'normal');
                doc.setFontSize(6);
                doc.setTextColor(...SLATE);
                doc.text('MEDIA MONITORING & PR MANAGEMENT', ML, fY + 11);

                doc.setFont('helvetica', 'bold');
                doc.setFontSize(11);
                doc.setTextColor(...MAROON);
                doc.text(clientName, PW - MR, fY + 7, { align: 'right' });

                doc.setFont('helvetica', 'normal');
                doc.setFontSize(7);
                doc.setTextColor(...SLATE);
                doc.text(`${idx + 1} / ${rows.length}`, PW / 2, fY + 9, { align: 'center' });
            }

            doc.save(`${clientName}_Newspapers_Report_${new Date().toISOString().slice(0,10)}.pdf`);
        }
    </script>
}
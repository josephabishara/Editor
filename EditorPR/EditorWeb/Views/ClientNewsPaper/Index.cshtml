@model EditorViewModelLayer.MediaViewModel.ClientNewsPaperListDTO
@using EditorViewModelLayer.MediaViewModel
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Newspaper Articles";
    var clientId = Model.ClientId > 0 ? Model.ClientId : (ViewBag.ClientId is int v ? v : 0);

    var fTitle  = ViewBag.FilterTitle    as string ?? "";
    var fFrom   = ViewBag.FilterDateFrom as string ?? "";
    var fTo     = ViewBag.FilterDateTo   as string ?? "";
    var fCat    = (int)(ViewBag.FilterCategoryId ?? 0);
    var fSub    = (int)(ViewBag.FilterSubId      ?? 0);
    var fWriter = (int)(ViewBag.FilterWriterId   ?? 0);
    var fPub    = (int)(ViewBag.FilterPubId      ?? 0);

    bool isAdmin = User.IsInRole("Admin");
    bool canEdit = User.IsInRole("Admin") || User.IsInRole("Manager") || User.IsInRole("EditorWeb");

    List<SelectListItem> ToSL(List<MediaSelectOption> src)
        => src.Select(o => new SelectListItem(o.Text, o.Value, o.Selected)).ToList();

    var pubSL    = ToSL(Model.PublicationOptions);
    var catSL    = ToSL(Model.CategoryOptions);
    var subSL    = ToSL(Model.SubCategoryOptions);
    var writerSL = ToSL(Model.WriterOptions);
}

@await Html.PartialAsync("_MediaStyles")

<style>
    /* ── Checkbox column ── */
    .cb-col { width: 36px; text-align: center !important; }
    .row-cb { width: 16px; height: 16px; accent-color: var(--accent); cursor: pointer; }

    /* ── Selection toolbar ── */
    .sel-toolbar {
        display: none; align-items: center; gap: .75rem;
        background: #721a24; color: #fff;
        border-radius: var(--radius); padding: .65rem 1.2rem;
        margin-bottom: 1rem; flex-wrap: wrap;
    }
    .sel-toolbar.visible { display: flex; }
    .sel-toolbar .sel-count { font-size: .85rem; font-weight: 700; flex: 1; }
    .sel-toolbar .sel-count span { background: rgba(255,255,255,.25); border-radius: 20px; padding: .15rem .6rem; margin-left: .4rem; }
    .btn-export {
        display: inline-flex; align-items: center; gap: .35rem;
        border: none; border-radius: 7px; padding: .42rem 1rem;
        font-size: .82rem; font-weight: 700; cursor: pointer; transition: filter .15s;
    }
    .btn-export:hover { filter: brightness(.9); }
    .btn-xl  { background: #16a34a; color: #fff; }
    .btn-pdf { background: #dc2626; color: #fff; }
    .btn-desel { background: rgba(255,255,255,.18); color: #fff; border: 1px solid rgba(255,255,255,.35); }
</style>

@if (TempData["Success"] != null) { <div class="alert alert-success">✓ @TempData["Success"]</div> }
@if (TempData["Error"]   != null) { <div class="alert alert-danger">✗ @TempData["Error"]</div> }

<div class="m-header">
    <div class="m-header-icon" style="background:#dbeafe;">📰</div>
    <div>
        <h1>Newspaper Articles</h1>
        <p>@Model.ClientName</p>
    </div>
    <div class="ms-auto d-flex gap-2">
        <a href="@Url.Action("ClientDashboard", "Dashboard", new { id = clientId })" class="btn-dashboard">← Dashboard</a>
    </div>
</div>

<div class="stat-row">
    <div class="stat-pill sp-total">
        <span class="num">@Model.Total</span><span class="lbl">Total Articles</span>
    </div>
    <div class="stat-pill sp-pr">
        <span class="num">@Model.TotalPR.ToString("N0")</span><span class="lbl">Total PR Value</span>
    </div>
    <div class="stat-pill sp-ad">
        <span class="num">@Model.TotalAD.ToString("N0")</span><span class="lbl">Total AD Value</span>
    </div>
</div>

<div class="filter-card">
    <div class="filter-title">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
        Filter Articles
    </div>
    <form method="get" action="@Url.Action("Index")">
        <input type="hidden" name="clientId" value="@clientId" />
        <div class="filter-grid">
            <div class="fg"><label>Title</label><input type="text" name="title" value="@fTitle" placeholder="Search…" /></div>
            <div class="fg"><label>Date From</label><input type="date" name="dateFrom" value="@fFrom" /></div>
            <div class="fg"><label>Date To</label><input type="date" name="dateTo" value="@fTo" /></div>
            <div class="fg">
                <label>Category</label>
                <select name="categoryId" id="fCat" asp-items="catSL" onchange="loadSubs(this.value,'fSub','/ClientNewsPaper/GetSubCategories')">
                    <option value="0">All</option>
                </select>
            </div>
            <div class="fg"><label>Sub Category</label><select name="subCategoryId" id="fSub" asp-items="subSL"><option value="0">All</option></select></div>
            <div class="fg"><label>Writer</label><select name="writerId" asp-items="writerSL"><option value="0">All</option></select></div>
            <div class="fg"><label>Publication</label><select name="publicationId" asp-items="pubSL"><option value="0">All</option></select></div>
            <div class="fg" style="display:flex;gap:.4rem;">
                <button type="submit" class="btn-filter">Search</button>
                <a href="@Url.Action("Index", new { clientId })" class="btn-reset">Reset</a>
            </div>
        </div>
    </form>
</div>

@* ── Selection toolbar (appears when rows are checked) ── *@
<div class="sel-toolbar" id="selToolbar">
    <div class="sel-count">Selected <span id="selCount">0</span> articles</div>
    <button class="btn-export btn-xl"  onclick="exportExcel()">⬇ Excel</button>
    <button class="btn-export btn-pdf" onclick="exportPDF()">⬇ PDF Report</button>
    <button class="btn-export btn-desel" onclick="deselectAll()">✕ Deselect All</button>
</div>

<div class="action-bar">
    <div class="result-count">
        Showing <strong>@Model.Items.Count()</strong> of <strong>@Model.Total</strong>
    </div>
    @if (canEdit)
    {
        <a href="@Url.Action("Create", new { clientId })" class="btn-add">+ Add Article</a>
    }
</div>

<div class="m-table-wrap">
    @if (!Model.Items.Any())
    {
        <div class="empty-state"><h3>No articles found</h3><p>Adjust filters or add a new article.</p></div>
    }
    else
    {
        <table class="m-table" id="mainTable">
            <thead>
                <tr>
                    <th class="cb-col">
                        <input type="checkbox" class="row-cb" id="cbAll" title="Select all" onchange="toggleAll(this)" />
                    </th>
                    <th>#</th>
                    <th>Date</th>
                    <th>Title</th>
                    <th>Publication</th>
                    <th>Media Type</th>
                    <th>Media Tier</th>
                    <th>Category</th>
                    <th>Writer</th>
                    <th>Circulation</th>
                    <th>Reach</th>
                    <th>AD Value</th>
                    <th>PR Value</th>
                    <th>Toning</th>
                    <th>Published</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @{ int r = 1; }
                @foreach (var item in Model.Items)
                {
                    <tr data-id="@item.Id"
                        data-date="@item.Date.ToString("dd MMM yyyy")"
                        data-title="@item.Title"
                        data-publication="@(item.PublicationName ?? "")"
                        data-mediatype="@(item.MediaType ?? "")"
                        data-mediatier="@(item.MediaTier ?? "")"
                        data-category="@(item.CategoryId > 0 ? item.CategoryId.ToString() : "")"
                        data-writer="@(item.WriterName ?? "")"
                        data-circulation="@(item.Circulation?.ToString() ?? "")"
                        data-reach="@item.Reach"
                        data-ad="@item.ADValue.ToString("F2")"
                        data-pr="@item.PRValue.ToString("F2")"
                        data-toning="@(item.Toning ?? "")"
                        data-published="@(item.Publish ? "Yes" : "No")"
                        data-content="@(System.Web.HttpUtility.HtmlAttributeEncode(item.Content ?? ""))"
                        data-client="@Model.ClientName"
                        data-pages="@item.Pages"
                        data-height="@item.Height"
                        data-width="@item.Width"
                        data-articlebrand="@item.ArticleBranding"
                        data-headlinebrand="@item.HeadlineBranding">
                        <td class="cb-col">
                            <input type="checkbox" class="row-cb row-check" onchange="onRowCheck()" />
                        </td>
                        <td style="color:var(--slate);font-size:.75rem;">@r</td>
                        <td style="white-space:nowrap;color:var(--slate);">@item.Date.ToString("dd MMM yyyy")</td>
                        <td><div class="m-title">@item.Title</div></td>
                        <td style="font-size:.78rem;">@(item.PublicationName ?? "—")</td>
                        <td style="font-size:.78rem;">@(item.MediaType ?? "—")</td>
                        <td style="font-size:.78rem;">@(item.MediaTier ?? "—")</td>
                        <td style="font-size:.78rem;">@(item.CategoryId > 0 ? item.CategoryId.ToString() : "—")</td>
                        <td style="font-size:.78rem;">@(item.WriterName ?? "—")</td>
                        <td style="font-size:.78rem;">@(item.Circulation?.ToString("N0") ?? "—")</td>
                        <td style="font-size:.78rem;">@item.Reach.ToString("N0")</td>
                        <td class="val-ad">@item.ADValue.ToString("N2")</td>
                        <td class="val-pr">@item.PRValue.ToString("N2")</td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.Toning) && item.Toning != "None")
                            {
                                var dc = item.Toning switch { "Positive"=>"t-pos","Negative"=>"t-neg",_=>"t-neu" };
                                <span class="toning-dot @dc"></span>@item.Toning
                            }
                            else { <span style="color:var(--slate);">—</span> }
                        </td>
                        <td>
                            <span class="pub-badge @(item.Publish ? "pub-yes" : "pub-no")">
                                @(item.Publish ? "✓ Yes" : "⏳ No")
                            </span>
                        </td>
                        <td>
                            <a href="@Url.Action("Details", new { id=item.Id })" class="act-btn act-view" title="View">👁</a>
                            @if (canEdit) { <a href="@Url.Action("Edit", new { id=item.Id })" class="act-btn act-edit" title="Edit">✏️</a> }
                            @if (isAdmin)
                            {
                                @if (item.Publish)
                                {
                                    <form method="post" action="@Url.Action("Unpublish")" style="display:inline;" onsubmit="return confirm('Unpublish?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="clientId" value="@clientId" />
                                        <button type="submit" class="act-btn act-unpub" title="Unpublish">📤</button>
                                    </form>
                                }
                                else
                                {
                                    <form method="post" action="@Url.Action("Publish")" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="clientId" value="@clientId" />
                                        <button type="submit" class="act-btn act-pub" title="Publish">📢</button>
                                    </form>
                                }
                                <form method="post" action="@Url.Action("Delete")" style="display:inline;" onsubmit="return confirm('Delete?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="hidden" name="clientId" value="@clientId" />
                                    <button type="submit" class="act-btn act-del" title="Delete">🗑</button>
                                </form>
                            }
                        </td>
                    </tr>
                    r++;
                }
            </tbody>
        </table>
    }
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>
<script>
const clientName = "@Model.ClientName";

// ── Selection helpers ──────────────────────────────────────────────────────
function toggleAll(cb) {
    document.querySelectorAll('.row-check').forEach(c => c.checked = cb.checked);
    onRowCheck();
}
function onRowCheck() {
    const count = document.querySelectorAll('.row-check:checked').length;
    document.getElementById('selCount').textContent = count;
    document.getElementById('selToolbar').classList.toggle('visible', count > 0);
    const all = document.querySelectorAll('.row-check');
    document.getElementById('cbAll').indeterminate = count > 0 && count < all.length;
    document.getElementById('cbAll').checked = count === all.length && all.length > 0;
}
function deselectAll() {
    document.querySelectorAll('.row-check, #cbAll').forEach(c => { c.checked = false; c.indeterminate = false; });
    onRowCheck();
}

// ── Get selected row data ──────────────────────────────────────────────────
function getSelectedRows() {
    const rows = [];
    document.querySelectorAll('.row-check:checked').forEach(cb => {
        const tr = cb.closest('tr');
        const d  = tr.dataset;
        rows.push({
            date:           d.date,
            title:          d.title,
            publication:    d.publication,
            mediaType:      d.mediatype,
            mediaTier:      d.mediatier,
            category:       d.category,
            writer:         d.writer,
            circulation:    d.circulation,
            reach:          d.reach,
            adValue:        d.ad,
            prValue:        d.pr,
            toning:         d.toning,
            published:      d.published,
            content:        d.content,
            client:         d.client,
            pages:          d.pages,
            height:         d.height,
            width:          d.width,
            articleBrand:   d.articlebrand,
            headlineBrand:  d.headlinebrand,
        });
    });
    return rows;
}

// ══════════════════════════════════════════════════════════════════════════
// EXCEL EXPORT
// ══════════════════════════════════════════════════════════════════════════
function exportExcel() {
    const rows = getSelectedRows();
    if (!rows.length) { alert('Please select at least one article.'); return; }

    const headers = [
        'Date','Title','Publication','Media Type','Media Tier',
        'Category','Writer','Circulation','Reach',
        'AD Value','PR Value','Toning','Published',
        'Pages','Height (cm)','Width (cm)','Article Branding','Headline Branding'
    ];

    const data = rows.map(r => [
        r.date, r.title, r.publication, r.mediaType, r.mediaTier,
        r.category, r.writer, r.circulation, r.reach,
        r.adValue, r.prValue, r.toning, r.published,
        r.pages, r.height, r.width, r.articleBrand, r.headlineBrand
    ]);

    const wb = XLSX.utils.book_new();
    const ws = XLSX.utils.aoa_to_sheet([headers, ...data]);

    // Column widths
    ws['!cols'] = headers.map((h, i) => ({ wch: i === 1 ? 40 : i === 2 ? 25 : 16 }));

    // Header style (light blue fill + bold) via sheet format
    const range = XLSX.utils.decode_range(ws['!ref']);
    for (let c = range.s.c; c <= range.e.c; c++) {
        const addr = XLSX.utils.encode_cell({ r: 0, c });
        if (!ws[addr]) continue;
        ws[addr].s = {
            font:  { bold: true, color: { rgb: 'FFFFFF' } },
            fill:  { fgColor: { rgb: '1A56DB' } },
            alignment: { horizontal: 'center' }
        };
    }

    XLSX.utils.book_append_sheet(wb, ws, 'Articles');
    const ts = new Date().toISOString().slice(0,10);
    XLSX.writeFile(wb, `${clientName}_Articles_${ts}.xlsx`);
}

// ══════════════════════════════════════════════════════════════════════════
// PDF EXPORT — one page per article
// ══════════════════════════════════════════════════════════════════════════
function exportPDF() {
    const rows = getSelectedRows();
    if (!rows.length) { alert('Please select at least one article.'); return; }

    const { jsPDF } = window.jspdf;
    const doc = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });

    const PW  = 210; // A4 width mm
    const PH  = 297; // A4 height mm
    const ML  = 15;  // margin left
    const MR  = 15;  // margin right
    const MT  = 15;  // margin top
    const CW  = PW - ML - MR;

    // Brand colors (RGB)
    const INK     = [15, 25, 35];
    const ACCENT  = [26, 86, 219];
    const SLATE   = [90, 106, 122];
    const RULE    = [221, 227, 234];
    const GREEN   = [22, 163, 74];
    const AMBER   = [217, 119, 6];
    const BG_CARD = [244, 246, 249];

    rows.forEach((row, idx) => {
        if (idx > 0) doc.addPage();

        let y = MT;

        // ── Header band ──────────────────────────────────────────────────
        doc.setFillColor(...ACCENT);
        doc.rect(0, 0, PW, 28, 'F');

        doc.setTextColor(255, 255, 255);
        doc.setFontSize(9);
        doc.setFont('helvetica', 'normal');
        doc.text('NEWSPAPER ARTICLE REPORT', ML, 10);

        doc.setFontSize(13);
        doc.setFont('helvetica', 'bold');
        const titleLines = doc.splitTextToSize(row.title || 'Untitled', CW - 20);
        doc.text(titleLines, ML, 19);

        // Client name top-right
        doc.setFontSize(8);
        doc.setFont('helvetica', 'normal');
        doc.text(clientName, PW - MR, 10, { align: 'right' });

        // Date top-right
        doc.text(row.date, PW - MR, 16, { align: 'right' });

        y = 34;

        // ── Publication info card ────────────────────────────────────────
        y = drawCard(doc, ML, y, CW, 'Source', [
            ['Publication',  row.publication ],
            ['Media Type',   row.mediaType   ],
            ['Media Tier',   row.mediaTier   ],
            ['Frequency',    ''              ],
            ['Language',     ''              ],
            ['Writer',       row.writer      ],
            ['Category',     row.category    ],
        ], ACCENT, BG_CARD, INK, SLATE, RULE);

        y += 4;

        // ── Metrics card ─────────────────────────────────────────────────
        y = drawCard(doc, ML, y, CW, 'Metrics & Values', [
            ['Circulation',      row.circulation ],
            ['Reach',            row.reach       ],
            ['AD Value',         row.adValue     ],
            ['PR Value',         row.prValue     ],
            ['Pages',            row.pages       ],
            ['Size (H×W cm)',    `${row.height} × ${row.width}` ],
        ], GREEN, BG_CARD, INK, SLATE, RULE);

        y += 4;

        // ── Branding card ────────────────────────────────────────────────
        y = drawCard(doc, ML, y, CW, 'Branding & Analysis', [
            ['Article Branding',  row.articleBrand  ],
            ['Headline Branding', row.headlineBrand ],
            ['Toning',            row.toning        ],
            ['Published',         row.published     ],
        ], AMBER, BG_CARD, INK, SLATE, RULE);

        y += 4;

        // ── Content section ──────────────────────────────────────────────
        if (row.content && row.content.trim()) {
            doc.setFillColor(...ACCENT);
            doc.roundedRect(ML, y, CW, 6, 1, 1, 'F');
            doc.setTextColor(255, 255, 255);
            doc.setFontSize(8);
            doc.setFont('helvetica', 'bold');
            doc.text('Content', ML + 3, y + 4.2);
            y += 8;

            doc.setFillColor(...BG_CARD);
            const contentText = doc.splitTextToSize(row.content, CW - 6);
            const contentH    = Math.min(contentText.length * 4.5 + 4, PH - y - MT);
            doc.roundedRect(ML, y, CW, contentH, 1, 1, 'F');
            doc.setTextColor(...INK);
            doc.setFontSize(8);
            doc.setFont('helvetica', 'normal');
            doc.text(contentText, ML + 3, y + 5, { maxWidth: CW - 6 });
            y += contentH + 4;
        }

        // ── Footer ───────────────────────────────────────────────────────
        doc.setDrawColor(...RULE);
        doc.setLineWidth(0.3);
        doc.line(ML, PH - 12, PW - MR, PH - 12);
        doc.setTextColor(...SLATE);
        doc.setFontSize(7.5);
        doc.setFont('helvetica', 'normal');
        const now = new Date().toLocaleString();
        doc.text(`Generated: ${now}`, ML, PH - 8);
        doc.text(`Page ${idx + 1} of ${rows.length}`, PW - MR, PH - 8, { align: 'right' });
    });

    const ts = new Date().toISOString().slice(0, 10);
    doc.save(`${clientName}_Articles_Report_${ts}.pdf`);
}

// ── Helper: draw a labeled card with key-value rows ────────────────────────
function drawCard(doc, x, y, w, title, pairs, headerColor, bgColor, inkColor, slateColor, ruleColor) {
    // Card header
    doc.setFillColor(...headerColor);
    doc.roundedRect(x, y, w, 6, 1, 1, 'F');
    doc.setTextColor(255, 255, 255);
    doc.setFontSize(8);
    doc.setFont('helvetica', 'bold');
    doc.text(title, x + 3, y + 4.2);
    y += 7;

    // Card body
    const validPairs = pairs.filter(([, v]) => v !== null && v !== undefined && v !== '');
    if (!validPairs.length) return y;

    const ROW_H = 6;
    const cardH = validPairs.length * ROW_H + 3;
    doc.setFillColor(...bgColor);
    doc.roundedRect(x, y, w, cardH, 1, 1, 'F');

    const colW = w / 2;
    validPairs.forEach(([label, val], i) => {
        const rowY = y + 4 + i * ROW_H;
        const col  = i % 2;
        const rx   = x + col * colW + 3;

        // Draw on two-column grid
        if (i % 2 === 0 && i > 0) { /* next row */ }

        // Label
        doc.setTextColor(...slateColor);
        doc.setFontSize(7);
        doc.setFont('helvetica', 'bold');
        const lx = x + Math.floor(i / 2) >= 0 ? x + 3 : x + colW + 3;

        // Simpler: single column layout
        doc.setTextColor(...slateColor);
        doc.setFontSize(7);
        doc.setFont('helvetica', 'bold');
        doc.text(String(label).toUpperCase(), x + 3, rowY);

        doc.setTextColor(...inkColor);
        doc.setFontSize(8);
        doc.setFont('helvetica', 'normal');
        doc.text(String(val || '—'), x + 55, rowY);

        // Subtle rule between rows
        if (i < validPairs.length - 1) {
            doc.setDrawColor(...ruleColor);
            doc.setLineWidth(0.2);
            doc.line(x + 3, rowY + 2, x + w - 3, rowY + 2);
        }
    });

    return y + cardH + 1;
}

// ── Sub-category loader ────────────────────────────────────────────────────
async function loadSubs(parentId, targetId, url) {
    const sel = document.getElementById(targetId);
    sel.innerHTML = '<option value="0">Loading…</option>';
    if (!parentId || parentId == '0') { sel.innerHTML = '<option value="0">All</option>'; return; }
    const data = await (await fetch(`${url}?parentId=${parentId}`)).json();
    sel.innerHTML = '<option value="0">All</option>';
    data.forEach(s => sel.innerHTML += `<option value="${s.value}">${s.text}</option>`);
}
</script>
}

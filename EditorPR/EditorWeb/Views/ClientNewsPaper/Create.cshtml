@model EditorViewModelLayer.MediaViewModel.ClientNewsPaperDTO
@using EditorViewModelLayer.MediaViewModel
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    bool isEdit = Model.Id > 0;
    ViewData["Title"] = isEdit ? "Edit Newspaper  " : "Add Newspaper  ";

    List<SelectListItem> ToSL(List<MediaSelectOption> src)
        => src.Select(o => new SelectListItem(o.Text, o.Value, o.Selected)).ToList();

    var pubSL = ToSL(Model.PublicationOptions);
    var catSL = ToSL(Model.CategoryOptions);
    var subSL = ToSL(Model.SubCategoryOptions);
    var writerSL = ToSL(Model.WriterOptions);
    var brandSL = ToSL(Model.BrandingOptions);
    var toningSL = ToSL(Model.ToningOptions);
    var yesNoSL = ToSL(Model.YesNoOptions);
    var genSL = ToSL(Model.GenerationOptions);

    // Parse existing images
    var existingImagePaths = new List<string>();
    if (!string.IsNullOrEmpty(Model.Images))
    {
        try { existingImagePaths = System.Text.Json.JsonSerializer.Deserialize<List<string>>(Model.Images) ?? new(); }
        catch { }
    }

    // Ensure Children list is initialised
    if (Model.Children == null) Model.Children = new List<ChildNewsPaperDTO>();

    // On Create, start with one blank child row
    if (!isEdit && Model.Children.Count == 0)
        Model.Children.Add(new ChildNewsPaperDTO { Date = DateTime.Today });
}

@await Html.PartialAsync("_MediaStyles")

<div class="form-wrap">

    <a href="@Url.Action("Index", new { clientId = Model.ClientId })"
       style="display:inline-flex;align-items:center;gap:.4rem;color:var(--slate);
        font-size:.82rem;text-decoration:none;margin-bottom:1.1rem;">
        ← Back to Newspapers
    </a>

    @await Html.PartialAsync("_navdashboard")

    <div class="m-header" style="margin-bottom:1.4rem;">
        <div class="m-header-icon" style="background:#fef9c3;">@(isEdit ? "✏️" : "📰")</div>
        <div>
            <h1>@ViewData["Title"]</h1>
            <p>@Model.ClientName</p>
        </div>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="val-summary">
            <strong>Please fix the errors below:</strong>
            <ul>
                @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@e.ErrorMessage</li>
                }
            </ul>
        </div>
    }

    <form method="post"
          enctype="multipart/form-data"
          action="@(isEdit ? Url.Action("Edit", new { id = Model.Id }) : Url.Action("Create"))">

        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ClientId" />
        <input type="hidden" asp-for="NewsPaperId" />

        <input type="hidden" name="Images" id="hdnImages" value="@Model.Images" />
        <input type="hidden" name="removedImages" id="hdnRemovedImages" value="[]" />

        @* ── CARD 1: Source & Classification ─────────────────────────────────── *@
        <div class="form-card">
            <div class="fg-3">
                <div class="fg">
                    <label asp-for="PublicationId">Publication <span style="color:var(--red)">*</span></label>
                    <select asp-for="PublicationId" asp-items="pubSL"
                            onchange="autoFillPublication(this.value)" class="select-search" required>
                        <option value="0">— Select —</option>
                    </select>
                    <span asp-validation-for="PublicationId" class="field-error"></span>
                </div>
                <div class="fg">
                    <label asp-for="CategoryId">Category</label>
                    <select asp-for="CategoryId" asp-items="catSL"
                            id="catSel" onchange="loadSubs(this.value)" class="select-search" required>
                        <option value="0">— None —</option>
                    </select>
                </div>
                <div class="fg">
                    <label asp-for="SubCategoryId">Sub Category</label> 
                    <select asp-for="SubCategoryId" asp-items="subSL" id="subSel" class="select-search" required>
                        <option value="0">— None —</option>
                    </select>
                  
                </div>
            </div>
            <div class="fg-3" style="margin-top:.9rem;">
                <div class="fg">
                    <label asp-for="WriterId">
                        <a asp-action="create" asp-controller="Writer" asp-route-state="1" class="btn btn-sm">Add Writer</a>
                        Writer
                </label>
                   
                    <select asp-for="WriterId" asp-items="writerSL" class="select-search">
                        <option value="0">— None —</option>
                    </select>
                </div>
                <div class="fg">
                    <label asp-for="Date">Date <span style="color:var(--red)">*</span></label>
                    <input asp-for="Date" type="date" required />
                    <span asp-validation-for="Date" class="field-error"></span>
                </div>

            </div>
            <div class="fg-3" style="margin-top:.9rem;">
                <div class="fg">
                    <label asp-for="Pages">Pages</label>
                    <input asp-for="Pages" type="number" min="1" required />
                </div>
                <div class="fg">
                    <label asp-for="Height">Height (cm)</label>
                    <input asp-for="Height" type="number" step="0.1" required />
                </div>
                <div class="fg">
                    <label asp-for="Width">Width (cm)</label>
                    <input asp-for="Width" type="number" step="0.1" required />
                </div>
            </div>
            <br />
            <div class="fg-3">
                <div class="fg">
                    <label asp-for="ArticleBranding">Article Branding</label>
                    <select asp-for="ArticleBranding" asp-items="brandSL"></select>
                </div>
                <div class="fg">
                    <label asp-for="HeadlineBranding">Headline Branding</label>
                    <select asp-for="HeadlineBranding" asp-items="brandSL"></select>
                </div>
                <div class="fg">
                    <label asp-for="PictureinArticle">Picture in Article</label>
                    <select asp-for="PictureinArticle" asp-items="yesNoSL"></select>
                </div>

            </div>
            <br />
            <div class="fg-3">

               
                <div class="fg">
                    <label asp-for="Toning">Toning</label>
                    <select asp-for="Toning" asp-items="toningSL"></select>
                </div>
                <div class="fg">
                    <label asp-for="Generation">Generation</label>
                    <select asp-for="Generation" asp-items="genSL"></select>
                </div>
            </div>
            <br />
            <div class="fg" style="margin-bottom:.9rem;">
                <label asp-for="Title">Title <span style="color:var(--red)">*</span></label>
                <input asp-for="Title" placeholder="Enter article headline…" />
                <span asp-validation-for="Title" class="field-error"></span>
            </div>

            <div class="fg" style="margin-bottom:.9rem;">
                <label asp-for="Content">Translation</label>
                <textarea id="textarea" class="form-control" asp-for="Content" placeholder="Content"></textarea>
                <script src="~/lib/tinymce/tinymce.min.js"></script>
                <script>
                    tinymce.init({
                    selector: '#textarea',
                    plugins: "paste searchreplace autolink visualblocks fullscreen image link media table code lists wordcount",
                    toolbar1: 'formatselect | bold italic forecolor backcolor | link | alignleft aligncenter alignright | numlist bullist | removeformat',
                    height: "200",
                    paste_data_images: true
                    });
                </script>
            </div>
            <br />

            <div class="fg">

                <div id="dropZone"
                     style="border:2px dashed var(--rule,#cbd5e1);border-radius:10px;
                    padding:1.4rem 1rem;text-align:center;background:#f8fafc;
                    cursor:pointer;min-height:110px;transition:border-color .2s,background .2s;">
                    <div style="font-size:2rem;line-height:1;">📁</div>
                    <p style="color:#64748b;margin:.4rem 0 .2rem;font-size:.88rem;">
                        Drag &amp; drop images here, or <strong>click to browse</strong>
                    </p>
                    <small style="color:#94a3b8;">JPG · PNG · GIF · WebP &nbsp;|&nbsp; Multiple allowed</small>
                    <input type="file" name="imageFiles" id="imageFilesInput"
                           multiple accept=".jpg,.jpeg,.png,.gif,.webp" style="display:none;" />
                </div>
                <div id="newPreviewGrid" style="display:flex;flex-wrap:wrap;gap:8px;margin-top:10px;"></div>

                @if (existingImagePaths.Any())
                {
                    <p style="font-size:.8rem;font-weight:600;color:#64748b;margin:12px 0 6px;">Current Images</p>
                    <div id="existingGrid" style="display:flex;flex-wrap:wrap;gap:8px;">
                        @foreach (var path in existingImagePaths)
                        {
                            <div class="existing-thumb" data-path="@path" style="position:relative;">
                                <img src="@path"
                                     style="width:88px;height:88px;object-fit:cover;border-radius:6px;border:1px solid #e2e8f0;"
                                     onerror="this.src='/images/no-image.png'" />
                                <button type="button" class="remove-existing" data-path="@path" title="Remove"
                                        style="position:absolute;top:2px;right:2px;background:#ef4444;color:#fff;
                                    border:none;border-radius:50%;width:20px;height:20px;font-size:11px;
                                    line-height:1;cursor:pointer;display:flex;align-items:center;justify-content:center;">
                                    ✕
                                </button>
                            </div>
                        }
                    </div>
                }
            </div>
            <br />

            @* ══════════════════════════════════════════════════════════════════
               CHILDREN SECTION — hidden by default, shown via JS
            ══════════════════════════════════════════════════════════════════ *@

            @* Header bar — always visible, toggle button controls the body *@
            <div style="display:flex;justify-content:space-between;align-items:center;
                margin-top:1rem;padding:.55rem .7rem;background:#f1f5f9;
                border-radius:8px;border:1px solid #e2e8f0;">
                <span style="font-size:.85rem;font-weight:700;color:#475569;">
                    📎 Also Mention
                    <span id="childBadge"
                          style="display:none;background:#3b82f6;color:#fff;border-radius:999px;
                    font-size:.72rem;padding:.1rem .5rem;margin-left:.4rem;">0</span>
                </span>
                <button type="button" id="btnAddChild"
                        style="background:#3b82f6;color:#fff;border:none;border-radius:6px;
                    padding:.32rem .85rem;font-size:.82rem;font-weight:600;cursor:pointer;">
                    + Add Also Mention
                </button>
            </div>

            @* Body — hidden until first child is added *@
            <div id="childrenSection" style="display:none; margin-top:.6rem;">
                <div id="childRowsContainer"></div>
            </div>

            @* Hidden template stamped with server option lists *@
            <template id="childRowTemplate">
                <div class="child-row"
                     style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;
                    padding:.9rem;margin-bottom:.75rem;position:relative;">

                    <div style="position:absolute;top:10px;right:12px;">
                        <button type="button" class="btn-remove-child"
                                style="background:#ef4444;color:#fff;border:none;border-radius:50%;
                            width:22px;height:22px;font-size:12px;cursor:pointer;line-height:1;"
                                title="Remove">
                            ✕
                        </button>
                    </div>

                    <div style="font-size:.78rem;font-weight:700;color:#64748b;margin-bottom:.7rem;">
                        Also Mention #<span class="child-number">1</span>
                        <span class="child-new-badge"
                              style="color:#22c55e;font-weight:400;margin-left:.3rem;">New</span>
                    </div>

                    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:.7rem;margin-bottom:.6rem;">
                        <div>
                            <label style="font-size:.8rem;font-weight:600;display:block;margin-bottom:.25rem;">
                                Publication <span style="color:#ef4444">*</span>
                            </label>
                            <select name="Children[__IDX__].PublicationId"
                                    class="child-pub-sel select-search-child"
                                    style="width:100%;padding:.38rem .5rem;border:1px solid #cbd5e1;
                                border-radius:6px;font-size:.85rem;"
                                    onchange="autoFillChild(this,__IDX__)">
                                <option value="0">— Select —</option>
                                {{PUB_OPTIONS}}
                            </select>
                        </div>
                        <div>
                            <label style="font-size:.8rem;font-weight:600;display:block;margin-bottom:.25rem;">
                                Writer
                            </label>
                            <select name="Children[__IDX__].WriterId"
                                    class="select-search-child"
                                    style="width:100%;padding:.38rem .5rem;border:1px solid #cbd5e1;
                                border-radius:6px;font-size:.85rem;">
                                <option value="0">— None —</option>
                                {{WRITER_OPTIONS}}
                            </select>
                        </div>
                        <div>
                            <label style="font-size:.8rem;font-weight:600;display:block;margin-bottom:.25rem;">
                                Date <span style="color:#ef4444">*</span>
                            </label>
                            <input type="date"
                                   name="Children[__IDX__].Date"
                                   value="{{TODAY}}"
                                   style="width:100%;padding:.38rem .5rem;border:1px solid #cbd5e1;
                            border-radius:6px;font-size:.85rem;" />
                        </div>
                    </div>

                    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:.7rem;">
                        <div>
                            <label style="font-size:.75rem;color:#64748b;display:block;margin-bottom:.2rem;">Pages</label>
                            <input type="number" name="Children[__IDX__].Pages" value="0" min="1"
                                   style="width:100%;padding:.3rem .5rem;border:1px solid #cbd5e1;
                            border-radius:6px;font-size:.83rem;" />
                        </div>
                        <div>
                            <label style="font-size:.75rem;color:#64748b;display:block;margin-bottom:.2rem;">Height (cm)</label>
                            <input type="number" step="0.1" name="Children[__IDX__].Height" value="0"
                                   style="width:100%;padding:.3rem .5rem;border:1px solid #cbd5e1;
                            border-radius:6px;font-size:.83rem;" />
                        </div>
                        <div>
                            <label style="font-size:.75rem;color:#64748b;display:block;margin-bottom:.2rem;">Width (cm)</label>
                            <input type="number" step="0.1" name="Children[__IDX__].Width" value="0"
                                   style="width:100%;padding:.3rem .5rem;border:1px solid #cbd5e1;
                            border-radius:6px;font-size:.83rem;" />
                        </div>
                    </div>

                  @*   {{!-- hidden AD/PR fields still posted so model binds --}} *@
                    <div style="display:none;">
                        <input type="number" step="0.01"
                               name="Children[__IDX__].ADValue"
                               class="child-ad"
                               id="childAD___IDX__"
                               value="0" />
                        <input type="number" step="0.01"
                               name="Children[__IDX__].PRValue"
                               class="child-pr"
                               id="childPR___IDX__"
                               value="0" readonly />
                        <input type="hidden" name="Children[__IDX__].Id" value="0" />
                    </div>
                </div>
            </template>


            <button type="submit" name="addChild" value="true" formnovalidate
                    style="background:transparent;border:1px dashed #cbd5e1;border-radius:8px;
                width:100%;padding:.6rem;color:#64748b;font-size:.85rem;
                cursor:pointer;margin-top:.3rem;">
                + Add Also Mention
            </button>
        </div>

        @* ── CARD 3: Auto-filled from Publication ─────────────────────────────── *@
        <div class="form-card" style="display:none;">
            <div class="form-card-title">
                🔄 Publication Data
                <span class="badge-autofill">Auto-filled on Publication change</span>
            </div>
            <div class="fg-4">
                <div class="fg">
                    <label asp-for="MediaType">Media Type</label>
                    <input asp-for="MediaType" class="autofill" id="afMediaType" readonly />
                </div>
                <div class="fg">
                    <label asp-for="MediaTier">Media Tier</label>
                    <input asp-for="MediaTier" class="autofill" id="afMediaTier" readonly />
                </div>
                <div class="fg">
                    <label asp-for="Frequency">Frequency</label>
                    <input asp-for="Frequency" class="autofill" id="afFrequency" readonly />
                </div>
                <div class="fg">
                    <label asp-for="Language">Language</label>
                    <input asp-for="Language" class="autofill" id="afLanguage" readonly />
                </div>
            </div>
            <div class="fg-4" style="margin-top:.9rem;">
                <div class="fg">
                    <label asp-for="Circulation">Circulation</label>
                    <input asp-for="Circulation" class="autofill" id="afCirculation" readonly />
                </div>
                <div class="fg">
                    <label asp-for="Reach">Reach (Circulation × 4)</label>
                    <input asp-for="Reach" class="autofill" id="afReach" readonly />
                </div>
                <div class="fg">
                    <label asp-for="ADValue">AD Value (CM Price)</label>
                    <input asp-for="ADValue" type="number" step="0.01" id="afAD"
                           oninput="recalcPR()" class="autofill" />
                </div>
                <div class="fg">
                    <label asp-for="PRValue">PR Value (AD × 3.5)</label>
                    <input asp-for="PRValue" class="autofill" id="afPR" readonly />
                </div>
            </div>
        </div>

        @* ── Footer ──────────────────────────────────────────────────────────── *@
        <div class="form-footer">
            <a href="@Url.Action("Index", new { clientId = Model.ClientId })" class="btn-cancel">Cancel</a>

            @if (!isEdit)
            {
                <button type="submit" name="saveAndDuplicate" value="true" class="btn-save"
                        style="background:#f59e0b;"
                        onclick="this.form.querySelectorAll('[name=saveAndDuplicate]').forEach(el => el.value = 'true')">
                    📋 Save &amp; Duplicate
                </button>
            }

            <button type="submit" name="save" value="true" class="btn-save">
                @(isEdit ? "💾 Save" : "✅ Save")
            </button>
        </div>

    </form>
</div>
 

@section Scripts {
    <script>
        const clientId = @Model.ClientId;

        // ── Publication auto-fill (parent) ───────────────────────────────────────────
        async function autoFillPublication(pubId) {
        if (!pubId || pubId == '0') return;
        const d = await (await fetch(
        `/ClientNewsPaper/GetPublicationAutoFill?publicationId=${pubId}&clientId=${clientId}`
        )).json();
        document.getElementById('afMediaType').value   = d.mediaType   ?? '';
        document.getElementById('afMediaTier').value   = d.mediaTier   ?? '';
        document.getElementById('afFrequency').value   = d.frequency   ?? '';
        document.getElementById('afLanguage').value    = d.language    ?? '';
        document.getElementById('afCirculation').value = d.circulation ?? '';
        document.getElementById('afReach').value       = d.reach       ?? '';
        document.getElementById('afAD').value          = d.adValue     ?? '';
        document.getElementById('afPR').value          = d.prValue     ?? '';
        }

        function recalcPR() {
        const ad = parseFloat(document.getElementById('afAD').value) || 0;
        document.getElementById('afPR').value = (ad * 3.5).toFixed(2);
        document.querySelector('[name="PRValue"]').value = (ad * 3.5).toFixed(2);
        }

        // ── Sub-category cascade ──────────────────────────────────────────────────────
        async function loadSubs(parentId) {
        const sel = document.getElementById('subSel');
        sel.innerHTML = '<option value="0">Loading…</option>';
        if (!parentId || parentId == '0') { sel.innerHTML = '<option value="0">— None —</option>'; return; }
        const data = await (await fetch(`/ClientNewsPaper/GetSubCategories?parentId=${parentId}`)).json();
        sel.innerHTML = '<option value="0">— None —</option>';
        data.forEach(s => sel.innerHTML += `<option value="${s.value}">${s.text}</option>`);
        }

        // ── Per-child auto-fill ───────────────────────────────────────────────────────
        async function autoFillChild(sel, idx) {
        const pubId = sel.value;
        if (!pubId || pubId == '0') return;
        const d = await (await fetch(
        `/ClientNewsPaper/GetPublicationAutoFill?publicationId=${pubId}&clientId=${clientId}`
        )).json();
        const adEl = document.getElementById(`childAD_${idx}`);
        const prEl = document.getElementById(`childPR_${idx}`);
        if (adEl) adEl.value = d.adValue ?? '';
        if (prEl) prEl.value = ((d.adValue ?? 0) * 3.5).toFixed(2);
        }

        function recalcChildPR(idx) {
        const ad = parseFloat(document.getElementById(`childAD_${idx}`).value) || 0;
        document.getElementById(`childPR_${idx}`).value = (ad * 3.5).toFixed(2);
        }

        // ── Select2 ────────────────────────────────────────────────────────────────────
        $(document).ready(function () {
        $('.select-search').select2({ placeholder: 'Search...', allowClear: true });
        });

        // ══════════════════════════════════════════════════════════════════════════════
        // CHILDREN — client-side add / remove
        // ══════════════════════════════════════════════════════════════════════════════
        (function () {
        const section    = document.getElementById('childrenSection');
        const container  = document.getElementById('childRowsContainer');
        const badge      = document.getElementById('childBadge');
        const template   = document.getElementById('childRowTemplate');
        const btnAdd     = document.getElementById('btnAddChild');

        // Serialise server-side option lists once at page load
        const pubOptions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                    Model.PublicationOptions.Select(o => new { value = o.Value, text = o.Text })));

        const writerOptions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                    Model.WriterOptions.Select(o => new { value = o.Value, text = o.Text })));

        const today = new Date().toISOString().slice(0, 10);

        let childIndex = 0;

        function buildOptions(list, selectedVal) {
        return list.map(o =>
        `<option value="${o.value}"${o.value == selectedVal ? ' selected' : ''}>${o.text}</option>`
        ).join('');
        }

        function updateBadge() {
        const count = container.querySelectorAll('.child-row').length;
        badge.textContent = count;
        badge.style.display = count > 0 ? 'inline' : 'none';
        section.style.display = count > 0 ? 'block' : 'none';
        }

        function addChildRow(data) {
        const idx = childIndex++;

        let html = template.innerHTML
        .replaceAll('__IDX__', idx)
        .replace('{{PUB_OPTIONS}}',    buildOptions(pubOptions,    data?.publicationId ?? 0))
        .replace('{{WRITER_OPTIONS}}', buildOptions(writerOptions, data?.writerId      ?? 0))
        .replace('{{TODAY}}', data?.date ?? today);

        const wrapper = document.createElement('div');
        wrapper.innerHTML = html;
        const row = wrapper.firstElementChild;

        // Stamp child number
        row.querySelector('.child-number').textContent = container.querySelectorAll('.child-row').length + 1;

        // If restoring existing child (Edit mode) update id badge
        if (data?.id > 0) {
        row.querySelector('.child-new-badge').textContent = `(ID: ${data.id})`;
        row.querySelector('.child-new-badge').style.color = '#94a3b8';
        // overwrite the hidden Id field
        row.querySelector(`[name="Children[${idx}].Id"]`).value = data.id;
        }

        // Restore numeric values if supplied
        if (data?.adValue !== undefined) {
        const adEl = row.querySelector(`[name="Children[${idx}].ADValue"]`);
        const prEl = row.querySelector(`[name="Children[${idx}].PRValue"]`);
        if (adEl) adEl.value = data.adValue;
        if (prEl) prEl.value = data.prValue ?? (data.adValue * 3.5).toFixed(2);
        }
        if (data?.pages    !== undefined) row.querySelector(`[name="Children[${idx}].Pages"]`).value  = data.pages;
        if (data?.height   !== undefined) row.querySelector(`[name="Children[${idx}].Height"]`).value = data.height;
        if (data?.width    !== undefined) row.querySelector(`[name="Children[${idx}].Width"]`).value  = data.width;

        // Remove button
        row.querySelector('.btn-remove-child').addEventListener('click', function () {
        row.remove();
        renumber();
        updateBadge();
        });

        container.appendChild(row);
        updateBadge();

        // Init Select2 on the new selects
        $(row).find('.select-search-child').select2({ placeholder: 'Search...', allowClear: true });
        }

        function renumber() {
        container.querySelectorAll('.child-row').forEach((row, i) => {
        row.querySelector('.child-number').textContent = i + 1;
        });
        }

        btnAdd.addEventListener('click', () => addChildRow(null));

        // ── EDIT MODE: re-populate existing children ───────────────────────────────
        @if (isEdit && Model.Children != null && Model.Children.Any())
        {
            <text>
                const existingChildren = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                            Model.Children.Select(c => new
                            {
                                id = c.Id,
                                publicationId = c.PublicationId,
                                writerId = c.WriterId,
                                date = c.Date.ToString("yyyy-MM-dd"),
                                pages = c.Pages,
                                height = c.Height,
                                width = c.Width,
                                adValue = c.ADValue,
                                prValue = c.PRValue
                            })));

                existingChildren.forEach(child => addChildRow(child));
            </text>
        }

        })();

        // ── Image upload ───────────────────────────────────────────────────────────────
        (function () {
        const dropZone   = document.getElementById('dropZone');
        const fileInput  = document.getElementById('imageFilesInput');
        const newGrid    = document.getElementById('newPreviewGrid');
        const hdnImages  = document.getElementById('hdnImages');
        const hdnRemoved = document.getElementById('hdnRemovedImages');

        dropZone.addEventListener('click', () => fileInput.click());
        dropZone.addEventListener('dragover', e => {
        e.preventDefault();
        dropZone.style.borderColor = '#3b82f6';
        dropZone.style.background  = '#eff6ff';
        });
        ['dragleave', 'dragend'].forEach(evt =>
        dropZone.addEventListener(evt, () => {
        dropZone.style.borderColor = '';
        dropZone.style.background  = '';
        })
        );
        dropZone.addEventListener('drop', e => {
        e.preventDefault();
        dropZone.style.borderColor = '';
        dropZone.style.background  = '';
        mergeFiles(e.dataTransfer.files);
        renderPreviews(fileInput.files);
        });
        fileInput.addEventListener('change', () => renderPreviews(fileInput.files));

        function renderPreviews(files) {
        newGrid.innerHTML = '';
        Array.from(files).forEach(file => {
        if (!file.type.startsWith('image/')) return;
        const reader = new FileReader();
        reader.onload = ev => {
        const wrap = document.createElement('div');
        wrap.style.cssText = 'position:relative;';
        wrap.innerHTML = `
        <img src="${ev.target.result}"
        style="width:88px;height:88px;object-fit:cover;border-radius:6px;border:1px solid #e2e8f0;" />
        <span style="position:absolute;bottom:0;left:0;right:0;background:rgba(0,0,0,.55);
        color:#fff;font-size:9px;padding:2px 4px;border-radius:0 0 6px 6px;
        white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${file.name}</span>`;
        newGrid.appendChild(wrap);
        };
        reader.readAsDataURL(file);
        });
        }

        function mergeFiles(dropped) {
        const dt = new DataTransfer();
        if (fileInput.files) Array.from(fileInput.files).forEach(f => dt.items.add(f));
        Array.from(dropped).forEach(f => dt.items.add(f));
        fileInput.files = dt.files;
        }

        document.querySelectorAll('.remove-existing').forEach(btn => {
        btn.addEventListener('click', function () {
        const path = this.dataset.path;
        this.closest('.existing-thumb').remove();
        let current = [];
        try { current = JSON.parse(hdnImages.value || '[]'); } catch {}
        current = current.filter(p => p !== path);
        hdnImages.value = JSON.stringify(current);
        let removed = [];
        try { removed = JSON.parse(hdnRemoved.value || '[]'); } catch {}
        if (!removed.includes(path)) removed.push(path);
        hdnRemoved.value = JSON.stringify(removed);
        });
        });
        })();
    </script>
}

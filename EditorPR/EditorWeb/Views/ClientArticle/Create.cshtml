                              style="display:none;width:13px;height:13px;
                        border:2px solid rgba(255,255,255,.4);
                        border-top-color:#fff;border-radius:50%;
                        animation:spin .6s linear infinite;"></span>
                        📸 Take Screenshot
                    </button>
                </div>

                <div id="screenshotStatus"
                     style="margin-top:.5rem;font-size:.78rem;color:#0369a1;display:none;"></div>

                <div id="screenshotPreview" style="margin-top:.6rem;display:none;">
                    <img id="screenshotImg"
                         style="max-width:220px;max-height:140px;border-radius:7px;
                    border:1.5px solid #0284c7;object-fit:cover;display:block;" />
                    <button type="button" onclick="removeScreenshot()"
                            style="display:inline-flex;align-items:center;gap:.25rem;
                        margin-top:.35rem;background:none;border:none;
                        color:#dc2626;font-size:.75rem;cursor:pointer;padding:0;">
                        ✕ Remove screenshot

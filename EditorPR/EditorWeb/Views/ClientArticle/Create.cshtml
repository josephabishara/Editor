                        padding:.45rem .7rem;font-size:.78rem;font-weight:600;
                        cursor:pointer;white-space:nowrap;">
                        ⬆ Use Article URL
                    </button>

                    <button type="button" id="btnScreenshot" onclick="screenshotFromUrl()"
                            style="display:inline-flex;align-items:center;gap:.35rem;
                        background:#0284c7;color:#fff;border:none;border-radius:7px;
                        padding:.45rem 1rem;font-size:.82rem;font-weight:700;
                        cursor:pointer;white-space:nowrap;transition:background .15s;"
                            onmouseover="this.style.background='#0369a1'"
                            onmouseout="this.style.background='#0284c7'">

@model EditorViewModelLayer.MediaViewModel.ClientArticleDTO
@using EditorViewModelLayer.MediaViewModel
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    bool isEdit = Model.Id > 0;
    ViewData["Title"] = isEdit ? "Edit Website" : "Add Website";

    List<SelectListItem> ToSL(List<MediaSelectOption> src)
        => src.Select(o => new SelectListItem(o.Text, o.Value, o.Selected)).ToList();

    var webSL = ToSL(Model.WebsiteOptions);
    var catSL = ToSL(Model.CategoryOptions);
    var subSL = ToSL(Model.SubCategoryOptions);
    var writerSL = ToSL(Model.WriterOptions);
    var brandSL = ToSL(Model.BrandingOptions);
    var toningSL = ToSL(Model.ToningOptions);
    var yesNoSL = ToSL(Model.YesNoOptions);
    var genSL = ToSL(Model.GenerationOptions);

    var existingImagePaths = new List<string>();
    if (!string.IsNullOrEmpty(Model.Images))
    {
        try { existingImagePaths = System.Text.Json.JsonSerializer.Deserialize<List<string>>(Model.Images) ?? new(); }
        catch { }
    }
}

@await Html.PartialAsync("_MediaStyles")
 

 

<div class="form-wrap">

    <a href="@Url.Action("Index", new { clientId = Model.ClientId })"
       style="display:inline-flex;align-items:center;gap:.4rem;color:var(--slate);
        font-size:.82rem;text-decoration:none;margin-bottom:1.1rem;">
        ← Back to Articles
    </a>

    @await Html.PartialAsync("_navdashboard")

    <div class="m-header" style="margin-bottom:1.4rem;">
        <div class="m-header-icon" style="background:#cffafe;">@(isEdit ? "✏️" : "🌐")</div>
        <div>
            <h1>@ViewData["Title"]</h1>
            <p>@Model.ClientName</p>
        </div>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="val-summary">
            <strong>Please fix the errors below:</strong>
            <ul>
                @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@err.ErrorMessage</li>
                }
            </ul>
        </div>
    }

    <form method="post" enctype="multipart/form-data"
          action="@(isEdit ? Url.Action("Edit", new { id = Model.Id }) : Url.Action("Create"))">

        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ClientId" />
        <input type="hidden" asp-for="ArticleId" />
        <input type="hidden" name="Images" id="hdnImages" value="@Model.Images" />
        <input type="hidden" name="removedImages" id="hdnRemovedImages" value="[]" />

        @* ── CARD 1: Source & Classification ── *@
        <div class="form-card">

            <div class="fg-3">
                <div class="fg">
                    <label asp-for="WebsiteId">Website <span style="color:var(--red)">*</span></label>
                    <select asp-for="WebsiteId" asp-items="webSL"
                            onchange="autoFillWebsite(this.value)" class="select-search" required>
                        <option value="0">— Select —</option>
                    </select>
                    <span asp-validation-for="WebsiteId" class="field-error"></span>
                </div>
                <div class="fg">
                    <label asp-for="CategoryId">Category</label>
                    <select asp-for="CategoryId" asp-items="catSL" class="select-search"
                            id="catSel" onchange="loadSubs(this.value)">
                        <option value="0">— None —</option>
                    </select>
                </div>
                <div class="fg">
                    <label asp-for="SubCategoryId">Sub Category</label>
                    <select asp-for="SubCategoryId" asp-items="subSL" class="select-search" id="subSel">
                        <option value="0">— None —</option>
                    </select>
                </div>
            </div>

            <div class="fg-3" style="margin-top:.9rem;">
                <div class="fg">
                    <label asp-for="ArticleURL">Article URL</label>
                    <input asp-for="ArticleURL" type="url" placeholder="https://…" id="articleUrlField" />
                </div>
                <div class="fg">
                    <label asp-for="Date">Date <span style="color:var(--red)">*</span></label>
                    <input asp-for="Date" type="date" required />
                    <span asp-validation-for="Date" class="field-error"></span>
                </div>
                <div class="fg">
                    <label asp-for="WriterId">
                        Writer
                        <a asp-action="Create" asp-controller="Writer" asp-route-state="1" class="btn btn-sm">Add Writer</a>
                    </label>
                    <select asp-for="WriterId" asp-items="writerSL" class="select-search">
                        <option value="0">— None —</option>
                    </select>
                </div>
            </div>
            <br />

            <div class="fg-3">
                <div class="fg">
                    <label asp-for="ArticleBranding">Article Branding</label>
                    <select asp-for="ArticleBranding" asp-items="brandSL"></select>
                </div>
                <div class="fg">
                    <label asp-for="HeadlineBranding">Headline Branding</label>
                    <select asp-for="HeadlineBranding" asp-items="brandSL"></select>
                </div>
                <div class="fg">
                    <label asp-for="PictureinArticle">Picture in Article</label>
                    <select asp-for="PictureinArticle" asp-items="yesNoSL"></select>
                </div>
            </div>

            <div class="fg-3" style="margin-top:.9rem;">
                <div class="fg">
                    <label asp-for="Toning">Toning</label>
                    <select asp-for="Toning" asp-items="toningSL"></select>
                </div>
                <div class="fg">
                    <label asp-for="Generation">Generation</label>
                    <select asp-for="Generation" asp-items="genSL"></select>
                </div>
            </div>
            <br />

            <div class="fg" style="margin-bottom:.9rem;">
                <label asp-for="Title">Title <span style="color:var(--red)">*</span></label>
                <input asp-for="Title" placeholder="Enter article headline…" />
                <span asp-validation-for="Title" class="field-error"></span>
            </div>

            <div class="fg" style="margin-bottom:.9rem;">
                <label asp-for="Content">Content</label>
                <textarea id="textarea" class="form-control" asp-for="Content" placeholder="Content"></textarea>
                <script src="~/lib/tinymce/tinymce.min.js"></script>
                <script>
                    tinymce.init({
                    selector: '#textarea',
                    plugins: "tooltip print preview fullpage paste searchreplace autolink directionality visualblocks visualchars fullscreen image link media template codesample code table charmap hr pagebreak nonbreaking anchor toc insertdatetime advlist lists textcolor wordcount imagetools contextmenu colorpicker textpattern",
                    toolbar1: 'formatselect | bold italic strikethrough forecolor backcolor | link | alignleft aligncenter alignright alignjustify | numlist bullist outdent indent | removeformat',
                    height: "200",
                    paste_data_images: true
                    });
                </script>
            </div>
            <br />

            @* ── 📸 SCREENSHOT FROM URL ── *@
         @*    <div id="screenshotBlock"
                 style="background:#f0f9ff;border:1.5px solid #bae6fd;border-radius:10px;
                padding:1rem 1.1rem;margin-bottom:.9rem;">

                <label style="font-size:.8rem;font-weight:700;color:#0369a1;display:block;margin-bottom:.5rem;">
                    📸 Screenshot from URL
                    <span style="font-size:.72rem;font-weight:400;color:#64748b;margin-left:.4rem;">
                        — capture a page and add it to images
                    </span>
                </label>

                <div style="display:flex;gap:.5rem;align-items:center;">
                    <input type="url" id="screenshotUrl"
                           placeholder="https://example.com/article"

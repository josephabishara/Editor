                </div>
            </div> *@
            
            <div id="screenshotBlock"
                 style="background:#f0f9ff;border:1.5px solid #bae6fd;border-radius:10px;
                padding:1rem 1.1rem;margin-bottom:.9rem;">

                <label style="font-size:.8rem;font-weight:700;color:#0369a1;display:block;margin-bottom:.6rem;">
                    📸 Screenshot from URL
                    <span style="font-size:.72rem;font-weight:400;color:#64748b;margin-left:.4rem;">
                        — capture a page and add it to images
                    </span>
                </label>

              @*   {{-- URL row --}} *@
                <div style="display:flex;gap:.5rem;align-items:center;margin-bottom:.6rem;">
                    <input type="url" id="screenshotUrl"
                           placeholder="https://example.com/article"
                           style="flex:1;padding:.45rem .7rem;border:1.5px solid #bae6fd;border-radius:7px;
                    font-size:.85rem;outline:none;transition:border-color .15s;box-sizing:border-box;"
                           onfocus="this.style.borderColor='#0284c7'"
                           onblur="this.style.borderColor='#bae6fd'" />

                    <button type="button" id="btnUseArticleUrl" onclick="useArticleUrl()"
                            title="Copy the Article URL field"
                            style="display:inline-flex;align-items:center;gap:.3rem;background:#e0f2fe;
                        color:#0369a1;border:none;border-radius:7px;padding:.45rem .7rem;
                        font-size:.78rem;font-weight:600;cursor:pointer;white-space:nowrap;">
                        ⬆ Use Article URL
                    </button>
                </div>

               @*  {{-- Options row --}} *@
                <div style="display:flex;gap:.6rem;align-items:center;flex-wrap:wrap;margin-bottom:.6rem;">

                   @*  {{-- Capture mode --}} *@
                    <div style="display:flex;align-items:center;gap:.4rem;font-size:.8rem;color:#475569;">
                        <label style="font-weight:600;white-space:nowrap;">Mode:</label>
                        <label style="display:flex;align-items:center;gap:.25rem;cursor:pointer;">
                            <input type="radio" name="ssMode" id="ssCrop" value="crop" checked />
                            Crop
                        </label>
                        <label style="display:flex;align-items:center;gap:.25rem;cursor:pointer;">
                            <input type="radio" name="ssMode" id="ssFullpage" value="fullpage" />
                            Full Page
                        </label>
                    </div>

                   @*  {{-- Width --}} *@
                    <div style="display:flex;align-items:center;gap:.35rem;font-size:.8rem;color:#475569;">
                        <label style="font-weight:600;white-space:nowrap;">Width:</label>
                        <select id="ssWidth"
                                style="padding:.3rem .5rem;border:1.5px solid #bae6fd;border-radius:6px;
                            font-size:.8rem;background:#fff;color:#1e293b;">
                            <option value="800">800 px</option>
                            <option value="1024">1024 px</option>
                            <option value="1280" selected>1280 px  (default)</option>
                            <option value="1440">1440 px</option>
                            <option value="1920">1920 px</option>
                        </select>
                    </div>

                  @*   {{-- Crop height (hidden when fullpage is selected) --}} *@
                    <div id="cropHeightGroup"
                         style="display:flex;align-items:center;gap:.35rem;font-size:.8rem;color:#475569;">
                        <label style="font-weight:600;white-space:nowrap;">Height (crop):</label>
                        <select id="ssCropHeight"
                                style="padding:.3rem .5rem;border:1.5px solid #bae6fd;border-radius:6px;
                            font-size:.8rem;background:#fff;color:#1e293b;">
                            <option value="600">600 px</option>
                            <option value="800">800 px</option>
                            <option value="900" selected>900 px  (default)</option>
                            <option value="1080">1080 px</option>
                            <option value="1200">1200 px</option>
                            <option value="1600">1600 px</option>
                            <option value="2000">2000 px</option>
                            <option value="3000">3000 px</option>
                            <option value="5000">5000 px  (very tall)</option>
                        </select>
                    </div>

                  @*   {{-- Take screenshot button --}} *@
                    <button type="button" id="btnScreenshot" onclick="screenshotFromUrl()"
                            style="display:inline-flex;align-items:center;gap:.35rem;background:#0284c7;
                        color:#fff;border:none;border-radius:7px;padding:.45rem 1rem;
                        font-size:.82rem;font-weight:700;cursor:pointer;white-space:nowrap;
                        transition:background .15s;"
                            onmouseover="this.style.background='#0369a1'"
                            onmouseout="this.style.background='#0284c7'">
                        <span id="screenshotSpinner"
                              style="display:none;width:13px;height:13px;
                        border:2px solid rgba(255,255,255,.4);border-top-color:#fff;
                        border-radius:50%;animation:spin .6s linear infinite;"></span>
                        📸 Take Screenshot
                    </button>
                </div>

                <div id="screenshotStatus"
                     style="font-size:.78rem;color:#0369a1;display:none;margin-bottom:.4rem;"></div>

                <div id="screenshotPreview" style="display:none;">
                    <img id="screenshotImg"
                         style="max-width:100%;max-height:200px;border-radius:7px;
                    border:1.5px solid #0284c7;object-fit:contain;display:block;" />
                    <div style="font-size:.75rem;color:#64748b;margin-top:.25rem;" id="screenshotDimLabel"></div>
                    <button type="button" onclick="removeScreenshot()"
                            style="display:inline-flex;align-items:center;gap:.25rem;margin-top:.3rem;
                        background:none;border:none;color:#dc2626;font-size:.75rem;
                        cursor:pointer;padding:0;">
                        ✕ Remove screenshot
                    </button>
                </div>
            </div>

            @* ── Image Drop Zone ── *@
            <div class="fg">
                <div id="dropZone"
                     style="border:2px dashed var(--rule,#cbd5e1);border-radius:10px;
                    padding:1.4rem 1rem;text-align:center;background:#f8fafc;
                    cursor:pointer;min-height:110px;transition:border-color .2s,background .2s;">
                    <div style="font-size:2rem;line-height:1;">📁</div>
                    <p style="color:#64748b;margin:.4rem 0 .2rem;font-size:.88rem;">
                        Drag &amp; drop images here, or <strong>click to browse</strong>
                    </p>
                    <small style="color:#94a3b8;">JPG · PNG · GIF · WebP &nbsp;|&nbsp; Multiple selection allowed</small>
                    <input type="file" name="imageFiles" id="imageFilesInput"
                           multiple accept=".jpg,.jpeg,.png,.gif,.webp" style="display:none;" />
                </div>
                <div id="newPreviewGrid" style="display:flex;flex-wrap:wrap;gap:8px;margin-top:10px;"></div>

                @if (existingImagePaths.Any())
                {
                    <p style="font-size:.8rem;font-weight:600;color:#64748b;margin:12px 0 6px;">Current Images</p>
                    <div id="existingGrid" style="display:flex;flex-wrap:wrap;gap:8px;">
                        @foreach (var path in existingImagePaths)
                        {
                            <div class="existing-thumb" data-path="@path" style="position:relative;">
                                <img src="@path"
                                     style="width:88px;height:88px;object-fit:cover;border-radius:6px;border:1px solid #e2e8f0;"
                                     onerror="this.src='/images/no-image.png'" />
                                <button type="button" class="remove-existing" data-path="@path" title="Remove"
                                        style="position:absolute;top:2px;right:2px;background:#ef4444;color:#fff;
                                    border:none;border-radius:50%;width:20px;height:20px;font-size:11px;
                                    line-height:1;cursor:pointer;display:flex;align-items:center;justify-content:center;">
                                    ✕
                                </button>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        @* ── CARD 2: Child Articles ── *@
        <div class="form-card" id="childrenCard">
            <div class="form-card-title" style="display:flex;justify-content:space-between;align-items:center;">
                <span>📎 Also Mention (Other Sources)</span>
                <button type="button" id="btnAddChild"
                        style="background:var(--blue,#3b82f6);color:#fff;border:none;
                    border-radius:6px;padding:.3rem .9rem;font-size:.82rem;cursor:pointer;">
                    + Also Mention
                </button>
            </div>
            <div id="childRowsContainer"></div>
            <template id="childRowTemplate">
                <div class="child-row" data-index="__IDX__"
                     style="border:1px solid #e2e8f0;border-radius:8px;padding:.9rem;
                    margin-bottom:.75rem;background:#f8fafc;position:relative;">
                    <div style="position:absolute;top:8px;right:10px;">
                        <button type="button" class="btn-remove-child"
                                style="background:#ef4444;color:#fff;border:none;border-radius:50%;
                            width:22px;height:22px;font-size:12px;cursor:pointer;line-height:1;">
                            ✕
                        </button>
                    </div>
                    <div style="font-size:.78rem;font-weight:600;color:#64748b;margin-bottom:.6rem;">
                        Child #<span class="child-number">1</span>
                    </div>
                    <div style="display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:.7rem;">
                        <div>
                            <label style="font-size:.8rem;font-weight:600;">Website <span style="color:#ef4444">*</span></label>
                            <select name="Children[__IDX__].WebsiteId" class="child-website-sel"
                                    style="width:100%;padding:.35rem .5rem;border:1px solid #cbd5e1;border-radius:6px;font-size:.85rem;"
                                    onchange="autoFillChild(this,__IDX__)">
                                <option value="0">— Select —</option>
                                {{WEBSITE_OPTIONS}}
                            </select>
                        </div>
                        <div>
                            <label style="font-size:.8rem;font-weight:600;">Writer</label>
                            <select name="Children[__IDX__].WriterId"
                                    style="width:100%;padding:.35rem .5rem;border:1px solid #cbd5e1;border-radius:6px;font-size:.85rem;">
                                <option value="0">— None —</option>
                                {{WRITER_OPTIONS}}
                            </select>
                        </div>
                        <div>
                            <label style="font-size:.8rem;font-weight:600;">Date <span style="color:#ef4444">*</span></label>
                            <input type="date" name="Children[__IDX__].Date"
                                   style="width:100%;padding:.35rem .5rem;border:1px solid #cbd5e1;border-radius:6px;font-size:.85rem;" />
                        </div>
                        <div>
                            <label style="font-size:.8rem;font-weight:600;">Article URL</label>
                            <input type="url" name="Children[__IDX__].ArticleURL" placeholder="https://…"
                                   style="width:100%;padding:.35rem .5rem;border:1px solid #cbd5e1;border-radius:6px;font-size:.85rem;" />
                        </div>
                    </div>
                    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:.7rem;margin-top:.6rem;">
                        <div>
                            <label style="font-size:.75rem;color:#64748b;">AD Value</label>
                            <input type="number" step="0.01" name="Children[__IDX__].ADValue" class="child-ad"
                                   id="childAD___IDX__" value="0" oninput="recalcChildPR(this,__IDX__)"
                                   style="width:100%;padding:.3rem .5rem;border:1px solid #cbd5e1;border-radius:6px;font-size:.83rem;background:#f1f5f9;" />
                        </div>
                        <div>
                            <label style="font-size:.75rem;color:#64748b;">PR Value (×3.5)</label>
                            <input type="number" step="0.01" name="Children[__IDX__].PRValue" class="child-pr"
                                   id="childPR___IDX__" value="0" readonly
                                   style="width:100%;padding:.3rem .5rem;border:1px solid #e2e8f0;border-radius:6px;font-size:.83rem;background:#e2e8f0;" />
                        </div>
                        <div>
                            <label style="font-size:.75rem;color:#64748b;">Media Tier</label>
                            <input type="text" name="Children[__IDX__].MediaTier" class="child-tier" readonly
                                   style="width:100%;padding:.3rem .5rem;border:1px solid #e2e8f0;border-radius:6px;font-size:.83rem;background:#e2e8f0;" />
                        </div>
                        <div>
                            <label style="font-size:.75rem;color:#64748b;">Language</label>
                            <input type="text" name="Children[__IDX__].Language"
                                   style="width:100%;padding:.3rem .5rem;border:1px solid #cbd5e1;border-radius:6px;font-size:.83rem;" />
                        </div>
                    </div>
                </div>
            </template>
        </div>

        @* ── CARD 3: Auto-fill (hidden) ── *@
        <div class="form-card" style="display:none;">
            <div class="fg-4">
                <div class="fg"><label asp-for="MediaType">Media Type</label><input asp-for="MediaType" class="autofill" id="afMediaType" readonly /></div>
                <div class="fg"><label asp-for="MediaTier">Media Tier</label><input asp-for="MediaTier" class="autofill" id="afMediaTier" readonly /></div>
                <div class="fg"><label asp-for="Frequency">Frequency</label><input asp-for="Frequency" class="autofill" id="afFrequency" readonly /></div>
                <div class="fg"><label asp-for="Language">Language</label><input asp-for="Language" class="autofill" id="afLanguage" readonly /></div>
            </div>
            <div class="fg-4" style="margin-top:.9rem;">
                <div class="fg"><label asp-for="Impression">Impression</label><input asp-for="Impression" type="number" id="afImpression" class="autofill" /></div>
                <div class="fg"><label asp-for="Reach">Reach</label><input asp-for="Reach" class="autofill" id="afReach" readonly /></div>
                <div class="fg"><label asp-for="ADValue">AD Value</label><input asp-for="ADValue" type="number" step="0.01" id="afAD" class="autofill" /></div>
                <div class="fg"><label asp-for="PRValue">PR Value</label><input asp-for="PRValue" class="autofill" id="afPR" readonly /></div>
            </div>
        </div>

        @* ── Footer ── *@
        <div class="form-footer">
            <a href="@Url.Action("Index", new { clientId = Model.ClientId })" class="btn-cancel">Cancel</a>
            <button type="submit" class="btn-save">@(isEdit ? "💾 Save" : "✅ Save")</button>
        </div>

    </form>
</div>

@section Scripts {
    <script>
        const clientId = @Model.ClientId;

        // ── "Use Article URL" shortcut ────────────────────────────────────────────────
        // function useArticleUrl() {
        // const src = document.getElementById('articleUrlField')?.value?.trim();
        // if (src) {
        // document.getElementById('screenshotUrl').value = src;
        // document.getElementById('screenshotUrl').focus();
        // }
        // }

        // ── Screenshot capture ────────────────────────────────────────────────────────
        
       // let _screenshotPath = null;

      
        // async function screenshotFromUrl() {
        // const urlInput   = document.getElementById('screenshotUrl');

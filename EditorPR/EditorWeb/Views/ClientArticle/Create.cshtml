        function addPathToImages(path) {
        const hdn = document.getElementById('hdnImages');
        let paths = [];
        try { paths = JSON.parse(hdn.value || '[]'); } catch {}
        if (!paths.includes(path)) { paths.push(path); hdn.value = JSON.stringify(paths); }
        }

        function removePathFromImages(path) {
        const hdn = document.getElementById('hdnImages');
        let paths = [];
        try { paths = JSON.parse(hdn.value || '[]'); } catch {}
        hdn.value = JSON.stringify(paths.filter(p => p !== path));
        }

        // FIX BUG 2: data-screenshot-thumb marks this as a screenshot so
        // renderPreviews() (which only removes [data-upload-thumb]) won't erase it
        function addThumbToGrid(path, label) {
        const grid = document.getElementById('newPreviewGrid');
        const wrap = document.createElement('div');
        wrap.style.cssText      = 'position:relative;';
        wrap.dataset.screenshotThumb = '1';
        wrap.innerHTML = `
        <img src="${path}"
        style="width:88px;height:88px;object-fit:cover;
        border-radius:6px;border:2px solid #0284c7;" />
        <span style="position:absolute;bottom:0;left:0;right:0;
        background:rgba(2,132,199,.85);color:#fff;font-size:9px;
        padding:2px 4px;border-radius:0 0 6px 6px;
        white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${label}</span>`;
        grid.appendChild(wrap);
        }

        // ── Toggle crop height group when mode changes ────────────────────────────────
        document.querySelectorAll('input[name="ssMode"]').forEach(radio => {
        radio.addEventListener('change', function () {
        document.getElementById('cropHeightGroup').style.display =
        this.value === 'fullpage' ? 'none' : 'flex';
        });
        });

        function useArticleUrl() {
        const src = document.getElementById('articleUrlField')?.value?.trim();
        if (src) { document.getElementById('screenshotUrl').value = src; }
        }

        let _screenshotPath = null;

        async function screenshotFromUrl() {
        const urlInput   = document.getElementById('screenshotUrl');
        const previewEl  = document.getElementById('screenshotPreview');
        const previewImg = document.getElementById('screenshotImg');
        const dimLabel   = document.getElementById('screenshotDimLabel');
        const spinner    = document.getElementById('screenshotSpinner');
        const btn        = document.getElementById('btnScreenshot');

        const targetUrl = urlInput.value.trim();
        if (!targetUrl) { setScreenshotStatus('⚠️ Please enter a URL first.', '#c2410c'); return; }
        if (!targetUrl.startsWith('http://') && !targetUrl.startsWith('https://')) {
        setScreenshotStatus('⚠️ URL must start with http:// or https://', '#c2410c'); return;
        }

        // Read options
        const mode        = document.querySelector('input[name="ssMode"]:checked')?.value ?? 'crop';
        const width       = document.getElementById('ssWidth').value;
        const cropHeight  = document.getElementById('ssCropHeight').value;

        spinner.style.display   = 'inline-block';
        btn.disabled            = true;
        previewEl.style.display = 'none';
        setScreenshotStatus(
        mode === 'fullpage'
        ? `⏳ Capturing full page at ${width}px wide… (may take 10–20 s)`
        : `⏳ Capturing ${width}×${cropHeight}px screenshot…`,
        '#0369a1'
        );

        try {
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';

        // Send mode + dimensions as form fields — controller reads them via [FromForm]
        const formData = new FormData();
        formData.append('__RequestVerificationToken', token);
        formData.append('url',         targetUrl);
        formData.append('captureMode', mode);
        formData.append('width',       width);
        formData.append('cropHeight',  cropHeight);

        const resp = await fetch('/ClientArticle/CaptureScreenshot', {
        method: 'POST',
        body:   formData
        });

        const data = await resp.json();
        if (!resp.ok) throw new Error(data.error || `Server error ${resp.status}`);

        _screenshotPath     = data.path;
        previewImg.src      = data.path;
        previewEl.style.display = 'block';

        const dimText = mode === 'fullpage'
        ? `Full page · ${width}px wide`
        : `${width} × ${cropHeight}px`;
        dimLabel.textContent = dimText;

        setScreenshotStatus('✅ Screenshot captured and added to images.', '#15803d');

        addPathToImages(data.path);
        addThumbToGrid(data.path, `📸 ${dimText}`);

        } catch (err) {
        setScreenshotStatus(`❌ ${err.message}`, '#dc2626');
        console.error('Screenshot error:', err);
        } finally {
        spinner.style.display = 'none';
        btn.disabled          = false;
        }
        }

        function removeScreenshot() {
        if (!_screenshotPath) return;
        removePathFromImages(_screenshotPath);
        document.querySelectorAll('#newPreviewGrid [data-screenshot-thumb]').forEach(el => el.remove());
        _screenshotPath = null;
        document.getElementById('screenshotPreview').style.display = 'none';
        document.getElementById('screenshotStatus').style.display  = 'none';
        }

        function setScreenshotStatus(msg, color) {
        const el = document.getElementById('screenshotStatus');
        el.textContent = msg; el.style.color = color; el.style.display = 'block';
        }

        // ── Website auto-fill ─────────────────────────────────────────────────────────
        async function autoFillWebsite(webId) {
        if (!webId || webId == '0') return;
        const d = await (await fetch(`/ClientArticle/GetWebsiteAutoFill?websiteId=${webId}&clientId=${clientId}`)).json();
        document.getElementById('afMediaType').value  = d.mediaType  ?? '';
        document.getElementById('afMediaTier').value  = d.mediaTier  ?? '';
        document.getElementById('afFrequency').value  = d.frequency  ?? '';
        document.getElementById('afLanguage').value   = d.language   ?? '';
        document.getElementById('afImpression').value = d.impression ?? '';
        document.getElementById('afReach').value      = d.reach      ?? '';
        document.getElementById('afAD').value         = d.adValue    ?? '';
        document.getElementById('afPR').value         = d.prValue    ?? '';
        }

        async function loadSubs(parentId) {
        const sel = document.getElementById('subSel');
        sel.innerHTML = '<option value="0">Loading…</option>';
        if (!parentId || parentId == '0') { sel.innerHTML = '<option value="0">— None —</option>'; return; }
        const data = await (await fetch(`/ClientArticle/GetSubCategories?parentId=${parentId}`)).json();
        sel.innerHTML = '<option value="0">— None —</option>';
        data.forEach(s => sel.innerHTML += `<option value="${s.value}">${s.text}</option>`);
        }

        $(document).ready(function () {
        $('.select-search').select2({ placeholder: 'Search...', allowClear: true });
        });

        // ── Image drop zone IIFE ──────────────────────────────────────────────────────
        (function () {
        const dropZone   = document.getElementById('dropZone');
        const fileInput  = document.getElementById('imageFilesInput');
        const newGrid    = document.getElementById('newPreviewGrid');
        const hdnImages  = document.getElementById('hdnImages');
        const hdnRemoved = document.getElementById('hdnRemovedImages');

        dropZone.addEventListener('click', () => fileInput.click());
        dropZone.addEventListener('dragover', e => {
        e.preventDefault(); dropZone.style.borderColor='#3b82f6'; dropZone.style.background='#eff6ff';
        });
        ['dragleave','dragend'].forEach(evt =>
        dropZone.addEventListener(evt, () => { dropZone.style.borderColor=''; dropZone.style.background=''; })
        );
        dropZone.addEventListener('drop', e => {
        e.preventDefault(); dropZone.style.borderColor=''; dropZone.style.background='';
        mergeFiles(e.dataTransfer.files); renderPreviews(fileInput.files);
        });
        fileInput.addEventListener('change', () => renderPreviews(fileInput.files));

        function renderPreviews(files) {
        // FIX BUG 2: only remove upload thumbs, preserve screenshot thumbs
        newGrid.querySelectorAll('[data-upload-thumb]').forEach(el => el.remove());

        Array.from(files).forEach(file => {
        if (!file.type.startsWith('image/')) return;
        const reader = new FileReader();
        reader.onload = ev => {
        const wrap = document.createElement('div');
        wrap.style.cssText    = 'position:relative;';
        wrap.dataset.uploadThumb = '1';  // ← tagged so renderPreviews can find it
        wrap.innerHTML = `
        <img src="${ev.target.result}"
        style="width:88px;height:88px;object-fit:cover;border-radius:6px;border:1px solid #e2e8f0;" />
        <span style="position:absolute;bottom:0;left:0;right:0;background:rgba(0,0,0,.55);
        color:#fff;font-size:9px;padding:2px 4px;border-radius:0 0 6px 6px;
        white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${file.name}</span>`;
        newGrid.appendChild(wrap);
        };
        reader.readAsDataURL(file);
        });
        }

        function mergeFiles(dropped) {
        const dt = new DataTransfer();
        if (fileInput.files) Array.from(fileInput.files).forEach(f => dt.items.add(f));
        Array.from(dropped).forEach(f => dt.items.add(f));
        fileInput.files = dt.files;
        }

        document.querySelectorAll('.remove-existing').forEach(btn => {
        btn.addEventListener('click', function () {
        const path = this.dataset.path;
        this.closest('.existing-thumb').remove();
        let current = [];
        try { current = JSON.parse(hdnImages.value || '[]'); } catch {}
        current = current.filter(p => p !== path);
        hdnImages.value = JSON.stringify(current);
        let removed = [];
        try { removed = JSON.parse(hdnRemoved.value || '[]'); } catch {}
        if (!removed.includes(path)) removed.push(path);
        hdnRemoved.value = JSON.stringify(removed);
        });
        });
        })();

        // ── Children IIFE ─────────────────────────────────────────────────────────────
        (function () {
        const websiteOptions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                    Model.WebsiteOptions.Select(o => new { value = o.Value, text = o.Text })));
        const writerOptions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                    Model.WriterOptions.Select(o => new { value = o.Value, text = o.Text })));

        function buildOptions(list, sel) {
        return list.map(o =>
        `<option value="${o.value}"${o.value==sel?' selected':''}>${o.text}</option>`
        ).join('');
        }

        let childIndex = 0;
        const container = document.getElementById('childRowsContainer');
        const template  = document.getElementById('childRowTemplate');
        const today     = new Date().toISOString().split('T')[0];

        document.getElementById('btnAddChild').addEventListener('click', () => {
        addChildRow(childIndex++);
        });

        function addChildRow(idx, data) {
        let html = template.innerHTML
        .replaceAll('__IDX__', idx)
        .replace('{{WEBSITE_OPTIONS}}', buildOptions(websiteOptions, data?.websiteId ?? 0))
        .replace('{{WRITER_OPTIONS}}',  buildOptions(writerOptions,  data?.writerId  ?? 0));

        const wrapper = document.createElement('div');
        wrapper.innerHTML = html;
        const row = wrapper.firstElementChild;
        row.querySelector('.child-number').textContent = idx + 1;

        if (data?.date)
        row.querySelector(`[name="Children[${idx}].Date"]`).value = data.date;
        if (data?.id > 0) {
        const hdnId = document.createElement('input');
        hdnId.type = 'hidden'; hdnId.name = `Children[${idx}].Id`; hdnId.value = data.id;
        row.appendChild(hdnId);
        }

        row.querySelector('.btn-remove-child').addEventListener('click', function () {
        row.remove();
        container.querySelectorAll('.child-row').forEach((r, i) =>
        r.querySelector('.child-number').textContent = i + 1);
        });
        container.appendChild(row);
        }

        window.autoFillChild = async function (sel, idx) {
        const webId = sel.value;
        if (!webId || webId == '0') return;
        const d = await (await fetch(`/ClientArticle/GetWebsiteAutoFill?websiteId=${webId}&clientId=${clientId}`)).json();
        const row = sel.closest('.child-row');
        row.querySelector(`[name="Children[${idx}].ADValue"]`).value   = d.adValue   ?? '';
        row.querySelector(`[name="Children[${idx}].PRValue"]`).value   = d.prValue   ?? '';
        row.querySelector(`[name="Children[${idx}].MediaTier"]`).value = d.mediaTier ?? '';
        row.querySelector(`[name="Children[${idx}].Language"]`).value  = d.language  ?? '';
        };

        window.recalcChildPR = function (adInput, idx) {
        const ad = parseFloat(adInput.value) || 0;
        adInput.closest('.child-row').querySelector(`[name="Children[${idx}].PRValue"]`).value = (ad * 3.5).toFixed(2);
        };

        @if (Model.Children != null && Model.Children.Any())
        {
            <text>
                const existingChildren = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                                Model.Children.Select(c => new
                                {
                                    id = c.Id,
                                    websiteId = c.WebsiteId,
                                    writerId = c.WriterId,
                                    date = c.Date.ToString("yyyy-MM-dd"),
                                    articleURL = c.ArticleURL ?? "",
                                    adValue = c.ADValue,
                                    prValue = c.PRValue,
                                    mediaTier = c.MediaTier ?? "",
                                    language = c.Language ?? ""
                                })));

                existingChildren.forEach(child => {
                addChildRow(childIndex, child);
                const row = container.lastElementChild;
                const idx = childIndex;
                row.querySelector(`[name="Children[${idx}].ArticleURL"]`).value = child.articleURL;
                row.querySelector(`[name="Children[${idx}].ADValue"]`).value    = child.adValue;
                row.querySelector(`[name="Children[${idx}].PRValue"]`).value    = child.prValue;
                row.querySelector(`[name="Children[${idx}].MediaTier"]`).value  = child.mediaTier;
                row.querySelector(`[name="Children[${idx}].Language"]`).value   = child.language;
                childIndex++;
                });
            </text>
        }
        })();
    </script>

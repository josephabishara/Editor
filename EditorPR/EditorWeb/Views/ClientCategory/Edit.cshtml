@model EditorViewModelLayer.ClientViewModel.ClientCategoryDTO
@{
    ViewData["Title"] = "Edit Category";
}

<h2>Edit: @Model.CategoryName</h2>
<hr />
<div class="container mt-4" style="width: 75%;">
    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <partial name="_Form" model="Model" />
                <div class="mt-3">
                    <button type="submit" class="btn btn-warning">Update</button>
                    <a asp-action="Index" asp-route-clientId="@Model.ClientId" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
@model EditorViewModelLayer.ClientViewModel.ClientCategoryDTO
@{
    ViewData["Title"] = "New Category";
}

<h2>New Category</h2>
<hr />
<div class="container mt-4" style="width: 75%;">
    <div class="card shadow-sm">
        <div class="card-body">
<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <partial name="_Form" model="Model" />
    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" asp-route-clientId="@Model.ClientId" class="btn btn-secondary">Cancel</a>
    </div>
</form>
        </div>    </div>
</div>
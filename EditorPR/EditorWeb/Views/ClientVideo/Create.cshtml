@model EditorViewModelLayer.MediaViewModel.ClientVideoDTO
@using EditorViewModelLayer.MediaViewModel
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Add Video";

    List<SelectListItem> ToSL(List<MediaSelectOption> src)
        => src.Select(o => new SelectListItem(o.Text, o.Value, o.Selected)).ToList();

    var chSL = ToSL(Model.ChannelOptions);
    var catSL = ToSL(Model.CategoryOptions);
    var subSL = ToSL(Model.SubCategoryOptions);
    var toningSL = ToSL(Model.ToningOptions);
}

@await Html.PartialAsync("_MediaStyles")

<style>
    .file-drop {
        border: 2px dashed var(--rule);
        border-radius: 9px;
        padding: 1.25rem;
        text-align: center;
        cursor: pointer;
        transition: border-color .15s,background .15s;
        background: var(--bg);
    }

        .file-drop:hover {
            border-color: var(--accent);
            background: #f0f4ff;
        }

        .file-drop input[type=file] {
            display: none;
        }

        .file-drop .drop-icon {
            font-size: 1.8rem;
            margin-bottom: .35rem;
        }

        .file-drop p {
            font-size: .8rem;
            color: var(--slate);
            margin: 0;
        }

    .file-preview {
        margin-top: .6rem;
        font-size: .78rem;
        color: var(--ink-2);
    }

        .file-preview img {
            max-height: 80px;
            border-radius: 6px;
            margin-top: .4rem;
            object-fit: cover;
        }

    #uploadOverlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(15,23,42,.6);
        z-index: 9999;
        align-items: center;
        justify-content: center;
        flex-direction: column;
    }

        #uploadOverlay.active {
            display: flex;
        }

        #uploadOverlay .box {
            background: #fff;
            border-radius: 14px;
            padding: 2rem 2.5rem;
            text-align: center;
            min-width: 300px;
            max-width: 420px;
            box-shadow: 0 20px 60px rgba(0,0,0,.3);
        }

            #uploadOverlay .box h3 {
                margin: 0 0 .4rem;
                font-size: 1rem;
                color: #1e293b;
            }

            #uploadOverlay .box p {
                margin: 0 0 1rem;
                font-size: .82rem;
                color: #64748b;
            }

    #progressBar {
        width: 100%;
        height: 10px;
        background: #e2e8f0;
        border-radius: 999px;
        overflow: hidden;
    }

    #progressFill {
        height: 100%;
        width: 0%;
        background: #3b82f6;
        border-radius: 999px;
        transition: width .3s;
    }

    #progressPct {
        font-size: .82rem;
        color: #1e293b;
        font-weight: 600;
        margin-top: .5rem;
    }

    #uploadFileSize {
        font-size: .75rem;
        color: #94a3b8;
        margin-top: .2rem;
    }

    #uploadErrorBox {
        display: none;
        margin-top: 1rem;
        background: #fef2f2;
        border: 1px solid #fca5a5;
        border-radius: 8px;
        padding: .75rem;
        font-size: .8rem;
        color: #dc2626;
        text-align: left;
    }
</style>

<div id="uploadOverlay">
    <div class="box">
        <h3 id="overlayTitle">📤 Uploading Video…</h3>
        <p>Please wait. Do not close or refresh this page.</p>
        <div id="progressBar"><div id="progressFill"></div></div>
        <div id="progressPct">0%</div>
        <div id="uploadFileSize"></div>
        <div id="uploadErrorBox"></div>
        <button id="btnOverlayClose"
                style="display:none;margin-top:1rem;background:#ef4444;color:#fff;
            border:none;border-radius:7px;padding:.4rem 1.1rem;
            font-size:.85rem;cursor:pointer;"
                onclick="closeOverlay()">
            Close &amp; Try Again
        </button>
    </div>
</div>

<div class="form-wrap">

    <a href="@Url.Action("Index", new { clientId = Model.ClientId })"
       style="display:inline-flex;align-items:center;gap:.4rem;color:var(--slate);
        font-size:.82rem;text-decoration:none;margin-bottom:1.1rem;">
        ← Back to Videos
    </a>

    @await Html.PartialAsync("_navdashboard")

    <div class="m-header" style="margin-bottom:1.4rem;">
        <div class="m-header-icon" style="background:#ede9fe;">📺</div>
        <div><h1>Add Video</h1><p>@Model.ClientName</p></div>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="val-summary">
            <strong>Please fix the errors below:</strong>
            <ul>@foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors)) {
                <li>@err.ErrorMessage</li>
            }
        </ul>
    </div>
}

<form id="videoForm" method="post" enctype="multipart/form-data"
      action="@Url.Action("Create")">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="ClientId" />

    @* ── CARD 1: Source & Details ── *@
    <div class="form-card">
        <div class="fg-3">
            <div class="fg">
                <label asp-for="ChannelId">Channel <span style="color:var(--red)">*</span></label>
                <select asp-for="ChannelId" asp-items="chSL"
                        onchange="autoFillChannel(this.value)" class="select-search" required>
                    <option value="0">— Select —</option>
                </select>
                <span asp-validation-for="ChannelId" class="field-error"></span>
            </div>
            <div class="fg">
                <label asp-for="CategoryId">Category</label>
                <select asp-for="CategoryId" asp-items="catSL"
                        id="catSel" class="select-search" onchange="loadSubs(this.value)">
                    <option value="0">— None —</option>
                </select>
            </div>
            <div class="fg">
                <label asp-for="SubCategoryId">Sub Category</label>
                <select asp-for="SubCategoryId" asp-items="subSL" class="select-search" id="subSel">
                    <option value="0">— None —</option>
                </select>
            </div>
        </div>

        <div class="fg-3" style="margin-top:.9rem;">
            <div class="fg">
                <label asp-for="Title">Title <span style="color:var(--red)">*</span></label>
                <input asp-for="Title" placeholder="Video title…" required />
                <span asp-validation-for="Title" class="field-error"></span>
            </div>
            <div class="fg">
                <label asp-for="Program">Program</label>
                <input asp-for="Program" placeholder="Program name…" />
            </div>
            <div class="fg">
                <label asp-for="VideoUrl">Video URL</label>
                <input asp-for="VideoUrl" type="url" placeholder="https://…" />
            </div>
        </div>

        <div class="fg-3" style="margin-top:.9rem;">
            <div class="fg">
                <label asp-for="Date">Date <span style="color:var(--red)">*</span></label>
                <input asp-for="Date" type="date" required />
                <span asp-validation-for="Date" class="field-error"></span>
            </div>
            <div class="fg">
                <label asp-for="Duration">Duration (sec)</label>
                <input asp-for="Duration" type="number" min="0" />
            </div>
            <div class="fg">
                <label asp-for="Toning">Toning</label>
                <select asp-for="Toning" asp-items="toningSL">
                    <option value="">— Select —</option>
                </select>
            </div>
        </div>
    </div>

    @* ── CARD 2: Channel Auto-fill (hidden) ── *@
    <div class="form-card" style="display:none;">
        <div class="fg-4">
            <div class="fg"><label asp-for="Language">Language</label><input asp-for="Language" /></div>
            <div class="fg"><label asp-for="MediaTier">Media Tier</label><input asp-for="MediaTier" class="autofill" id="afMediaTier" readonly /></div>
            <div class="fg"><label asp-for="Impression">Impression</label><input asp-for="Impression" type="number" id="afImpression" oninput="recalcReach()" class="autofill" /></div>
            <div class="fg"><label asp-for="Reach">Reach (×4)</label><input asp-for="Reach" class="autofill" id="afReach" readonly /></div>
        </div>
        <div class="fg-4" style="margin-top:.9rem;">
            <div class="fg"><label asp-for="ADValue">AD Value</label><input asp-for="ADValue" type="number" step="0.01" id="afAD" oninput="recalcPR()" class="autofill" /></div>
            <div class="fg"><label asp-for="PRValue">PR Value (×3.5)</label><input asp-for="PRValue" class="autofill" id="afPR" readonly /></div>
            <div></div><div></div>
        </div>
    </div>

    @* ── CARD 3: File Uploads ── *@
    <div class="form-card">
        <div class="form-card-title">📁 Files</div>
        <div class="fg-2">
            <div class="fg">
                <label>Video File</label>
                <div class="file-drop" onclick="document.getElementById('videoFileInput').click()">
                    <div class="drop-icon">🎬</div>
                    <p>Click to upload video file</p>
                    <input type="file" id="videoFileInput" name="videoFile"
                           accept="video/*" onchange="onVideoSelected(this)" />
                    <div class="file-preview" id="videoPreview"></div>
                </div>
                <div id="fileSizeWarning"
                     style="display:none;margin-top:.4rem;font-size:.77rem;color:#d97706;
                    background:#fffbeb;border:1px solid #fde68a;
                    border-radius:6px;padding:.35rem .6rem;">
                    ⚠️ Large file — a progress bar will appear during upload.
                </div>
            </div>
            <div class="fg" style="display:none;">
                <label>Screenshot</label>
                <div class="file-drop" onclick="document.getElementById('screenshotInput').click()">
                    <div class="drop-icon">📸</div>
                    <p>Click to upload screenshot</p>
                    <input type="file" id="screenshotInput" name="screenshotFile"
                           accept="image/*" onchange="previewFile(this,'shotPreview')" />
                    <div class="file-preview" id="shotPreview"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="form-footer">
        <a href="@Url.Action("Index", new { clientId = Model.ClientId })" class="btn-cancel">Cancel</a>
        <button type="submit" class="btn-save" id="btnSave">✅ Save</button>
    </div>
</form>
</div>

@section Scripts {
    <script>
        const clientId      = @Model.ClientId;
        const indexUrl      = '@Url.Action("Index", new { clientId = Model.ClientId })';
        let   xhrRef        = null;   // keep reference so we can abort on close

        // ── Overlay helpers ───────────────────────────────────────────────────────────
        function showOverlayError(msg) {
            document.getElementById('overlayTitle').textContent   = '❌ Upload Failed';
            const errBox = document.getElementById('uploadErrorBox');
            errBox.textContent   = msg;
            errBox.style.display = 'block';
            document.getElementById('btnOverlayClose').style.display = 'inline-block';
            document.getElementById('progressFill').style.background = '#ef4444';
        }

        function closeOverlay() {
            if (xhrRef) { xhrRef.abort(); xhrRef = null; }
            document.getElementById('uploadOverlay').classList.remove('active');
            document.getElementById('btnSave').disabled = false;
            // Reset overlay state for next attempt
            document.getElementById('overlayTitle').textContent   = '📤 Uploading Video…';
            document.getElementById('uploadErrorBox').style.display = 'none';
            document.getElementById('btnOverlayClose').style.display = 'none';
            document.getElementById('progressFill').style.background = '#3b82f6';
            document.getElementById('progressFill').style.width = '0%';
            document.getElementById('progressPct').textContent  = '0%';
        }

        // ── Channel auto-fill ─────────────────────────────────────────────────────────
        async function autoFillChannel(chId) {
            if (!chId || chId == '0') return;
            const d = await (await fetch(`/ClientVideo/GetChannelAutoFill?channelId=${chId}&clientId=${clientId}`)).json();
            document.getElementById('afMediaTier').value  = d.mediaTier  ?? '';
            document.getElementById('afImpression').value = d.impression ?? '';
            document.getElementById('afReach').value      = d.reach      ?? '';
            document.getElementById('afAD').value         = d.adValue    ?? '';
            document.getElementById('afPR').value         = d.prValue    ?? '';
            document.querySelector('[name="MediaTier"]').value = d.mediaTier ?? '';
        }

        function recalcReach() {
            const imp = parseInt(document.getElementById('afImpression').value) || 0;
            document.getElementById('afReach').value = imp * 4;
            document.querySelector('[name="Reach"]').value = imp * 4;
        }

        function recalcPR() {
            const ad = parseFloat(document.getElementById('afAD').value) || 0;
            document.getElementById('afPR').value = (ad * 3.5).toFixed(2);
            document.querySelector('[name="PRValue"]').value = (ad * 3.5).toFixed(2);
        }

        async function loadSubs(parentId) {
            const sel = document.getElementById('subSel');
            sel.innerHTML = '<option value="0">Loading…</option>';
            if (!parentId || parentId == '0') { sel.innerHTML = '<option value="0">— None —</option>'; return; }
            const data = await (await fetch(`/ClientVideo/GetSubCategories?parentId=${parentId}`)).json();
            sel.innerHTML = '<option value="0">— None —</option>';
            data.forEach(s => sel.innerHTML += `<option value="${s.value}">${s.text}</option>`);
        }

        // ── File preview ──────────────────────────────────────────────────────────────
        function previewFile(input, previewId) {
            const preview = document.getElementById(previewId);
            preview.innerHTML = '';
            if (!input.files || !input.files[0]) return;
            const file = input.files[0];
            if (file.type.startsWith('image/')) {
                const reader = new FileReader();
                reader.onload = ev => {
                    const img = document.createElement('img');
                    img.src = ev.target.result;
                    preview.appendChild(img);
                };
                reader.readAsDataURL(file);
            } else {
                preview.innerHTML = `<span>📎 ${file.name}</span>`;
            }
        }

        function onVideoSelected(input) {
            const preview = document.getElementById('videoPreview');
            const warning = document.getElementById('fileSizeWarning');
            preview.innerHTML  = '';
            warning.style.display = 'none';
            if (!input.files || !input.files[0]) return;
            const file    = input.files[0];
            const sizeMB  = (file.size / 1024 / 1024).toFixed(1);
            preview.innerHTML = `<span>📎 ${file.name} (${sizeMB} MB)</span>`;
            if (file.size > 30 * 1024 * 1024) warning.style.display = 'block';
        }

        // ── Form submit → XHR with progress ──────────────────────────────────────────
        document.getElementById('videoForm').addEventListener('submit', function (ev) {
            const fileInput = document.getElementById('videoFileInput');

            // No video file — let normal submit proceed (small form, no progress needed)
            if (!fileInput.files || fileInput.files.length === 0) return;

            ev.preventDefault();

            const overlay = document.getElementById('uploadOverlay');
            const fill    = document.getElementById('progressFill');
            const pct     = document.getElementById('progressPct');
            const sizeEl  = document.getElementById('uploadFileSize');
            const btnSave = document.getElementById('btnSave');

            const file = fileInput.files[0];
            sizeEl.textContent = `${file.name} — ${(file.size / 1024 / 1024).toFixed(1)} MB`;

            overlay.classList.add('active');
            btnSave.disabled = true;

            const formData = new FormData(this);
            const xhr = new XMLHttpRequest();
            xhrRef    = xhr;

            // ── Upload progress ───────────────────────────────────────────────────────
            xhr.upload.addEventListener('progress', function (ev) {
                if (!ev.lengthComputable) return;
                const percent       = Math.round((ev.loaded / ev.total) * 100);
                fill.style.width    = percent + '%';
                pct.textContent     = percent + '%';
            });

            // ── Upload complete (server responded) ────────────────────────────────────
            xhr.addEventListener('load', function () {
                if (xhr.status >= 200 && xhr.status < 400) {
                    pct.textContent = '✅ Done! Redirecting…';
                    // responseURL = final URL after server redirect
                    window.location.href = xhr.responseURL || indexUrl;
                } else {
                    // Server returned an error — show status + response body
                    showOverlayError(
                        `Server returned HTTP ${xhr.status}.\n` +
                        (xhr.responseText
                            ? xhr.responseText.substring(0, 300)
                            : 'No details available.')
                    );
                    btnSave.disabled = false;
                }
            });

            // ── Connection dropped / refused ──────────────────────────────────────────
            // ERR_CONNECTION_REFUSED = IIS/IIS Express dropped the TCP connection.
            // Most common cause: web.config maxAllowedContentLength not set.
            // The web.config fix (maxAllowedContentLength = 4294967295) resolves this.
            xhr.addEventListener('error', function () {
                showOverlayError(
                    'The connection was refused or dropped by the server.\n\n' +
                    'This usually means the server rejected the file because it is too large.\n\n' +
                    'Fix: Ensure web.config contains:\n' +
                    '<security><requestFiltering>\n' +
                    '  <requestLimits maxAllowedContentLength="4294967295" />\n' +
                    '</requestFiltering></security>'
                );
                btnSave.disabled = false;
            });

            xhr.addEventListener('abort', function () {
                // User clicked "Close & Try Again" — already handled by closeOverlay()
            });

            xhr.open('POST', this.action);
            xhr.send(formData);
        });

        $(document).ready(function () {
            $('.select-search').select2({ placeholder: 'Search...', allowClear: true });
        });
    </script>
}

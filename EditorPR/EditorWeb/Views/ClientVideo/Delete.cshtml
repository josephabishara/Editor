@model EditorViewModelLayer.MediaViewModel.ClientVideoDTO

@{
    ViewData["Title"] = "Delete Video";
}

@await Html.PartialAsync("_MediaStyles")

<style>
    .danger-card {
        background: #fff5f5;
        border: 1.5px solid #fca5a5;
        border-radius: var(--radius, 10px);
        padding: 1.4rem 1.6rem;
        margin-bottom: 1.4rem;
    }

    .danger-icon {
        font-size: 2.2rem;
        line-height: 1;
        margin-bottom: .5rem;
    }

    .danger-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: #dc2626;
        margin-bottom: .25rem;
    }

    .danger-msg {
        font-size: .875rem;
        color: #6b7280;
    }

    .detail-label {
        font-size: .73rem;
        font-weight: 600;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: .03em;
        display: block;
        margin-bottom: .15rem;
    }

    .detail-value {
        font-size: .9rem;
        font-weight: 500;
        color: #1e293b;
    }

    .btn-confirm-del {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        background: #dc2626;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: .55rem 1.4rem;
        font-size: .9rem;
        font-weight: 700;
        cursor: pointer;
        transition: background .15s;
    }

        .btn-confirm-del:hover {
            background: #b91c1c;
        }
</style>

<div class="form-wrap">

    <a href="@Url.Action("Index", new { clientId = Model.ClientId })"
       style="display:inline-flex;align-items:center;gap:.4rem;color:var(--slate);
        font-size:.82rem;text-decoration:none;margin-bottom:1.1rem;">
        ← Back to Videos
    </a>

    @await Html.PartialAsync("_navdashboard")

    <div class="m-header" style="margin-bottom:1.2rem;">
        <div class="m-header-icon" style="background:#fee2e2;">🗑️</div>
        <div>
            <h1>Delete Video</h1>
            <p>@Model.ClientName</p>
        </div>
    </div>

    @* ── Warning banner ── *@
    <div class="danger-card">
        <div class="danger-icon">⚠️</div>
        <div class="danger-title">This action cannot be undone</div>
        <div class="danger-msg">
            You are about to permanently delete this video record
            @if (!string.IsNullOrEmpty(Model.VideoFile) || !string.IsNullOrEmpty(Model.Screenshot))
            {
                <text> and its associated files</text>
            }
            . Please review the details below before confirming.
        </div>
    </div>

    @* ── Video summary ── *@
    <div class="form-card">
        <div class="form-card-title">📺 Video to be deleted</div>

        <div class="fg-3">
            <div>
                <span class="detail-label">Title</span>
                <span class="detail-value" style="font-size:.97rem;font-weight:700;">@Model.Title</span>
            </div>
            <div>
                <span class="detail-label">Date</span>
                <span class="detail-value">@Model.Date.ToString("dd MMM yyyy")</span>
            </div>
            <div>
                <span class="detail-label">Channel</span>
                <span class="detail-value">@(Model.ChannelName ?? "—")</span>
            </div>
        </div>

        <div class="fg-3" style="margin-top:.9rem;">
            <div>
                <span class="detail-label">Category</span>
                <span class="detail-value">@(Model.CategoryName ?? "—")</span>
            </div>
            <div>
                <span class="detail-label">Sub Category</span>
                <span class="detail-value">@(Model.SubCategoryName ?? "—")</span>
            </div>
            <div>
                <span class="detail-label">Program</span>
                <span class="detail-value">@(Model.Program ?? "—")</span>
            </div>
        </div>

        <div class="fg-4" style="margin-top:.9rem;">
            <div>
                <span class="detail-label">AD Value</span>
                <span class="detail-value" style="color:#0ea5e9;font-weight:700;">
                    @Model.ADValue.ToString("N2")
                </span>
            </div>
            <div>
                <span class="detail-label">PR Value</span>
                <span class="detail-value" style="color:#16a34a;font-weight:700;">
                    @Model.PRValue.ToString("N2")
                </span>
            </div>
            <div>
                <span class="detail-label">Duration</span>
                <span class="detail-value">
                    @if (Model.Duration > 0)
                    {
                        var ts = TimeSpan.FromSeconds(Model.Duration);
                        @(ts.Hours > 0 ? $"{ts.Hours}h {ts.Minutes}m {ts.Seconds}s"
                          : ts.Minutes > 0 ? $"{ts.Minutes}m {ts.Seconds}s"
                          : $"{ts.Seconds}s")
                    }
                    else
                    {

                        <text>—</text>
                    }
                </span>
            </div>
            <div>
                <span class="detail-label">Toning</span>
                <span class="detail-value">@(Model.Toning ?? "—")</span>
            </div>
        </div>

        <div class="fg-3" style="margin-top:.9rem;">
            <div>
                <span class="detail-label">Language</span>
                <span class="detail-value">@(Model.Language ?? "—")</span>
            </div>
            <div>
                <span class="detail-label">Media Tier</span>
                <span class="detail-value">@(Model.MediaTier ?? "—")</span>
            </div>
            <div>
                <span class="detail-label">Created By</span>
                <span class="detail-value">@(Model.CreatedByUserName ?? "—")</span>
            </div>
        </div>

        @* ── Video URL ── *@
        @if (!string.IsNullOrWhiteSpace(Model.VideoUrl))
        {
            <div style="margin-top:.9rem;">
                <span class="detail-label">Video URL</span>
                <a href="@Model.VideoUrl" target="_blank" rel="noopener"
                   style="font-size:.85rem;word-break:break-all;">
                    @Model.VideoUrl
                </a>
            </div>
        }

        @* ── Files warning ── *@
        @{
            bool hasVideo = !string.IsNullOrEmpty(Model.VideoFile);
            bool hasShot = !string.IsNullOrEmpty(Model.Screenshot);
        }
        @if (hasVideo || hasShot)
        {
            <div style="margin-top:1rem;padding:.75rem;background:#fff7ed;
                border:1px solid #fed7aa;border-radius:7px;">
                <strong style="font-size:.82rem;color:#c2410c;">
                    ⚠️ The following files will also be deleted:
                </strong>
                <div style="margin-top:.5rem;display:flex;gap:1.5rem;align-items:flex-start;flex-wrap:wrap;">
                    @if (hasVideo)
                    {
                        <div>
                            <span class="detail-label">Video File</span>
                            <span style="font-size:.82rem;color:#1e293b;">
                                📎 @System.IO.Path.GetFileName(Model.VideoFile)
                            </span>
                        </div>
                    }
                    @if (hasShot)
                    {
                        <div>
                            <span class="detail-label">Screenshot</span>
                            <img src="@Model.Screenshot"
                                 style="width:90px;height:60px;object-fit:cover;border-radius:6px;
                            border:1.5px solid #fca5a5;opacity:.85;display:block;margin-top:.25rem;"
                                 onerror="this.src='/images/no-image.png'" />
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    @* ── Confirm form ── *@
    <form method="post"
          action="@Url.Action("Delete", new { id = Model.Id })"
          onsubmit="return confirm('Are you sure you want to permanently delete this video record? This cannot be undone.')">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.Id" />
        <input type="hidden" name="clientId" value="@Model.ClientId" />

        <div style="display:flex;gap:.75rem;align-items:center;flex-wrap:wrap;">
            <button type="submit" class="btn-confirm-del">
                🗑️ Yes, Delete Permanently
            </button>
            <a href="@Url.Action("Index", new { clientId = Model.ClientId })" class="btn-cancel">
                Cancel
            </a>
            <a href="@Url.Action("Details", new { id = Model.Id })"
               style="font-size:.82rem;color:var(--slate);text-decoration:none;margin-left:.25rem;">
                View Video
            </a>
        </div>
    </form>

</div>

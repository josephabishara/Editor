@{
    ViewData["Title"] = "Import Websites from Excel";
}

<div class="container mt-4" style="max-width: 600px;">
    <div class="d-flex align-items-center gap-2 mb-4">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">&larr;</a>
        <h4 class="mb-0 fw-semibold">Import Websites from Excel</h4>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm mb-3">
        <div class="card-header bg-light fw-semibold">Upload Excel File</div>
        <div class="card-body">
            <form asp-action="Import" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label">Select Excel File <span class="text-danger">*</span></label>
                    <input type="file" name="file" class="form-control" accept=".xlsx,.xls" required />
                    <div class="form-text">Accepted formats: .xlsx, .xls</div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success px-4">
                        Import
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-info">
        <div class="card-body">
            <h6 class="fw-semibold mb-2">Expected Column Structure</h6>
            <div class="table-responsive">
                <table class="table table-sm table-bordered mb-2">
                    <thead class="table-primary">
                        <tr>
                            <th>A</th>
                            <th>B</th>
                            <th>C</th>
                            <th>D</th>
                            <th>E</th>
                            <th>F</th>
                            <th>G</th>
                            <th>H</th>
                            <th>I</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="text-muted small">
                            <td>Id</td>
                            <td>Website Name <span class="text-danger">*</span></td>
                            <td>URL <span class="text-danger">*</span></td>
                            <td>Media Tier</td>
                            <td>Frequency</td>
                            <td>Reach</td>
                            <td>Distribution</td>
                            <td>Language</td>
                            <td>Unit Price</td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <p class="small text-muted mb-2">
                <span class="text-danger">*</span> Required columns. Row 1 is the header — data starts from Row 2.
                The <strong>Id</strong> column is ignored on import (auto-generated).
            </p>
            <a asp-action="DownloadTemplate" class="btn btn-sm btn-outline-primary">
                Download Blank Template
            </a>
        </div>
    </div>
</div>

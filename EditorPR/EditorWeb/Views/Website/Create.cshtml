@model EditorViewModelLayer.WebsiteViewModel.WebsiteDTO    
@{
    ViewData["Title"] = "Add Website";
}

<div class="container mt-4" style="width: 75%;">
    <div class="d-flex align-items-center gap-2 mb-4">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">&larr;</a>
        <h4 class="mb-0 fw-semibold">Add Website</h4>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="WebsiteName" class="form-label fw-semibold"></label>
                        <input asp-for="WebsiteName" class="form-control" placeholder="e.g. Al-Ahram" />
                        <span asp-validation-for="WebsiteName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="URL" class="form-label fw-semibold"></label>
                        <input asp-for="URL" class="form-control" placeholder="https://example.com" />
                        <span asp-validation-for="URL" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Frequency" class="form-label fw-semibold"></label>
                        <select asp-for="Frequency" class="form-select">
                            <option value="">-- Select Frequency --</option>
                            <option value="Daily">Daily</option>
                            <option value="Weekly">Weekly</option>
                            <option value="Monthly">Monthly</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="MediaTier" class="form-label fw-semibold"></label>
                        <select asp-for="MediaTier" class="form-select">
                            <option value="">-- Select Tier --</option>
                            <option value="A">A</option>
                            <option value="B">B</option>
                            <option value="C">C</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Reach" class="form-label fw-semibold"></label>
                        <input asp-for="Reach" class="form-control" placeholder="Enter Website reach" />
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Distribution" class="form-label fw-semibold"></label>
                        <select asp-for="Distribution" class="form-select">
                            <option value="">-- Select Distribution --</option>
                            <option value="National">National</option>
                            <option value="Independent">Independent</option>
                            <option value="Party">Party</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Language" class="form-label fw-semibold"></label>
                        <select asp-for="Language" class="form-select">
                            <option value="">-- Select Language --</option>
                            <option value="Arabic">Arabic</option>
                            <option value="English">English</option>
                            <option value="French">French</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="UnitPrice" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="UnitPrice" class="form-control" type="number" step="0.01" min="0" />
                        </div>
                        <span asp-validation-for="UnitPrice" class="text-danger small"></span>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-success px-4">Save</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

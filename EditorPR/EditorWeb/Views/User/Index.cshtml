@model IEnumerable<EditorViewModelLayer.AuthViewModels.UserDTO>
@{
    ViewData["Title"] = "User Management";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0 fw-semibold">User Management</h4>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary btn-sm">+ Add User</a>
        }
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0 align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Full Name</th>
                        <th>Username</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">No users found.</td>
                        </tr>
                    }
                    @foreach (var u in Model)
                    {
                        <tr class="@(!u.IsActive ? "table-secondary text-muted" : "")">
                            <td>@u.Id</td>
                            <td class="fw-semibold">@u.FullName</td>
                            <td>@u.Username</td>
                            <td>@u.Email</td>
                            <td>
                                <span class="badge bg-info text-dark">@u.Role</span>
                            </td>
                            <td>
                                @if (u.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inactive</span>
                                }
                            </td>
                            <td class="small text-muted">@u.CreatedAt.ToString("dd MMM yyyy")</td>
                            <td>
                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-action="Edit" asp-route-id="@u.Id"
                                       class="btn btn-sm btn-outline-warning me-1">Edit</a>

                                    <a asp-action="AdminChangePassword" asp-route-id="@u.Id"
                                       class="btn btn-sm btn-outline-secondary me-1">Password</a>

                                    <form asp-action="ToggleActive" method="post" class="d-inline"
                                          onsubmit="return confirm('@(u.IsActive ? "Deactivate" : "Activate") this user?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@u.Id" />
                                        <button type="submit"
                                                class="btn btn-sm @(u.IsActive ? "btn-outline-danger" : "btn-outline-success")">
                                            @(u.IsActive ? "Deactivate" : "Activate")
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- My Password shortcut -->
    <div class="mt-3">
        <a asp-action="ChangeMyPassword" class="btn btn-sm btn-outline-primary">
            🔒 Change My Password
        </a>
    </div>
</div>

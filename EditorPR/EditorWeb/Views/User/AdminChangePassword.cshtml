@model EditorViewModelLayer.AuthViewModels.AdminChangePasswordViewModel
@{
    ViewData["Title"] = "Reset User Password";
}

<div class="container mt-4" style="max-width: 480px;">
    <div class="d-flex align-items-center gap-2 mb-4">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">&larr;</a>
        <h4 class="mb-0 fw-semibold">Reset User Password</h4>
    </div>

    <div class="card shadow-sm border-warning">
        <div class="card-header bg-warning text-dark fw-semibold">
            Resetting password for: <strong>@Model.UserName</strong>
        </div>
        <div class="card-body">
            <form asp-action="AdminChangePassword" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="UserId"   type="hidden" />
                <input asp-for="UserName" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="mb-3">
                    <label asp-for="NewPassword" class="form-label fw-semibold"></label>
                    <input asp-for="NewPassword" class="form-control" type="password"
                           autocomplete="new-password" />
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ConfirmNewPassword" class="form-label fw-semibold"></label>
                    <input asp-for="ConfirmNewPassword" class="form-control" type="password"
                           autocomplete="new-password" />
                    <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2 mt-3">
                    <button type="submit" class="btn btn-warning px-4">Reset Password</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

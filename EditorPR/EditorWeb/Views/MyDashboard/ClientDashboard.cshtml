@model EditorViewModelLayer.ClientViewModel.ClientDashboardDTO
@{
    ViewData["Title"] = "My Dashboard";
    Layout = "~/Views/Shared/_ClientLayout.cshtml";
}
@await Html.PartialAsync("_ClientStyles")
<div class="container-fluid dashboard-wrapper">

    <div class="dashboard-header mb-4">
        <div class="d-flex align-items-center gap-3">
            @if (!string.IsNullOrWhiteSpace(Model.Photo))
            {
                <img src="@Model.Photo" class="rounded-circle"
                     width="56" height="56" style="object-fit:cover;" />
            }
            <div>
                <h4 class="mb-0">@Model.Name</h4>
                <small class="text-white">@Model.Email</small>
            </div>
        </div>
    </div>

 
    <form method="get" class="row g-2 mb-4">
        <div class="col-auto">
            <label class="form-label mb-0">From</label>
            <input type="date" name="dateFrom" class="form-control form-control-sm"
                   value="@ViewBag.DateFrom" />
        </div>
        <div class="col-auto">
            <label class="form-label mb-0">To</label>
            <input type="date" name="dateTo" class="form-control form-control-sm"
                   value="@ViewBag.DateTo" />
        </div>
        <div class="col-auto align-self-end">
            <button type="submit" class="btn btn-primary btn-sm">Filter</button>
            <a href="@Url.Action("Index")" class="btn btn-secondary btn-sm">Reset</a>
        </div>
    </form>

 
    <div class="row g-4 stats-grid">
        <div class="col-lg-4 col-md-6">
            <div class="dashboard-card articles-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="metric-title">Articles (Website)</div>
                        <div class="metric-number">@Model.ArticleCount.ToString("N0")</div>
                    </div>
                    <div class="card-icon icon-primary">
                        <i class="bi bi-newspaper"></i>
                    </div>
                </div>

                <div class="metric-details">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="metric-label">Total AD Value</span>
                        <strong>@Model.ArticleTotalAD.ToString("N2")</strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <div class="metric-label">Total PR Value</div>
                        <div class="metric-value">@Model.ArticleTotalPR.ToString("N2")</div>
                    </div>
                    <i class="bi bi-graph-up-arrow text-success fs-4"></i>
                </div>
                <a asp-action="ClientArticle"
                   asp-controller="MyDashboard"
                   class="btn btn-primary w-100 dashboard-btn">
                    Open Website
                </a>
            </div>
        </div>

        <div class="col-lg-4 col-md-6">
            <div class="dashboard-card publications-card">

                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="metric-title">Publications (Print)</div>
                        <div class="metric-number">@Model.NewsPaperCount.ToString("N0")</div>
                    </div>

                    <div class="card-icon icon-warning">
                        <i class="bi bi-journal-richtext"></i>
                    </div>
                </div>

                <div class="metric-details ">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="metric-label">Total AD Value</span>
                        <strong>@Model.NewsPaperTotalAD.ToString("N2")</strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <div class="metric-label">Total PR Value</div>
                        <div class="metric-value">@Model.NewsPaperTotalPR.ToString("N2")</div>
                    </div>

                    <i class="bi bi-bar-chart-line text-warning fs-4"></i>
                </div>

                <a asp-action="ClientNewsPaper"
                   asp-controller="MyDashboard"
                   class="btn btn-warning w-100 dashboard-btn text-dark">
                    Open Publications
                </a>

            </div>
        </div>

        <div class="col-lg-4 col-md-6">
            <div class="dashboard-card videos-card">

                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="metric-title">Videos (TV / Channels)</div>
                        <div class="metric-number">@Model.VideoCount.ToString("N0")</div>
                    </div>

                    <div class="card-icon icon-danger">
                        <i class="bi bi-play-circle-fill"></i>
                    </div>
                </div>

                <div class="metric-details">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="metric-label">Total AD Value</span>
                        <strong>@Model.VideoTotalAD.ToString("N2")</strong>
                    </div>

                    <div class="d-flex justify-content-between">
                        <span class="metric-label">Total PR Value</span>
                        <strong class="text-success">@Model.VideoTotalPR.ToString("N2")</strong>
                    </div>
                </div>

                <a asp-action="ClientVideo"
                   asp-controller="MyDashboard"
                   class="btn btn-danger w-100 dashboard-btn">
                    Open Videos
                </a>

            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Notes))
{
    <div class="alert alert-light border">
        <strong>Notes:</strong> @Model.Notes
    </div>
}

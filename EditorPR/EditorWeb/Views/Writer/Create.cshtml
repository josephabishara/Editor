@model EditorViewModelLayer.WriterViewModel.WriterDTO
@{
    ViewData["Title"] = "Add Writer";
}

<div class="container mt-4" style="max-width: 680px;">
    <div class="d-flex align-items-center gap-2 mb-4">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">&larr;</a>
        <h4 class="mb-0 fw-semibold">Add Writer</h4>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="WriterName" class="form-label fw-semibold"></label>
                        <input asp-for="WriterName" class="form-control" placeholder="e.g. Al-Ahram" />
                        <span asp-validation-for="WriterName" class="text-danger small"></span>
                    </div>

                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-success px-4">Save</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

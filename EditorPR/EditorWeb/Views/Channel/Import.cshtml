@{
    ViewData["Title"] = "Import Channels from Excel";
}

<div class="container mt-4" style="max-width: 640px;">
    <div class="d-flex align-items-center gap-2 mb-4">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">&larr;</a>
        <h4 class="mb-0 fw-semibold">Import Channels from Excel</h4>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm mb-3">
        <div class="card-header fw-semibold bg-light">Upload Excel File</div>
        <div class="card-body">
            <form asp-action="Import" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label">
                        Select File <span class="text-danger">*</span>
                    </label>
                    @* ✅ name="file" matches controller parameter: Import(IFormFile? file) *@
                    <input type="file"
                           name="file"
                           class="form-control"
                           accept=".xlsx,.xls"
                           required />
                    <div class="form-text">Accepted: .xlsx, .xls</div>
                    <span class="text-danger small">
                        @Html.ValidationMessage("file")
                    </span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success px-4">Import</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-info">
        <div class="card-body">
            <h6 class="fw-semibold mb-3">Expected Column Structure</h6>
            <div class="table-responsive mb-3">
                <table class="table table-sm table-bordered text-center mb-0">
                    <thead class="table-primary">
                        <tr>
                            <th>A</th><th>B</th><th>C</th><th>D</th>
                            <th>E</th><th>F</th><th>G</th><th>H</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="small text-muted">
                            <td>Id<br/><span class="text-secondary">(ignored)</span></td>
                            <td>Channel Name<br/><span class="text-danger">*</span></td>
                            <td>Media Tier</td>
                            <td>Reach</td>
                            <td>Distribution</td>
                            <td>Language</td>
                            <td>Unit Price</td>
                            <td>Unit Currency</td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <p class="small text-muted mb-3">
                <span class="text-danger">*</span> Required.
                Row 1 is the header — data starts from Row 2.
                The <strong>Id</strong> column is ignored on import.
            </p>
            <a asp-action="DownloadTemplate" class="btn btn-sm btn-outline-primary">
                ⬇ Download Blank Template
            </a>
        </div>
    </div>
</div>

@* ─── Details.cshtml ─────────────────────────────────────────────────────── *@
@model EditorViewModelLayer.GeneralNewspaperViewModel.GeneralNewspaperDTO
@{
    ViewData["Title"] = "Newspaper Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4><i class="bi bi-eye me-2"></i>Newspaper Details</h4>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#shareModal">
            <i class="bi bi-share me-1"></i> Share to Clients
        </button>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-pencil me-1"></i> Edit
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i> Back
        </a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">

        <div class="row g-3">
            <div class="col-md-3">
                <p class="text-muted mb-0 small">Date</p>
                <strong>@Model.Date.ToString("dd MMM yyyy")</strong>
            </div>
            <div class="col-md-3">
                <p class="text-muted mb-0 small">Publication</p>
                <strong>@Model.PublicationName</strong>
            </div>
            <div class="col-md-3">
                <p class="text-muted mb-0 small">Writer</p>
                <strong>@Model.WriterName</strong>
            </div>
            <div class="col-md-3">
                <p class="text-muted mb-0 small">Toning</p>
                <strong>@(Model.Toning ?? "—")</strong>
            </div>

            <div class="col-md-12">
                <p class="text-muted mb-0 small">Title</p>
                <strong>@Model.Title</strong>
            </div>

            <div class="col-md-3">
                <p class="text-muted mb-0 small">Pages</p>
                <strong>@Model.Pages</strong>
            </div>
            <div class="col-md-3">
                <p class="text-muted mb-0 small">Height (cm)</p>
                <strong>@Model.Height</strong>
            </div>
            <div class="col-md-3">
                <p class="text-muted mb-0 small">Width (cm)</p>
                <strong>@Model.Width</strong>
            </div>
            <div class="col-md-3">
                <p class="text-muted mb-0 small">Picture in Article</p>
                <strong>@(Model.PictureinArticle ?? "—")</strong>
            </div>

            <div class="col-md-3">
                <p class="text-muted mb-0 small">Article Branding</p>
                <span class="badge bg-secondary">@(Model.ArticleBranding ?? "—")</span>
            </div>
            <div class="col-md-3">
                <p class="text-muted mb-0 small">Headline Branding</p>
                <span class="badge bg-secondary">@(Model.HeadlineBranding ?? "—")</span>
            </div>
            <div class="col-md-3">
                <p class="text-muted mb-0 small">AI Generated</p>
                @if (Model.Generation == true)
                {
                    <span class="badge bg-info text-dark">Yes</span>
                }
                else
                {
                    <span class="badge bg-light text-dark border">No</span>
                }
            </div>

            @if (!string.IsNullOrEmpty(Model.Content))
            {
                <div class="col-md-12">
                    <p class="text-muted mb-1 small">Content</p>
                    <div class="border rounded p-3 bg-light">
                        @Html.Raw(Model.Content)
                    </div>
                </div>
            }
        </div>

    </div>
</div>

@* ── Share to Clients modal ───────────────────────────────────────────────── *@
<div class="modal fade" id="shareModal" tabindex="-1" aria-labelledby="shareModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form id="shareForm" asp-action="ShareToClients" asp-controller="GeneralNewspaper" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="GeneralNewspaperId" value="@Model.Id" />

                <div class="modal-header">
                    <h5 class="modal-title" id="shareModalLabel">
                        <i class="bi bi-share me-1"></i> Share "@Model.Title" to Clients
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    <p class="text-muted small mb-3">
                        Select one or more clients. For each client you check, choose a Category
                        and Sub Category (categories are specific to each client).
                    </p>

                    <div id="shareClientsLoading" class="text-center text-muted py-3">
                        <i class="bi bi-arrow-repeat"></i> Loading clients…
                    </div>

                    <div id="shareClientsList" class="d-none"></div>

                    <div id="shareError" class="alert alert-danger d-none mt-2 mb-0 py-2 small"></div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success" id="btnShareSubmit">
                        <i class="bi bi-send me-1"></i> Share
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const modalEl       = document.getElementById('shareModal');
            const loadingEl     = document.getElementById('shareClientsLoading');
            const listEl        = document.getElementById('shareClientsList');
            const errorEl       = document.getElementById('shareError');
            const form          = document.getElementById('shareForm');
            const btnSubmit     = document.getElementById('btnShareSubmit');
            const generalId     = @Model.Id;

            let loaded = false;

            modalEl.addEventListener('show.bs.modal', function () {
                errorEl.classList.add('d-none');
                if (loaded) return;   // only fetch the client list once per page load

                fetch('@Url.Action("GetShareClients", "GeneralNewspaper")?id=' + generalId)
                    .then(r => r.json())
                    .then(clients => {
                        renderClients(clients);
                        loaded = true;
                        loadingEl.classList.add('d-none');
                        listEl.classList.remove('d-none');
                    })
                    .catch(() => {
                        loadingEl.textContent = 'Failed to load clients.';
                    });
            });

            function renderClients(clients) {
                listEl.innerHTML = '';

                clients.forEach((c, idx) => {
                    const row = document.createElement('div');
                    row.className = 'border rounded p-2 mb-2';
                    row.innerHTML = `
                        <div class="form-check">
                            <input class="form-check-input client-check" type="checkbox"
                                   id="client_${c.clientId}" value="${c.clientId}"
                                   ${c.alreadyShared ? 'disabled' : ''}>
                            <label class="form-check-label fw-semibold" for="client_${c.clientId}">
                                ${c.clientName}
                                ${c.alreadyShared ? '<span class="badge bg-secondary ms-2">Already shared</span>' : ''}
                            </label>
                        </div>
                        <div class="row g-2 mt-1 d-none category-row" data-client-id="${c.clientId}">
                            <div class="col-md-6">
                                <select class="form-select form-select-sm category-select" disabled>
                                    <option value="">Loading categories…</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <select class="form-select form-select-sm subcategory-select" disabled>
                                    <option value="">— Select category first —</option>
                                </select>
                            </div>
                        </div>`;
                    listEl.appendChild(row);

                    const checkbox  = row.querySelector('.client-check');
                    const catRow    = row.querySelector('.category-row');
                    const catSelect = row.querySelector('.category-select');
                    const subSelect = row.querySelector('.subcategory-select');

                    checkbox.addEventListener('change', function () {
                        if (this.checked) {
                            catRow.classList.remove('d-none');
                            loadCategories(c.clientId, catSelect);
                        } else {
                            catRow.classList.add('d-none');
                        }
                    });

                    catSelect.addEventListener('change', function () {
                        loadSubCategories(this.value, subSelect);
                    });
                });
            }

            function loadCategories(clientId, selectEl) {
                selectEl.disabled = true;
                selectEl.innerHTML = '<option value="">Loading…</option>';

                fetch('@Url.Action("GetShareCategories", "GeneralNewspaper")?clientId=' + clientId)
                    .then(r => r.json())
                    .then(opts => {
                        selectEl.innerHTML = '<option value="">— Select Category —</option>' +
                            opts.map(o => `<option value="${o.value}">${o.text}</option>`).join('');
                        selectEl.disabled = false;
                    })
                    .catch(() => {
                        selectEl.innerHTML = '<option value="">Failed to load</option>';
                    });
            }

            function loadSubCategories(categoryId, selectEl) {
                if (!categoryId) {
                    selectEl.innerHTML = '<option value="">— Select category first —</option>';
                    selectEl.disabled = true;
                    return;
                }

                selectEl.disabled = true;
                selectEl.innerHTML = '<option value="">Loading…</option>';

                fetch('@Url.Action("GetShareSubCategories", "GeneralNewspaper")?parentId=' + categoryId)
                    .then(r => r.json())
                    .then(opts => {
                        selectEl.innerHTML = '<option value="">— None —</option>' +
                            opts.map(o => `<option value="${o.value}">${o.text}</option>`).join('');
                        selectEl.disabled = false;
                    })
                    .catch(() => {
                        selectEl.innerHTML = '<option value="">Failed to load</option>';
                    });
            }

            // ── Build Clients[i].* hidden inputs from checked rows before submit ──
            form.addEventListener('submit', function (e) {
                // Strip any hidden inputs from a previous (failed) attempt
                form.querySelectorAll('.dynamic-client-input').forEach(el => el.remove());

                const checked = listEl.querySelectorAll('.client-check:checked');

                if (checked.length === 0) {
                    e.preventDefault();
                    errorEl.textContent = 'Please select at least one client.';
                    errorEl.classList.remove('d-none');
                    return;
                }

                let valid = true;
                let i = 0;

                checked.forEach(cb => {
                    const row        = cb.closest('.border');
                    const catSelect  = row.querySelector('.category-select');
                    const subSelect  = row.querySelector('.subcategory-select');

                    if (!catSelect.value) {
                        valid = false;
                        catSelect.classList.add('is-invalid');
                        return;
                    }
                    catSelect.classList.remove('is-invalid');

                    appendHidden(`Clients[${i}].ClientId`, cb.value);
                    appendHidden(`Clients[${i}].CategoryId`, catSelect.value);
                    appendHidden(`Clients[${i}].SubCategoryId`, subSelect.value || '0');
                    i++;
                });

                if (!valid) {
                    e.preventDefault();
                    errorEl.textContent = 'Please choose a Category for every selected client.';
                    errorEl.classList.remove('d-none');
                    form.querySelectorAll('.dynamic-client-input').forEach(el => el.remove());
                    return;
                }

                btnSubmit.disabled = true;
                btnSubmit.innerHTML = 'Sharing…';
            });

            function appendHidden(name, value) {
                const input = document.createElement('input');
                input.type = 'hidden';
                input.className = 'dynamic-client-input';
                input.name = name;
                input.value = value;
                form.appendChild(input);
            }
        })();
    </script>
}

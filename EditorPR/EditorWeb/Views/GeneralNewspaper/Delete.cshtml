@* ─── Delete.cshtml ──────────────────────────────────────────────────────── *@
@model EditorViewModelLayer.GeneralNewspaperViewModel.GeneralNewspaperDTO
@{
    ViewData["Title"] = "Delete Newspaper";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="text-danger"><i class="bi bi-exclamation-triangle me-2"></i>Delete Newspaper</h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Back
    </a>
</div>

<div class="alert alert-warning">
    Are you sure you want to delete this newspaper? This action cannot be undone.
</div>

<div class="card shadow-sm border-danger">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-3">
                <p class="text-muted mb-0 small">Date</p>
                <strong>@Model.Date.ToString("dd MMM yyyy")</strong>
            </div>
            <div class="col-md-3">
                <p class="text-muted mb-0 small">Publication</p>
                <strong>@Model.PublicationName</strong>
            </div>
            <div class="col-md-3">
                <p class="text-muted mb-0 small">Writer</p>
                <strong>@Model.WriterName</strong>
            </div>
            <div class="col-md-3">
                <p class="text-muted mb-0 small">Pages</p>
                <strong>@Model.Pages</strong>
            </div>
            <div class="col-md-12">
                <p class="text-muted mb-0 small">Title</p>
                <strong>@Model.Title</strong>
            </div>
        </div>

        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="mt-4">
            @Html.AntiForgeryToken()
            <div class="d-flex justify-content-end gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash me-1"></i> Confirm Delete
                </button>
            </div>
        </form>
    </div>
</div>

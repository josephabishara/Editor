@model EditorViewModelLayer.GeneralNewspaperViewModel.GeneralNewspaperIndexVM
@{
    ViewData["Title"] = "General Newspapers";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/select2/4.1.0-rc.0/css/select2.min.css" />
<style>
    /* Match Bootstrap form-control-sm height inside Select2 */
    .select2-container--default .select2-selection--single {
        height: 31px;
        border: 1px solid #ced4da;
    }
    .select2-container--default .select2-selection--single .select2-selection__rendered {
        line-height: 29px;
        font-size: .875rem;
    }
    .select2-container--default .select2-selection--single .select2-selection__arrow {
        height: 29px;
    }
</style>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h4 class="mb-0">
        <i class="bi bi-newspaper me-2"></i>General Newspapers
    </h4>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-circle me-1"></i> New Newspaper
        </a>
        <a asp-action="Import" class="btn btn-success btn-sm">
            <i class="bi bi-upload me-1"></i> Import Excel
        </a>
        <a asp-action="DownloadTemplate" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-download me-1"></i> Template
        </a>
        <a id="btnExportAll"
           asp-action="ExportToExcel"
           asp-route-FromDate="@Model.Filter.FromDate?.ToString("yyyy-MM-dd")"
           asp-route-ToDate="@Model.Filter.ToDate?.ToString("yyyy-MM-dd")"
           asp-route-Title="@Model.Filter.Title"
           asp-route-PublicationId="@Model.Filter.PublicationId"
           class="btn btn-outline-success btn-sm">
            <i class="bi bi-file-earmark-excel me-1"></i> Export All
        </a>
        <button type="button" class="btn btn-warning btn-sm" id="btnExportSelected">
            <i class="bi bi-check2-square me-1"></i> Export Selected
        </button>
    </div>
</div>

@* ── Filter Bar ─────────────────────────────────────────────────────────── *@
<div class="card shadow-sm mb-3">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-2 align-items-end">
            <div class="col-md-2">
                <label asp-for="Filter.FromDate" class="form-label small mb-1">From Date</label>
                <input asp-for="Filter.FromDate" type="date" class="form-control form-control-sm" />
            </div>
            <div class="col-md-2">
                <label asp-for="Filter.ToDate" class="form-label small mb-1">To Date</label>
                <input asp-for="Filter.ToDate" type="date" class="form-control form-control-sm" />
            </div>
            <div class="col-md-3">
                <label asp-for="Filter.Title" class="form-label small mb-1">Title</label>
                <input asp-for="Filter.Title" type="text" class="form-control form-control-sm" placeholder="Search by title..." />
            </div>
            <div class="col-md-3">
                <label asp-for="Filter.PublicationId" class="form-label small mb-1">Publication</label>
                <select asp-for="Filter.PublicationId" id="publicationFilterSelect" class="form-select form-select-sm">
                    <option value="">-- All Publications --</option>
                    @foreach (var p in Model.Publications)
                    {
                        <option value="@p.Value" selected="@p.Selected">@p.Text</option>
                    }
                </select>
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary btn-sm w-100">
                    <i class="bi bi-search me-1"></i> Filter
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm w-100">
                    <i class="bi bi-x-circle me-1"></i> Clear
                </a>
            </div>
        </form>
    </div>
</div>

@* {{-- Export Selected hidden form --}} *@
<form id="exportSelectedForm"
      asp-action="ExportSelected"
      asp-controller="GeneralNewspaper"
      method="post"
      style="display:none">
    @Html.AntiForgeryToken()
    <input type="hidden" id="selectedIdsInput" name="selectedIds" />
</form>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-bordered mb-0 align-middle" id="newspapersTable">
                <thead class="table-dark">
                    <tr>
                        <th style="width:40px">
                            <input type="checkbox" id="selectAll" title="Select All" />
                        </th>
                        <th>#</th>
                        <th>Date</th>
                        <th>Title</th>
                        <th>Publication</th>
                        <th>Writer</th>
                        <th>Pages</th>
                        <th>Size (cm)</th>
                        <th>Branding</th>
                        <th>Generated</th>
                        <th style="width:130px">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>
                                <input type="checkbox" class="row-check" value="@item.Id" />
                            </td>
                            <td>@item.Id</td>
                            <td>@item.Date.ToString("dd MMM yyyy")</td>
                            <td>@item.Title</td>
                            <td>@item.PublicationName</td>
                            <td>@item.WriterName</td>
                            <td>@item.Pages</td>
                            <td>@item.Height x @item.Width</td>
                            <td>
                                <span class="badge bg-secondary">@item.ArticleBranding</span>
                            </td>
                            <td>
                                @if (item.Generation == true)
                                {
                                    <span class="badge bg-info text-dark">AI</span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-dark">Manual</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a asp-action="Details" asp-route-id="@item.Id"
                                       class="btn btn-outline-info btn-sm" title="Details">
                                        <i class="fa fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.Id"
                                       class="btn btn-outline-primary btn-sm" title="Edit">
                                        <i class="fa fa-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id"
                                       class="btn btn-outline-danger btn-sm" title="Delete">
                                        <i class="fa fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Items.Any())
                    {
                        <tr>
                            <td colspan="10" class="text-center text-muted py-4">
                                No newspapers found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.1.0-rc.0/js/select2.min.js"></script>
    <script>
        $(function () {
            $('#publicationFilterSelect').select2({
                placeholder: '-- All Publications --',
                allowClear: true,
                width: '100%'
            });
        });

        // Select All toggle
        document.getElementById('selectAll').addEventListener('change', function () {
            document.querySelectorAll('.row-check')
                    .forEach(cb => cb.checked = this.checked);
        });

        // Export Selected
        document.getElementById('btnExportSelected').addEventListener('click', function () {
            const checked = [...document.querySelectorAll('.row-check:checked')]
                                .map(cb => cb.value);
            if (checked.length === 0) {
                alert('Please select at least one newspaper to export.');
                return;
            }
            document.getElementById('selectedIdsInput').value = checked.join(',');
            document.getElementById('exportSelectedForm').submit();
        });
    </script>
}

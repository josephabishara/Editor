@model EditorViewModelLayer.ClientViewModel.ClientDTO
@{
    ViewData["Title"] = "Change Client Photo";
    var currentPhoto = string.IsNullOrEmpty(Model.Photo)
        ? "/uploads/clients/default-company.png"
        : Model.Photo;
}

<div class="container mt-4" style="max-width: 500px;">
    <div class="d-flex align-items-center gap-2 mb-4">
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-secondary">&larr;</a>
        <h4 class="mb-0 fw-semibold">Change Photo</h4>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            
            @* Current / preview photo *@
            <div class="text-center mb-4">
                <img id="photoPreview"
                     src="@currentPhoto"
                     class="rounded-circle border shadow-sm"
                     style="width:120px;height:120px;object-fit:cover;"
                     alt="@Model.Name" />
                <div class="mt-2 text-muted small">
                    @Model.Name
                </div>
            </div>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">@TempData["Error"]</div>
            }

            <form asp-action="ChangePhoto"
                  asp-controller="Client"
                  asp-route-id="@Model.Id"
                  method="post"
                  enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                
                <div class="mb-3">
                    <label class="form-label fw-semibold">Select New Photo</label>
               
                    <input type="file"
                           name="photoFile"
                           class="form-control"
                           onchange="previewPhoto(this)"
                           required />
                    <div class="form-text">JPG, PNG, WebP — max 2 MB</div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">Upload Photo</button>
                    <a asp-action="Details" asp-route-id="@Model.Id"
                       class="btn btn-outline-secondary">Cancel</a>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function previewPhoto(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => document.getElementById('photoPreview').src = e.target.result;
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}
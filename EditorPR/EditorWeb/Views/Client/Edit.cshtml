@model EditorViewModelLayer.ClientViewModel.ClientDTO
@{
    ViewData["Title"] = "Edit Client";
}

<div class="container mt-4" style="max-width: 720px;">
    <div class="d-flex align-items-center gap-2 mb-4">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">&larr;</a>
        <h4 class="mb-0 fw-semibold">Edit Client</h4>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />
                <input asp-for="ApplicationUserId" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Name" class="form-label fw-semibold"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Username" class="form-label fw-semibold"></label>
                        <input asp-for="Username" class="form-control" />
                        <span asp-validation-for="Username" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label fw-semibold"></label>
                        <input asp-for="Email" class="form-control" type="email" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Password" class="form-label fw-semibold">
                            New Password <small class="text-muted fw-normal">(leave blank to keep current)</small>
                        </label>
                        <input asp-for="Password" class="form-control" type="password"
                               placeholder="Leave blank to keep current password" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Contact" class="form-label fw-semibold"></label>
                        <input asp-for="Contact" class="form-control" />
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Status" class="form-label fw-semibold"></label>
                        <select asp-for="Status" class="form-select">
                            <option value="Active">Active</option>
                            <option value="Inactive">Inactive</option>
                            <option value="Suspended">Suspended</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Website" class="form-label fw-semibold"></label>
                        <input asp-for="Website" class="form-control" />
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Url" class="form-label fw-semibold"></label>
                        <input asp-for="Url" class="form-control" />
                        <span asp-validation-for="Url" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="ManagersLimitedNewsDays" class="form-label fw-semibold"></label>
                        <input asp-for="ManagersLimitedNewsDays" class="form-control" type="number" min="0" />
                    </div>

                    <div class="col-12">
                        <label asp-for="Notes" class="form-label fw-semibold"></label>
                        <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-warning px-4">Update Client</button>
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

@model IEnumerable<EditorViewModelLayer.ClientViewModel.ClientDTO>
@{
    ViewData["Title"] = "Clients";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-2">
            <h4 class="mb-0 fw-semibold">  <i class="fa fa-building"></i> Clients</h4>
        </div>
        <div class="col-6">
        </div>
        <div class="col-2">
            <a asp-action="Create" class="btn btn-primary btn-sm"><i class="fa fa-plus"></i> Add Client</a>

        </div>
        <div class="col-2">
            <a asp-action="All" class="btn btn-primary btn-sm"><i class="fa fa-dashboard"></i> Dashboard</a>

        </div>
    </div>

    <br />

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-primary">
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Username</th>
                        <th>Status</th>
                        <th>News/Day</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">No clients found.</td>
                        </tr>
                    }
                    @foreach (var c in Model)
                    {
                        <tr>
                            <td>@c.Id</td>
                            <td class="fw-semibold">@c.Name</td>
                            <td>@c.Email</td>
                            <td>@c.Username</td>
                            <td>
                                <span class="badge @(c.Status == "Active" ? "bg-success" : "bg-secondary")">
                                    @c.Status
                                </span>
                            </td>
                            <td>@c.ManagersLimitedNewsDays</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@c.Id"
                                   class="btn btn-sm btn-outline-info me-1"><i class="fa fa-eye"></i></a>
                                <a asp-action="Edit" asp-route-id="@c.Id"
                                   class="btn btn-sm btn-outline-success me-1"><i class="fa fa-edit"></i></a>
                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-action="Delete" asp-route-id="@c.Id"
                                       class="btn btn-sm btn-outline-dark"><i class="fa fa-trash"></i></a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

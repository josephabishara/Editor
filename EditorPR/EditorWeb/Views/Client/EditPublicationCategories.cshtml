@model EditorViewModelLayer.ClientViewModel.UpdateClientPublicationCategoriesDTO
@{
    ViewData["Title"] = "Edit Publication Categories";
    var clientName = ViewBag.ClientName as string ?? "Client";
}

<div class="container mt-4" style="max-width: 820px;">
    <div class="d-flex align-items-center gap-2 mb-4">
        <a asp-action="Details" asp-route-id="@Model.CustomerId"
           class="btn btn-sm btn-outline-secondary">&larr;</a>
        
        <div>
            <h4 class="mb-0 fw-semibold">Publication Media Tiers</h4>
            <small class="text-muted">Client: <strong>@clientName</strong></small>
        </div>
        <a asp-action="ImportPublicationCategories" asp-route-id="@Model.CustomerId" class="btn btn-outline-success px-4">
            <i class="bi bi-upload me-1"></i> Import Excel
        </a>
    </div>
   

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }


    <div class="card shadow-sm">
        <div class="card-body p-0">
            <form asp-action="EditPublicationCategories" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" name="CustomerId" value="@Model.CustomerId" />
               
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th style="width:40px;">#</th>
                            <th>Publication</th>
                            <th>Price</th>
                            <th style="width:160px;">Media Tier</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Categories.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">
                                    No publications found. Add publications first.
                                </td>
                            </tr>
                        }

                        @for (int i = 0; i < Model.Categories.Count; i++)
                        {
                            var cat = Model.Categories[i];

                            <input type="hidden" name="Categories[@i].Id" value="@cat.Id" />
                            <input type="hidden" name="Categories[@i].CustomerId" value="@cat.CustomerId" />
                            <input type="hidden" name="Categories[@i].PublicationId" value="@cat.PublicationId" />
                            <input type="hidden" name="Categories[@i].PublicationName" value="@cat.PublicationName" />
                            <input type="hidden" name="Categories[@i].UnitPrice" value="@cat.UnitPrice" />

                            <tr>
                                <td class="text-muted small">@(i + 1)</td>
                                <td class="fw-semibold">@cat.PublicationName</td>
                                <td class="fw-semibold">@cat.UnitPrice</td>
                                
                                <td>
                                    <select name="Categories[@i].MediaTier" class="form-select form-select-sm">
                                        <option value="">-- None --</option>
                                        <option value="A" selected="@(cat.MediaTier == "A" ? "selected" : null)">A</option>
                                        <option value="B" selected="@(cat.MediaTier == "B" ? "selected" : null)">B</option>
                                        <option value="C" selected="@(cat.MediaTier == "C" ? "selected" : null)">C</option>
                                    </select>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                @if (Model.Categories.Any())
                {
                    <div class="p-3 border-top d-flex gap-2">
                        <button type="submit" class="btn btn-success px-4">Save Changes</button>
                        <a asp-action="Details" asp-route-id="@Model.CustomerId"
                           class="btn btn-outline-secondary">Cancel</a>
                      
                    </div>
                }
            </form>
        </div>
    </div>
</div>

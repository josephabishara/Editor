@model EditorViewModelLayer.ClientViewModel.ClientDTO
@{
    ViewData["Title"] = "Add Client";
}

<div class="container mt-4" style="max-width: 720px;">
    <div class="d-flex align-items-center gap-2 mb-4">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">&larr;</a>
        <h4 class="mb-0 fw-semibold">Add Client</h4>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label fw-semibold">Profile Photo <span class="text-muted fw-normal small">(optional)</span></label>
                        <div class="d-flex align-items-center gap-3">
                            <img id="photoPreview"
                                 src="/uploads/clients/default-company.png"
                                 class="rounded-circle border"
                                 style="width:80px;height:80px;object-fit:cover;"
                                 alt="Preview" />
                            <div>
                                <input asp-for="PhotoFile"
                                       type="file"
                                       class="form-control"
                                       accept="image/*"
                                       onchange="previewPhoto(this)" />
                                <div class="form-text">JPG, PNG, WebP — max 2 MB</div>
                                <span asp-validation-for="PhotoFile" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>
                 
                    <div class="col-md-6">
                        <label asp-for="Name" class="form-label fw-semibold"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Username" class="form-label fw-semibold"></label>
                        <input asp-for="Username" class="form-control"  type="text" />
                        <span asp-validation-for="Username" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label fw-semibold"></label>
                        <input asp-for="Email" class="form-control" type="email" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Password" class="form-label fw-semibold">
                            Password <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Password" class="form-control" type="password" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Contact" class="form-label fw-semibold"></label>
                        <input asp-for="Contact" class="form-control" />
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Status" class="form-label fw-semibold"></label>
                        <select asp-for="Status" class="form-select">
                            <option value="Active">Active</option>
                            <option value="Inactive">Inactive</option>
                            <option value="Suspended">Suspended</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Website" class="form-label fw-semibold"></label>
                        <input asp-for="Website" class="form-control" placeholder="https://..." />
                    </div>

                  

                    <div class="col-md-6">
                        <label asp-for="ManagersLimitedNewsDays" class="form-label fw-semibold"></label>
                        <input asp-for="ManagersLimitedNewsDays" class="form-control" type="number" min="0" />
                        <span asp-validation-for="ManagersLimitedNewsDays" class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Notes" class="form-label fw-semibold"></label>
                        <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-success px-4">Save Client</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function previewPhoto(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => document.getElementById('photoPreview').src = e.target.result;
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}

@model IEnumerable<EditorViewModelLayer.ReportViewModel.ReportDTO>
@using EditorEntitiesLayer.Entities

@{
    ViewData["Title"] = "Reports";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="bi bi-file-earmark-text me-2"></i>Reports</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i> New Report
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover table-striped mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Report Name</th>
                    <th>Customer</th>
                    <th>Date</th>
                    <th>Type</th>
                    <th>Articles</th>
                    <th>Newspapers</th>
                    <th>Status</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td>@r.Id</td>
                        <td>@r.ReportName</td>
                        <td>@r.CustomerName</td>
                        <td>@r.ReportDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            @{
                                var typeClass = r.ReportType switch
                                {
                                    ReportType.Daily => "bg-info",
                                    ReportType.Weekly => "bg-primary",
                                    ReportType.Monthly => "bg-warning text-dark",
                                    _ => "bg-secondary"
                                };
                            }
                            <span class="badge @typeClass">@r.ReportType</span>
                        </td>
                        <td><span class="badge bg-secondary">@r.ArticleCount</span></td>
                        <td><span class="badge bg-secondary">@r.NewspaperCount</span></td>
                        <td>
                            @if (r.Publish)
                            {
                                <span class="badge bg-success">Published</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Draft</span>
                            }
                        </td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@r.Id"
                               class="btn btn-sm btn-outline-info" title="Details">
                                <i class="fa fa-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@r.Id"
                               class="btn btn-sm btn-outline-primary" title="Edit">
                                <i class="fa fa-pencil"></i>
                            </a>

                            @if (!r.Publish)
                            {
                                <form asp-action="Publish" asp-route-id="@r.Id"
                                      method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-success"
                                            title="Publish"
                                            onclick="return confirm('Publish this report?')">
                                        <i class="fa fa-check"></i>
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="UnPublish" asp-route-id="@r.Id"
                                      method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-warning"
                                            title="Unpublish"
                                            onclick="return confirm('Unpublish this report?')">
                                        <i class="fa fa-close"></i>
                                    </button>
                                </form>
                            }

                            <a asp-action="Delete" asp-route-id="@r.Id"
                               class="btn btn-sm btn-outline-danger" title="Delete">
                                <i class="fa fa-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="9" class="text-center text-muted py-4">No reports found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@model EditorViewModelLayer.ReportViewModel.ReportDTO

@{
    ViewData["Title"] = "Delete Report";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-danger shadow-sm">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0"><i class="bi bi-trash me-2"></i>Delete Report</h5>
            </div>
            <div class="card-body">
                <p class="mb-1">Are you sure you want to delete this report?</p>
                <ul class="list-unstyled mt-3">
                    <li><strong>Name:</strong> @Model.ReportName</li>
                    <li><strong>Customer:</strong> @Model.CustomerName</li>
                    <li><strong>Date:</strong> @Model.ReportDate.ToString("yyyy-MM-dd")</li>
                    <li><strong>Type:</strong> @Model.ReportType</li>
                </ul>
                <div class="alert alert-warning mt-3">
                    <i class="bi bi-exclamation-triangle me-1"></i>
                    This will also remove all linked articles and newspapers from this report.
                </div>
                <form asp-action="Delete" method="post">
                    @Html.AntiForgeryToken()
                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-x-circle me-1"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash me-1"></i> Confirm Delete
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

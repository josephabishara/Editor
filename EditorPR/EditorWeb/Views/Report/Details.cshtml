@model EditorViewModelLayer.ReportViewModel.ReportDetailsDTO
@using EditorEntitiesLayer.Entities

@{
    ViewData["Title"] = "Report Details";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">
        <i class="bi bi-file-earmark-text me-2"></i>@Model.ReportName
        @{
            var typeClass = Model.ReportType switch
            {
                ReportType.Daily   => "bg-info",
                ReportType.Weekly  => "bg-primary",
                ReportType.Monthly => "bg-warning text-dark",
                _                  => "bg-secondary"
            };
        }
        <span class="badge @typeClass ms-2">@Model.ReportType</span>
        @if (Model.Publish)
        {
            <span class="badge bg-success ms-1">Published</span>
        }
        else
        {
            <span class="badge bg-warning text-dark ms-1">Draft</span>
        }
    </h4>
    <div class="d-flex gap-2">
        <a asp-action="Preview" asp-route-id="@Model.Id"
           target="_blank"
           class="btn btn-outline-dark btn-sm">
            <i class="bi bi-eye me-1"></i> Preview
        </a>
        <a asp-action="Edit" asp-route-id="@Model.Id"
           class="btn btn-outline-primary btn-sm">
            <i class="bi bi-pencil me-1"></i> Edit
        </a>
        <a asp-action="SelectArticles" asp-route-id="@Model.Id"
           class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-newspaper me-1"></i> Articles
        </a>
        <a asp-action="SelectNewspapers" asp-route-id="@Model.Id"
           class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-journal-text me-1"></i> Newspapers
        </a>
        <a asp-action="Index" class="btn btn-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i> Back
        </a>
    </div>
</div>

<!-- ── Summary cards ─────────────────────────────────────────────────────────── -->
<div class="row g-3 mb-4">
    <div class="col-md-2">
        <div class="card text-center border-0 bg-light h-100">
            <div class="card-body py-3">
                <div class="text-muted small">Customer</div>
                <div class="fw-bold">@Model.CustomerName</div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card text-center border-0 bg-light h-100">
            <div class="card-body py-3">
                <div class="text-muted small">Report Date</div>
                <div class="fw-bold">@Model.ReportDate.ToString("yyyy-MM-dd")</div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card text-center border-0 bg-light h-100">
            <div class="card-body py-3">
                <div class="text-muted small">Articles</div>
                <div class="fw-bold fs-4">@Model.ArticleCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card text-center border-0 bg-light h-100">
            <div class="card-body py-3">
                <div class="text-muted small">Newspapers</div>
                <div class="fw-bold fs-4">@Model.NewspaperCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card text-center border-0 bg-success text-white h-100">
            <div class="card-body py-3">
                <div class="small opacity-75">Total PR Value</div>
                <div class="fw-bold fs-5">@Model.TotalPRValue.ToString("N2")</div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card text-center border-0 bg-primary text-white h-100">
            <div class="card-body py-3">
                <div class="small opacity-75">Total AD Value</div>
                <div class="fw-bold fs-5">@Model.TotalADValue.ToString("N2")</div>
            </div>
        </div>
    </div>
</div>

<!-- ── Linked Articles ────────────────────────────────────────────────────────── -->
<div class="card shadow-sm mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0"><i class="bi bi-newspaper me-2"></i>Linked Articles (@Model.ArticleCount)</h6>
        @if (Model.Articles.Any())
        {
            <span class="text-muted small">
                PR: <strong>@Model.Articles.Sum(a => a.PRValue).ToString("N2")</strong>
                &nbsp;|&nbsp;
                AD: <strong>@Model.Articles.Sum(a => a.ADValue).ToString("N2")</strong>
            </span>
        }
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th>Title</th>
                        <th>Website</th>
                        <th>Writer</th>
                        <th class="text-end">PR Value</th>
                        <th class="text-end">AD Value</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in Model.Articles)
                    {
                        <tr>
                            <td class="text-nowrap">@a.Date.ToString("yyyy-MM-dd")</td>
                            <td>
                                @if (!string.IsNullOrEmpty(a.ArticleURL))
                                {
                                    <a href="@a.ArticleURL" target="_blank" rel="noopener">@a.Title</a>
                                }
                                else
                                {
                                    @a.Title
                                }
                            </td>
                            <td>@a.WebsiteName</td>
                            <td>@a.WriterName</td>
                            <td class="text-end">@a.PRValue.ToString("N2")</td>
                            <td class="text-end">@a.ADValue.ToString("N2")</td>
                        </tr>
                    }
                    @if (!Model.Articles.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-3">No articles linked.</td>
                        </tr>
                    }
                    else
                    {
                        <tr class="table-light fw-semibold">
                            <td colspan="4" class="text-end">Subtotal</td>
                            <td class="text-end">@Model.Articles.Sum(a => a.PRValue).ToString("N2")</td>
                            <td class="text-end">@Model.Articles.Sum(a => a.ADValue).ToString("N2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- ── Linked Newspapers ──────────────────────────────────────────────────────── -->
<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0"><i class="bi bi-journal-text me-2"></i>Linked Newspapers (@Model.NewspaperCount)</h6>
        @if (Model.Newspapers.Any())
        {
            <span class="text-muted small">
                PR: <strong>@Model.TotalPRValue.ToString("N2")</strong>
                &nbsp;|&nbsp;
                AD: <strong>@Model.TotalADValue.ToString("N2")</strong>
            </span>
        }
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th>Title</th>
                        <th>Publication</th>
                        <th class="text-end">PR Value</th>
                        <th class="text-end">AD Value</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var n in Model.Newspapers)
                    {
                        <tr>
                            <td class="text-nowrap">@n.Date.ToString("yyyy-MM-dd")</td>
                            <td>@n.Title</td>
                            <td>@n.PublicationName</td>
                            <td class="text-end">@n.PRValue.ToString("N2")</td>
                            <td class="text-end">@n.ADValue.ToString("N2")</td>
                        </tr>
                    }
                    @if (!Model.Newspapers.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-3">No newspapers linked.</td>
                        </tr>
                    }
                    else
                    {
                        <tr class="table-light fw-semibold">
                            <td colspan="3" class="text-end">Subtotal</td>
                            <td class="text-end">@Model.TotalPRValue.ToString("N2")</td>
                            <td class="text-end">@Model.TotalADValue.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

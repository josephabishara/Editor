            </div>

            @* ════════════════════════════════════════════════════════════════════ *@
            @* FOOTER — client LOGO instead of name                                 *@
            @* ════════════════════════════════════════════════════════════════════ *@
            @{
                RenderFooter();
            }
            <div class="page-number"></div>
        </div>

        @* ════════════════════════════════════════════════════════════════════ *@
        @* Hidden footer template — JS clones this onto every PDF.js-rendered   *@
        @* cover page, so RenderFooter() stays the single source of truth and   *@
        @* the footer never has to be duplicated inside the <script> block.    *@
        @* ════════════════════════════════════════════════════════════════════ *@
        <template id="footer-template">
            @{
                RenderFooter();
            }
        </template>

    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
    <script>
        function renumberPages() {
        var papers = document.querySelectorAll('.paper');
        papers.forEach(function (paper, index) {
        var label = paper.querySelector('.page-number');
        if (label) label.textContent = 'Page ' + (index + 1);
        });

        // Only now is every page (including the async-rendered PDF cover)
        // guaranteed to be in the DOM — safe to allow printing.
        var printBtn = document.getElementById('btn-print');
        if (printBtn) {
        printBtn.disabled = false;
        printBtn.innerHTML = '&#x1F5A8; Print / Save PDF';
        }
        }

        (function () {
        var container = document.getElementById('cover-pdf-pages');
        if (!container) { renumberPages(); return; } // no cover PDF — number everything now

        var pdfUrl = container.getAttribute('data-pdf-url');
        if (!window.pdfjsLib) { renumberPages(); return; }

        pdfjsLib.GlobalWorkerOptions.workerSrc =
        'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

        pdfjsLib.getDocument(pdfUrl).promise.then(function (pdf) {
        container.innerHTML = '';

        var footerTemplate = document.getElementById('footer-template');

        var renderPage = function (pageNum) {
        return pdf.getPage(pageNum).then(function (page) {
        var viewport = page.getViewport({ scale: 2 });

        var paper = document.createElement('div');
        paper.className = 'paper';

        var coverPage = document.createElement('div');
        coverPage.className = 'cover-page';

        var canvas = document.createElement('canvas');
        canvas.width = viewport.width;
        canvas.height = viewport.height;
        canvas.style.width = '100%';

        var pageNumberLabel = document.createElement('div');
        pageNumberLabel.className = 'page-number';

        coverPage.appendChild(canvas);
        paper.appendChild(coverPage);

        // Clone the report footer onto this dynamically-generated page too,
        // so every page — including PDF.js-rendered cover pages — has one.
        if (footerTemplate && footerTemplate.content) {
        paper.appendChild(footerTemplate.content.cloneNode(true));
        }

        paper.appendChild(pageNumberLabel);
        container.appendChild(paper);

        var ctx = canvas.getContext('2d');
        return page.render({ canvasContext: ctx, viewport: viewport }).promise;
        });
        };

        var chain = Promise.resolve();
        for (var i = 1; i <= pdf.numPages; i++) {
        (function (pageNum) {
        chain = chain.then(function () { return renderPage(pageNum); });
        })(i);
        }
        return chain;
        }).then(function () {
        renumberPages();
        }).catch(function (err) {
        container.innerHTML =
        '<div class="paper"><div class="cover-page"><div class="cover-fallback">' +
        '<h2>Cover PDF could not be loaded</h2>' +
        '<p style="font-size:12px">' + (err && err.message ? err.message : 'Unknown error') + '</p>' +
        '<a class="cover-link" href="' + pdfUrl + '" target="_blank" rel="noopener">Open cover PDF in new tab</a>' +
        '</div></div><div class="page-number"></div></div>';

        var fallbackPaper = container.querySelector('.paper');
        var footerTemplateFallback = document.getElementById('footer-template');
        if (fallbackPaper && footerTemplateFallback && footerTemplateFallback.content) {
        fallbackPaper.appendChild(footerTemplateFallback.content.cloneNode(true));
        }

        renumberPages();
        });
        })();
    </script>
</body>
</html>

@model EditorViewModelLayer.ReportViewModel.ReportDTO

@{
    ViewData["Title"] = "New Report — Step 1 of 3";
}

<div class="row justify-content-center">
    <div class="col-lg-7">

        <!-- Wizard progress -->
        <div class="d-flex align-items-center mb-4">
            <span class="badge bg-primary rounded-pill px-3 py-2 fs-6 me-2">1</span>
            <div class="flex-grow-1 border-top border-2"></div>
            <span class="badge bg-secondary rounded-pill px-3 py-2 fs-6 mx-2">2</span>
            <div class="flex-grow-1 border-top border-2"></div>
            <span class="badge bg-secondary rounded-pill px-3 py-2 fs-6 ms-2">3</span>
        </div>
        <div class="d-flex justify-content-between text-muted small mb-4">
            <span class="fw-bold text-primary">Report Info</span>
            <span>Select Articles</span>
            <span>Select Newspapers</span>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-file-earmark-plus me-2"></i>Report Information</h5>
            </div>
            <div class="card-body">

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        <asp-validation-summary asp-validation-summary="ModelOnly" />
                    </div>
                }

                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="CustomerId" class="form-label fw-semibold">
                            Customer <span class="text-danger">*</span>
                        </label>
                        <select asp-for="CustomerId" asp-items="ViewBag.Customers"
                                class="form-select">
                            <option value="">-- Select Customer --</option>
                        </select>
                        <span asp-validation-for="CustomerId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ReportName" class="form-label fw-semibold">
                            Report Name <span class="text-danger">*</span>
                        </label>
                        <input asp-for="ReportName" class="form-control" placeholder="Enter report name" />
                        <span asp-validation-for="ReportName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ReportDate" class="form-label fw-semibold">Report Date</label>
                        <input asp-for="ReportDate" type="date" class="form-control" />
                        <span asp-validation-for="ReportDate" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ReportType" class="form-label fw-semibold">Report Type</label>
                        <select asp-for="ReportType" asp-items="ViewBag.ReportTypes" class="form-select"></select>
                        <span asp-validation-for="ReportType" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left me-1"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-primary">
                            Next <i class="bi bi-arrow-right ms-1"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

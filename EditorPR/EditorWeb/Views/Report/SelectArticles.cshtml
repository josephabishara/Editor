@model EditorViewModelLayer.ReportViewModel.SaveArticlesViewModel
@{
    ViewData["Title"] = "New Report — Step 2 of 3";
    var report = ViewBag.Report as EditorViewModelLayer.ReportViewModel.ReportDTO;
    var articles = ViewBag.Articles as List<EditorViewModelLayer.ReportViewModel.ReportArticlePickerDTO>
                   ?? new List<EditorViewModelLayer.ReportViewModel.ReportArticlePickerDTO>();
}

<div class="row justify-content-center">
    <div class="col-xl-10">

        <!-- Wizard progress -->
        <div class="d-flex align-items-center mb-4">
            <span class="badge bg-success rounded-pill px-3 py-2 fs-6 me-2"><i class="bi bi-check"></i></span>
            <div class="flex-grow-1 border-top border-2 border-success"></div>
            <span class="badge bg-primary rounded-pill px-3 py-2 fs-6 mx-2">2</span>
            <div class="flex-grow-1 border-top border-2"></div>
            <span class="badge bg-secondary rounded-pill px-3 py-2 fs-6 ms-2">3</span>
        </div>
        <div class="d-flex justify-content-between text-muted small mb-4">
            <span class="text-success fw-bold">Report Info ✓</span>
            <span class="fw-bold text-primary">Select Articles</span>
            <span>Select Newspapers</span>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-newspaper me-2"></i>Select Articles</h5>
                <span class="badge bg-white text-primary">Report: @report?.ReportName</span>
            </div>
            <div class="card-body">

                <!-- Date filter -->
                <form method="get" asp-action="SelectArticles" asp-route-id="@Model.ReportId"
                      class="row g-2 align-items-end mb-3">
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">From Date</label>
                        <input type="date" name="from" class="form-control"
                               value="@Model.From?.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">To Date</label>
                        <input type="date" name="to" class="form-control"
                               value="@Model.To?.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-md-4">
                        <button type="submit" class="btn btn-outline-secondary w-100">
                            <i class="bi bi-funnel me-1"></i> Filter
                        </button>
                    </div>
                </form>

                <form asp-action="SelectArticles" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ReportId" />

                    <!-- Select all -->
                    <div class="mb-2">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="selectAll" />
                            <label class="form-check-label fw-semibold" for="selectAll">
                                Select / Deselect All
                            </label>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-hover table-sm align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th style="width:40px"></th>
                                    <th>Date</th>
                                    <th>Title</th>
                                    <th>Website</th>
                                    <th>Writer</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < articles.Count; i++)
                                {
                                    var a = articles[i];
                                    <tr class="article-row @(a.Selected ? "table-primary" : "")">
                                        <td>
                                            <input type="checkbox"
                                                   name="SelectedArticleIds"
                                                   value="@a.ArticleId"
                                                   class="form-check-input row-check"
                                                   @(a.Selected ? "checked" : "") />
                                        </td>
                                        <td>@a.Date.ToString("yyyy-MM-dd")</td>
                                        <td>@a.Title</td>
                                        <td>@a.WebsiteName</td>
                                        <td>@a.WriterName</td>
                                    </tr>
                                }
                                @if (!articles.Any())
                                {
                                    <tr>
                                        <td colspan="5" class="text-center text-muted py-4">
                                            No published articles found for the selected date range.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="d-flex justify-content-between mt-3">
                        <a asp-action="Edit" asp-route-id="@Model.ReportId"
                           class="btn btn-secondary">
                            <i class="bi bi-arrow-left me-1"></i> Back
                        </a>
                        <button type="submit" class="btn btn-primary">
                            Next <i class="bi bi-arrow-right ms-1"></i>
                        </button>
                    </div>
                </form>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('selectAll').addEventListener('change', function () {
            document.querySelectorAll('.row-check').forEach(cb => cb.checked = this.checked);
        });
    </script>
}

@model EditorViewModelLayer.ReportViewModel.SaveNewspapersViewModel
@{
    ViewData["Title"] = "New Report — Step 3 of 3";
    var report = ViewBag.Report as EditorViewModelLayer.ReportViewModel.ReportDTO;
    var newspapers = ViewBag.Newspapers as List<EditorViewModelLayer.ReportViewModel.ReportNewspaperPickerDTO>
                     ?? new List<EditorViewModelLayer.ReportViewModel.ReportNewspaperPickerDTO>();
}

<div class="row justify-content-center">
    <div class="col-xl-10">

        <!-- Wizard progress -->
        <div class="d-flex align-items-center mb-4">
            <span class="badge bg-success rounded-pill px-3 py-2 fs-6 me-2"><i class="bi bi-check"></i></span>
            <div class="flex-grow-1 border-top border-2 border-success"></div>
            <span class="badge bg-success rounded-pill px-3 py-2 fs-6 mx-2"><i class="bi bi-check"></i></span>
            <div class="flex-grow-1 border-top border-2 border-success"></div>
            <span class="badge bg-primary rounded-pill px-3 py-2 fs-6 ms-2">3</span>
        </div>
        <div class="d-flex justify-content-between text-muted small mb-4">
            <span class="text-success fw-bold">Report Info ✓</span>
            <span class="text-success fw-bold">Articles ✓</span>
            <span class="fw-bold text-primary">Select Newspapers</span>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-journal-text me-2"></i>Select Newspapers</h5>
                <span class="badge bg-white text-primary">Report: @report?.ReportName</span>
            </div>
            <div class="card-body">

                <!-- Date filter -->
                <form method="get" asp-action="SelectNewspapers" asp-route-id="@Model.ReportId"
                      class="row g-2 align-items-end mb-3">
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">From Date</label>
                        <input type="date" name="from" class="form-control"
                               value="@Model.From?.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">To Date</label>
                        <input type="date" name="to" class="form-control"
                               value="@Model.To?.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-md-4">
                        <button type="submit" class="btn btn-outline-secondary w-100">
                            <i class="bi bi-funnel me-1"></i> Filter
                        </button>
                    </div>
                </form>

                <form asp-action="SelectNewspapers" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ReportId" />

                    <div class="mb-2">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="selectAll" />
                            <label class="form-check-label fw-semibold" for="selectAll">
                                Select / Deselect All
                            </label>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-hover table-sm align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th style="width:40px"></th>
                                    <th>Date</th>
                                    <th>Title</th>
                                    <th class="text-end">PR Value</th>
                                    <th class="text-end">AD Value</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var n in newspapers)
                                {
                                    <tr class="@(n.Selected ? "table-primary" : "")">
                                        <td>
                                            <input type="checkbox"
                                                   name="SelectedNewspaperIds"
                                                   value="@n.NewspaperId"
                                                   class="form-check-input row-check"
                                                   @(n.Selected ? "checked" : "") />
                                        </td>
                                        <td>@n.Date.ToString("yyyy-MM-dd")</td>
                                        <td>@n.Title</td>
                                        <td class="text-end">@n.PRValue.ToString("N2")</td>
                                        <td class="text-end">@n.ADValue.ToString("N2")</td>
                                    </tr>
                                }
                                @if (!newspapers.Any())
                                {
                                    <tr>
                                        <td colspan="5" class="text-center text-muted py-4">
                                            No published newspapers found for the selected date range.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="d-flex justify-content-between mt-3">
                        <a asp-action="SelectArticles" asp-route-id="@Model.ReportId"
                           class="btn btn-secondary">
                            <i class="bi bi-arrow-left me-1"></i> Back
                        </a>
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle me-1"></i> Finish
                        </button>
                    </div>
                </form>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('selectAll').addEventListener('change', function () {
            document.querySelectorAll('.row-check').forEach(cb => cb.checked = this.checked);
        });
    </script>
}

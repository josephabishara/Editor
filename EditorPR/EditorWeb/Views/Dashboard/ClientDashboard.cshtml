@model EditorViewModelLayer.ClientViewModel.ClientDashboardDTO

@{
    ViewData["Title"] = "Client Dashboard";
}

@await Html.PartialAsync("_ClientStyles")
<div class="container-fluid dashboard-wrapper">

    <div class="dashboard-header mb-4">

        <a asp-action="Index"
           asp-controller="Dashboard"
           class="back-link">
            <i class="bi bi-arrow-left"></i>
            Back To Dashboard
        </a>

        <div class="row d-flex align-items-center justify-content-between flex-wrap gap-4 client-header-content">

            <form method="get"
                  asp-action="ClientDashboard"
                  asp-controller="Dashboard"
                  class="row d-flex align-items-center justify-content-between flex-wrap gap-4 client-header-content">

                <input type="hidden" name="id" value="@Model.ClientId" />

                <div class="col-md-5 d-flex align-items-center gap-4 flex-wrap">
                    <img src="@Model.Photo" class="client-avatar" alt="@Model.Name" />
                    <div>
                        <h1 class="client-name">@Model.Name</h1>
                        <div class="client-email">
                            <i class="bi bi-envelope"></i> @Model.Email
                        </div>
                    </div>
                </div>

                <div class="col-md-2">
                    <input type="date"
                           name="from"
                           value="@Model.DateFrom?.ToString("yyyy-MM-dd")"
                           class="form-control fs-6 rounded-pill shadow-sm"
                           placeholder="From" />
                </div>

                <div class="col-md-2">
                    <input type="date"
                           name="to"
                           value="@Model.DateTo?.ToString("yyyy-MM-dd")"
                           class="form-control fs-6 rounded-pill shadow-sm"
                           placeholder="To" />
                </div>

                <div class="col-md-1">
                    <button type="submit" class="btn btn-outline-light w-100">
                        <i class="bi bi-funnel"></i> Filter
                    </button>
                </div>

            </form>
         
        </div>
    </div>

    <div class="row g-4 stats-grid">

        <div class="col-lg-4 col-md-6">
            <div class="dashboard-card articles-card">

                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="metric-title">Articles (Website)</div>
                        <div class="metric-number">@Model.ArticleCount.ToString("N0")</div>
                    </div>

                    <div class="card-icon icon-primary">
                        <i class="bi bi-newspaper"></i>
                    </div>
                </div>

                <div class="metric-details d-flex justify-content-between align-items-center">
                    <div>
                        <div class="metric-label">Total PR Value</div>
                        <div class="metric-value">@Model.ArticleTotalPR.ToString("N2")</div>
                    </div>

                    <i class="bi bi-graph-up-arrow text-success fs-4"></i>
                </div>

                <a asp-action="Index"
                   asp-controller="ClientArticle"
                   asp-route-clientId="@Model.ClientId"
                   class="btn btn-primary w-100 dashboard-btn">
                    Open Articles
                </a>

            </div>
        </div>

        <div class="col-lg-4 col-md-6">
            <div class="dashboard-card publications-card">

                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="metric-title">Publications (Print)</div>
                        <div class="metric-number">@Model.NewsPaperCount.ToString("N0")</div>
                    </div>

                    <div class="card-icon icon-warning">
                        <i class="bi bi-journal-richtext"></i>
                    </div>
                </div>

                <div class="metric-details d-flex justify-content-between align-items-center">
                    <div>
                        <div class="metric-label">Total PR Value</div>
                        <div class="metric-value">@Model.NewsPaperTotalPR.ToString("N2")</div>
                    </div>

                    <i class="bi bi-bar-chart-line text-warning fs-4"></i>
                </div>

                <a asp-action="Index"
                   asp-controller="ClientNewsPaper"
                   asp-route-clientId="@Model.ClientId"
                   class="btn btn-warning w-100 dashboard-btn text-dark">
                    Open Publications
                </a>

            </div>
        </div>

        <div class="col-lg-4 col-md-6">
            <div class="dashboard-card videos-card">

                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="metric-title">Videos (TV / Channels)</div>
                        <div class="metric-number">@Model.VideoCount.ToString("N0")</div>
                    </div>

                    <div class="card-icon icon-danger">
                        <i class="bi bi-play-circle-fill"></i>
                    </div>
                </div>

                <div class="metric-details">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="metric-label">Total AD Value</span>
                        <strong>@Model.VideoTotalAD.ToString("N2")</strong>
                    </div>

                    <div class="d-flex justify-content-between">
                        <span class="metric-label">Total PR Value</span>
                        <strong class="text-success">@Model.VideoTotalPR.ToString("N2")</strong>
                    </div>
                </div>

                <a asp-action="Index"
                   asp-controller="ClientVideo"
                   asp-route-clientId="@Model.ClientId"
                   class="btn btn-danger w-100 dashboard-btn">
                    Open Videos
                </a>

            </div>
        </div>

    </div>

    <div class="overview-panel">

        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
            <h3 class="overview-title mb-0">Performance Overview</h3>

            <span class="badge bg-success px-3 py-2 rounded-pill">
                @if (Model.DateFrom.HasValue || Model.DateTo.HasValue)
                {
                    @($"{Model.DateFrom?.ToString("dd MMM yyyy") ?? "Start"} → {Model.DateTo?.ToString("dd MMM yyyy") ?? "Today"}")
                }
                else
                {
                    <span>All Time</span>
                }
            </span>
        </div>

        <div class="row">

            <div class="col-md-4">
                <div class="overview-item">
                    <h6>Total Articles</h6>
                    <p>@Model.ArticleCount.ToString("N0") active media articles published.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="overview-item">
                    <h6>Total Publications</h6>
                    <p>@Model.NewsPaperCount.ToString("N0") print publications tracked.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="overview-item">
                    <h6>Total Videos</h6>
                    <p>@Model.VideoCount.ToString("N0") TV and media videos monitored.</p>
                </div>
            </div>

        </div>

    </div>

</div> 
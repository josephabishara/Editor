@model EditorViewModelLayer.ClientViewModel.ClientDashboardDTO
@{
    ViewData["Title"] = "Client Dashboard";
}

<div class="container-fluid py-4">
    
      
   
   @*  {{!-- Client header --}} *@
    <div class="d-flex align-items-center gap-3 mb-4">
        <a asp-action="Index" asp-controller="Dashboard"
           style="display:inline-flex;align-items:center;gap:.4rem;color:var(--slate);font-size:.82rem;text-decoration:none;margin-bottom:1.25rem;">
            ← Back Dashboard
        </a>  <img src="@Model.Photo" class="rounded-circle" width="150" height="150" />
        <div>
            <h4 class="mb-0">@Model.Name</h4>
            <small class="text-muted">@Model.Email</small>
        </div>
    </div>

 @*    {{!-- KPI Cards row --}} *@
    <div class="row g-3 mb-4">

       @*  {{!-- Articles --}} *@
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-1 small">Articles (Web)</p>
                            <h3 class="fw-bold mb-0">@Model.ArticleCount.ToString("N0")</h3>
                        </div>
                        <span class="badge bg-primary fs-6 p-2">
                            <i class="bi bi-newspaper"></i>
                        </span>
                    </div>
                    <hr class="my-2" />
                    <p class="mb-0 small">
                        Total PR Value:
                        <strong class="text-success">@Model.ArticleTotalPR.ToString("N2")</strong>
                    </p>
                    <a asp-action="Index" asp-controller="ClientArticle" asp-route-clientId="@Model.ClientId" class="btn btn-primary btn-lg btn-block"> See Website</a>
                </div>
            </div>
        </div>

    @*     {{!-- Newspapers --}} *@
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-1 small">Publications (Print)</p>
                            <h3 class="fw-bold mb-0">@Model.NewsPaperCount.ToString("N0")</h3>
                        </div>
                        <span class="badge bg-warning text-dark fs-6 p-2">
                            <i class="bi bi-journal-text"></i>
                        </span>
                    </div>
                    <hr class="my-2" />
                    <p class="mb-0 small">
                        Total PR Value:
                        <strong class="text-success">@Model.NewsPaperTotalPR.ToString("N2")</strong>
                    </p>
                    <a asp-action="Index" asp-controller="ClientNewsPaper" asp-route-clientId="@Model.ClientId" class="btn btn-primary btn-lg btn-block"> See Publication</a>
                </div>
            </div>
        </div>

       @*  {{!-- Videos --}} *@
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-1 small">Videos (TV/Channel)</p>
                            <h3 class="fw-bold mb-0">@Model.VideoCount.ToString("N0")</h3>
                        </div>
                        <span class="badge bg-danger fs-6 p-2">
                            <i class="bi bi-play-circle"></i>
                        </span>
                    </div>
                    <hr class="my-2" />
                    <p class="mb-0 small">
                        AD: <strong>@Model.VideoTotalAD.ToString("N2")</strong> &nbsp;|&nbsp;
                        PR: <strong class="text-success">@Model.VideoTotalPR.ToString("N2")</strong>
                    </p>
                    <a asp-action="Index" asp-controller="ClientVideo" asp-route-clientId="@Model.ClientId" class="btn btn-primary btn-lg btn-block"> See Videos</a>
                </div>
            </div>
        </div>

    </div>

  @*   {{!-- Grand Total row --}} *@
    <div class="row">
        
        <div class="col-md-6">
            <div class="card border-0 bg-dark text-white shadow-sm">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Grand Total PR Value</h5>
                    <h3 class="mb-0 text-warning">@Model.GrandTotalPR.ToString("N2")</h3>
                </div>
            </div>
        </div>
    </div>

</div>
 
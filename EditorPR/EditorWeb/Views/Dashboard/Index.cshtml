@model IEnumerable<EditorViewModelLayer.ClientViewModel.ClientDTO>
@{
    ViewData["Title"] = "Clients";
}

<div class="container-fluid mt-4">
    <div class="row">
        @if (!Model.Any())
        {
            
                <span colspan="7" class="text-center text-muted py-4">No clients found.</span>
            
        }
        @foreach (var c in Model)
        {

            <div class="col-md-3 p-3"  >
            <div class="card " >
                    <img class="card-img-top img-thumbnail"  src="@c.Photo" alt="@c.Name" >
                <div class="card-body">
                    <h4 class="card-title"> @c.Name  </h4>
                    
                    <a asp-action="ClientDashboard" asp-route-id="@c.Id" class="btn btn-dark">Dashboard</a>
                </div>
            </div>
            </div>
                
        }
    </div>
    </div>

